<script>
(function(){
  var token = null;
  try { token = localStorage.getItem('finovate_token'); } catch(e){}
  var login = document.getElementById('fh-nav-login');
  var dash  = document.getElementById('fh-nav-dashboard');
  var out   = document.getElementById('fh-nav-logout');
  if (token) {
    if(login) login.style.display='none';
    if(dash)  dash.style.display='';
    if(out)   out.style.display='';
    fetch('/api/me', { headers: { 'Authorization': 'Bearer ' + token } })
      .then(function(r){ return r.json(); })
      .then(function(d){
        var t = document.getElementById('fh-welcome-title');
        var s = document.getElementById('fh-welcome-sub');
        if(t) t.textContent = 'Bienvenue, ' + (d.prenom||'') + ' ' + (d.nom||'');
        if(s) s.textContent = 'Voici un résumé de votre compte.';
      }).catch(function(){});
  }
})();
</script>
