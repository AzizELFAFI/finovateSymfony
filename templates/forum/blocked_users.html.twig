{% extends 'forum/_layout.html.twig' %}
{% block title %}Utilisateurs bloqués & restreints{% endblock %}
{% block page_title %}Utilisateurs bloqués & restreints{% endblock %}
{% block page_subtitle %}Gérez les utilisateurs que vous avez bloqués ou restreints{% endblock %}
{% block content %}
<div style="max-width:800px;margin:0 auto;padding:30px 20px 60px">
    <h1 style="font-size:24px;font-weight:800;margin-bottom:6px;color:#1a1a1b">🚫 Utilisateurs bloqués & restreints</h1>
    <p style="color:#888;font-size:14px;margin-bottom:30px">Gérez les utilisateurs que vous avez bloqués ou restreints.</p>

    {% for msg in app.flashes('success') %}
    <div style="background:#f0fdf4;border:1px solid #237f4e;color:#237f4e;padding:12px 16px;border-radius:8px;margin-bottom:16px">{{ msg }}</div>
    {% endfor %}

    {# Blocked users #}
    <div style="margin-bottom:40px">
        <h2 style="font-size:17px;font-weight:700;margin-bottom:16px;padding-bottom:10px;border-bottom:2px solid #f0f0f0">🚫 Bloqués ({{ blocks|length }})</h2>
        {% if blocks is empty %}
        <p style="color:#aaa;font-size:14px">Aucun utilisateur bloqué.</p>
        {% else %}
        {% for block in blocks %}
        <div style="display:flex;align-items:center;gap:14px;padding:14px;border:1px solid #e0e0e0;border-radius:10px;margin-bottom:10px">
            <div style="width:40px;height:40px;border-radius:50%;background:#1a1a1b;color:white;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;flex-shrink:0">
                {{ block.blocked.firstname|first|upper }}
            </div>
            <div style="flex:1">
                <div style="font-weight:700;color:#1a1a1b">{{ block.blocked.firstname }} {{ block.blocked.lastname }}</div>
                <div style="font-size:12px;color:#888">{{ block.blocked.email }} · Bloqué le {{ block.createdAt|date('d/m/Y') }}</div>
                {% if block.reason %}<div style="font-size:12px;color:#555;margin-top:3px">Raison : {{ block.reason }}</div>{% endif %}
            </div>
            <form method="post" action="{{ path('app_user_unblock', {id: block.blocked.id}) }}">
                <button type="submit" style="background:#237f4e;color:white;border:none;padding:8px 16px;border-radius:6px;font-size:13px;font-weight:600;cursor:pointer">Débloquer</button>
            </form>
        </div>
        {% endfor %}
        {% endif %}
    </div>

    {# Restricted users #}
    <div>
        <h2 style="font-size:17px;font-weight:700;margin-bottom:16px;padding-bottom:10px;border-bottom:2px solid #f0f0f0">⏱ Restreints ({{ restrictions|length }})</h2>
        {% if restrictions is empty %}
        <p style="color:#aaa;font-size:14px">Aucun utilisateur restreint.</p>
        {% else %}
        {% for r in restrictions %}
        <div style="display:flex;align-items:center;gap:14px;padding:14px;border:1px solid #e0e0e0;border-radius:10px;margin-bottom:10px">
            <div style="width:40px;height:40px;border-radius:50%;background:#f59e0b;color:white;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;flex-shrink:0">
                {{ r.restricted.firstname|first|upper }}
            </div>
            <div style="flex:1">
                <div style="font-weight:700;color:#1a1a1b">{{ r.restricted.firstname }} {{ r.restricted.lastname }}</div>
                <div style="font-size:12px;color:#888">
                    {{ r.restricted.email }} · Restreint le {{ r.createdAt|date('d/m/Y') }}
                    {% if r.restrictedUntil %} · Jusqu'au {{ r.restrictedUntil|date('d/m/Y') }}{% else %} · Indéfini{% endif %}
                </div>
                {% if r.reason %}<div style="font-size:12px;color:#555;margin-top:3px">Raison : {{ r.reason }}</div>{% endif %}
            </div>
            <form method="post" action="{{ path('app_user_unrestrict', {id: r.restricted.id}) }}">
                <button type="submit" style="background:#237f4e;color:white;border:none;padding:8px 16px;border-radius:6px;font-size:13px;font-weight:600;cursor:pointer">Lever</button>
            </form>
        </div>
        {% endfor %}
        {% endif %}
    </div>
</div>
{% endblock %}

