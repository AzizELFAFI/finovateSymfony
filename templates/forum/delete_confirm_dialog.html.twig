{% extends 'base.html.twig' %}

{% block title %}Confirmation - FINOVATE{% endblock %}

{% block body %}
<div class="dialog-overlay">
    <div class="delete-confirm-dialog">
        <!-- Warning Icon -->
        <div class="warning-icon">⚠</div>

        <!-- Title -->
        <h2 class="dialog-title">Confirm Deletion</h2>

        <!-- Message -->
        <p class="dialog-message">Are you sure you want to delete this user?</p>

        <!-- User Info -->
        <p class="user-info" id="userInfo">
            <!-- User details will be inserted here -->
        </p>

        <!-- Warning Note -->
        <p class="warning-note">This action cannot be undone.</p>

        <!-- Action Buttons -->
        <div class="dialog-actions">
            <button class="btn-cancel" onclick="handleCancel()">Cancel</button>
            <button class="btn-delete" onclick="handleDelete()">Delete User</button>
        </div>
    </div>
</div>

<style>
    .dialog-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .delete-confirm-dialog {
        background: white;
        border-radius: 12px;
        padding: 30px;
        width: 450px;
        max-width: 90%;
        text-align: center;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    }

    .warning-icon {
        font-size: 48px;
        color: #ffc107;
        margin-bottom: 15px;
    }

    .dialog-title {
        color: #495057;
        font-size: 20px;
        font-weight: bold;
        margin: 0 0 10px 0;
    }

    .dialog-message {
        color: #6c757d;
        font-size: 14px;
        margin: 0 0 10px 0;
    }

    .user-info {
        color: #495057;
        font-size: 13px;
        font-weight: bold;
        margin: 0 0 25px 0;
    }

    .warning-note {
        color: #dc3545;
        font-size: 12px;
        margin: 0 0 25px 0;
    }

    .dialog-actions {
        display: flex;
        gap: 15px;
        justify-content: center;
    }

    .btn-cancel,
    .btn-delete {
        flex: 1;
        padding: 12px 30px;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-cancel {
        background: #6c757d;
        color: white;
    }

    .btn-cancel:hover {
        background: #5a6268;
        transform: translateY(-2px);
    }

    .btn-delete {
        background: #dc3545;
        color: white;
    }

    .btn-delete:hover {
        background: #c82333;
        transform: translateY(-2px);
    }
</style>

<script>
function handleCancel() {
    window.history.back();
}

function handleDelete() {
    // Add delete logic here
    console.log('Deleting user...');
    // After deletion, redirect or close dialog
}
</script>
{% endblock %}
