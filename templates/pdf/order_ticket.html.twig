<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Ticket de commande - Finovate</title>
    <style>
        @page {
            margin: 20mm;
        }
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            margin: 0;
            padding: 0;
            color: #333;
            font-size: 12pt;
        }
        .container {
            max-width: 100%;
        }
        .header {
            text-align: center;
            border-bottom: 3px solid #0f766e;
            padding-bottom: 20px;
            margin-bottom: 25px;
        }
        .logo {
            font-size: 28pt;
            font-weight: bold;
            color: #0f766e;
            margin-bottom: 5px;
        }
        .subtitle {
            color: #6b7280;
            font-size: 11pt;
        }
        .order-number {
            background: #0f766e;
            color: white;
            padding: 8px 20px;
            display: inline-block;
            border-radius: 20px;
            font-weight: bold;
            margin-top: 15px;
        }
        .info-section {
            margin-bottom: 25px;
        }
        .info-title {
            font-size: 10pt;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }
        .info-value {
            font-size: 14pt;
            font-weight: bold;
            color: #111;
        }
        .info-grid {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
        }
        .info-box {
            width: 48%;
            background: #f9fafb;
            padding: 15px;
            border-radius: 8px;
            border-left: 4px solid #0f766e;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 25px;
        }
        th {
            background: #0f766e;
            color: white;
            padding: 12px 10px;
            text-align: left;
            font-size: 10pt;
            text-transform: uppercase;
        }
        th:last-child {
            text-align: right;
        }
        th:nth-child(2) {
            text-align: center;
        }
        td {
            padding: 12px 10px;
            border-bottom: 1px solid #e5e7eb;
        }
        td:last-child {
            text-align: right;
        }
        td:nth-child(2) {
            text-align: center;
        }
        .total-row {
            background: rgba(15, 118, 110, 0.1);
            font-weight: bold;
        }
        .total-row td {
            font-size: 14pt;
            padding: 15px 10px;
        }
        .points-badge {
            background: linear-gradient(135deg, #f59e0b, #fbbf24);
            color: white;
            padding: 4px 12px;
            border-radius: 15px;
            font-weight: bold;
        }
        .summary-box {
            background: #f9fafb;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 25px;
        }
        .summary-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px dashed #e5e7eb;
        }
        .summary-row:last-child {
            border-bottom: none;
        }
        .footer {
            text-align: center;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 2px dashed #e5e7eb;
        }
        .footer p {
            color: #9ca3af;
            font-size: 9pt;
            margin: 5px 0;
        }
        .thank-you {
            font-size: 16pt;
            color: #0f766e;
            font-weight: bold;
            margin-bottom: 10px;
        }
        .barcode {
            margin-top: 20px;
            text-align: center;
        }
        .barcode-text {
            font-family: 'Courier New', monospace;
            font-size: 10pt;
            letter-spacing: 3px;
            color: #333;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="logo">FINOVATE</div>
            <div class="subtitle">Votre banque digitale</div>
            <div class="order-number">{{ orderNumber }}</div>
        </div>

        <div class="info-grid">
            <div class="info-box">
                <div class="info-title">Client</div>
                <div class="info-value">{{ user.firstname }} {{ user.lastname }}</div>
                <div style="color: #6b7280; font-size: 10pt; margin-top: 5px;">{{ user.email }}</div>
            </div>
            <div class="info-box">
                <div class="info-title">Date de commande</div>
                <div class="info-value">{{ orderDate|date('d/m/Y') }}</div>
                <div style="color: #6b7280; font-size: 10pt; margin-top: 5px;">{{ orderDate|date('H:i') }}</div>
            </div>
        </div>

        <table>
            <thead>
                <tr>
                    <th>Produit</th>
                    <th>Quantité</th>
                    <th>Sous-total</th>
                </tr>
            </thead>
            <tbody>
                {% for item in items %}
                <tr>
                    <td>{{ item.product.name }}</td>
                    <td>{{ item.quantity }}</td>
                    <td><span class="points-badge">{{ item.subtotal }} pts</span></td>
                </tr>
                {% endfor %}
                <tr class="total-row">
                    <td colspan="2">TOTAL</td>
                    <td><span class="points-badge" style="font-size: 14pt;">{{ totalPoints }} pts</span></td>
                </tr>
            </tbody>
        </table>

        <div class="summary-box">
            <div class="summary-row">
                <span>Nombre d'articles</span>
                <span><strong>{{ items|length }}</strong></span>
            </div>
            <div class="summary-row">
                <span>Points utilisés</span>
                <span><strong>{{ totalPoints }} pts</strong></span>
            </div>
            <div class="summary-row">
                <span>Nouveau solde de points</span>
                <span><strong style="color: #0f766e;">{{ newPoints }} pts</strong></span>
            </div>
        </div>

        <div class="footer">
            <div class="thank-you">Merci pour votre achat !</div>
            <p>Ce ticket constitue votre preuve d'achat. Conservez-le précieusement.</p>
            <p>En cas de problème, contactez notre support à support@finovate.com</p>
            <p>© {{ "now"|date('Y') }} FINOVATE - Tous droits réservés</p>
        </div>

        <div class="barcode">
            <div class="barcode-text">{{ orderNumber }}</div>
        </div>
    </div>
</body>
</html>
