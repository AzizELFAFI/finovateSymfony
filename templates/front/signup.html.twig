    <style>
      .fin-login-card {
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 18px 55px rgba(0, 0, 0, 0.12);
        padding: 28px;
        border: 1px solid rgba(26, 95, 58, 0.08);
      }
      .fin-login-title {
        margin-bottom: 14px;
        font-weight: 800;
        color: #1a5f3a;
        letter-spacing: -0.5px;
      }
      .fin-login-subtitle {
        color: #6b7280;
        font-size: 0.95rem;
        margin-bottom: 18px;
      }
      .fin-input {
        height: 48px;
        border-radius: 12px;
        border: 2px solid #e5e7eb;
        padding: 10px 14px;
        transition: border-color .15s ease, box-shadow .15s ease;
        background: #ffffff;
      }
      .fin-input:focus {
        border-color: #237f4e;
        box-shadow: 0 0 0 .2rem rgba(35, 127, 78, .15);
      }
      .fin-actions {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-top: 12px;
      }
      .fin-links {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 10px;
        margin-top: 10px;
      }
      .fin-links a {
        font-weight: 600;
      }

      .voice-field {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .voice-btn {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        border: 2px solid #e5e7eb;
        background: #ffffff;
        color: #237f4e;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all .15s ease;
        cursor: pointer;
        flex: 0 0 auto;
      }

      .voice-btn:hover {
        border-color: #237f4e;
        box-shadow: 0 0 0 .2rem rgba(35, 127, 78, .12);
      }

      .voice-btn[disabled] {
        opacity: 0.6;
        cursor: not-allowed;
      }

      .voice-btn.is-listening {
        background: rgba(35, 127, 78, 0.08);
        border-color: #237f4e;
      }

      .voice-status {
        margin-top: 12px;
        display: none;
        border-radius: 12px;
      }

      .dictate-all-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        border-radius: 12px;
        border: 2px solid #237f4e;
        background: linear-gradient(135deg, #1a5f3a 0%, #237f4e 100%);
        color: #ffffff;
        font-weight: 600;
        cursor: pointer;
        transition: all .15s ease;
        margin-bottom: 16px;
      }

      .dictate-all-btn:hover {
        box-shadow: 0 4px 12px rgba(35, 127, 78, 0.3);
        transform: translateY(-1px);
      }

      .dictate-all-btn[disabled] {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
      }

      .dictate-all-btn.is-listening {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        border-color: #dc3545;
        animation: pulse 1.5s infinite;
      }

      @keyframes pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.4); }
        50% { box-shadow: 0 0 0 10px rgba(220, 53, 69, 0); }
      }
    </style>

  </head>

