    <script>
      (function () {
        var loginItem = document.getElementById('nav-login');
        var dashboardItem = document.getElementById('nav-dashboard');
        var logoutItem = document.getElementById('nav-logout');

        if (loginItem && dashboardItem && logoutItem) {
          var token = null;
          try {
            token = localStorage.getItem('finovate_token') || sessionStorage.getItem('finovate_token');
          } catch (e) {}

          var isAuthed = !!token;
          loginItem.style.display = isAuthed ? 'none' : '';
          dashboardItem.style.display = isAuthed ? '' : 'none';
          logoutItem.style.display = isAuthed ? '' : 'none';
        }

        var form = document.getElementById('signup');
        if (!form) return;

        var voiceStatus = document.createElement('div');
        voiceStatus.className = 'alert alert-info voice-status';
        voiceStatus.setAttribute('role', 'alert');
        voiceStatus.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="margin-right:8px;"></span><span id="voice-status-text">Écoute en cours...</span>';
        form.prepend(voiceStatus);

        function setVoiceStatus(show, text) {
          if (!voiceStatus) return;
          if (show) {
            var t = document.getElementById('voice-status-text');
            if (t) t.textContent = text || 'Écoute en cours...';
            voiceStatus.style.display = '';
          } else {
            voiceStatus.style.display = 'none';
          }
        }

        function createMicButton() {
          var btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'voice-btn';
          btn.setAttribute('aria-label', 'Saisie vocale');
          btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" style="width:18px; height:18px;"><path d="M12 14a3 3 0 003-3V7a3 3 0 10-6 0v4a3 3 0 003 3z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M19 11a7 7 0 01-14 0" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 19v3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 22h8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
          return btn;
        }

        var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        var supportsSpeech = !!SpeechRecognition;

        // Dictate all button logic
        var dictateAllBtn = document.getElementById('dictate-all-btn');
        var dictateAllText = document.getElementById('dictate-all-text');

        async function extractAllFieldsWithAi(transcript) {
          var res = await fetch('/api/ai/signup-all', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ transcript: transcript })
          });
          var data = await res.json().catch(function () { return {}; });
          if (!res.ok) {
            throw new Error(data.message || 'IA indisponible.');
          }
          return data;
        }

        function startDictateAll() {
          if (!supportsSpeech) {
            showSignupError('Saisie vocale non supportée par ce navigateur. Utilisez Chrome/Edge.');
            return;
          }

          var rec = new SpeechRecognition();
          rec.lang = 'fr-FR';
          rec.interimResults = false;
          rec.maxAlternatives = 1;

          dictateAllBtn.classList.add('is-listening');
          dictateAllBtn.disabled = true;
          dictateAllText.textContent = 'Parle maintenant...';

          clearSignupError();
          setVoiceStatus(true, 'Dicte tes informations personnelles (nom, prenom, email, date de naissance, CIN, telephone)...');

          var finished = false;
          function cleanup() {
            if (finished) return;
            finished = true;
            setVoiceStatus(false);
            dictateAllBtn.classList.remove('is-listening');
            dictateAllBtn.disabled = false;
            dictateAllText.textContent = 'Dicter tout le formulaire';
          }

          rec.onerror = function () {
            cleanup();
            showSignupError('Erreur de reconnaissance vocale.');
          };

          rec.onresult = async function (evt) {
            try {
              var transcript = '';
              if (evt && evt.results && evt.results[0] && evt.results[0][0]) {
                transcript = (evt.results[0][0].transcript || '').trim();
              }
              if (!transcript) {
                cleanup();
                showSignupError('Aucun texte detecte.');
                return;
              }

              setVoiceStatus(true, 'Analyse IA en cours...');
              var fields = await extractAllFieldsWithAi(transcript);
              cleanup();

              // Fill each field if value exists
              var fieldMap = {
                nom: 'nom',
                prenom: 'prenom',
                email: 'email',
                date_naissance: 'date_naissance',
                cin: 'cin',
                telephone: 'telephone'
              };

              var filledCount = 0;
              Object.keys(fieldMap).forEach(function (key) {
                var val = fields[key];
                if (val && typeof val === 'string' && val.trim() !== '') {
                  var input = document.getElementById(fieldMap[key]);
                  if (input) {
                    input.value = val.trim();
                    filledCount++;
                  }
                }
              });

              if (filledCount === 0) {
                showSignupError('Aucune information reconnue. Resseye en parlant plus clairement.');
              }
            } catch (e) {
              cleanup();
              showSignupError((e && e.message) ? e.message : 'Erreur IA.');
            }
          };

          rec.onend = function () {
            cleanup();
          };

          try {
            rec.start();
          } catch (e) {
            cleanup();
            showSignupError('Impossible de demarrer le micro.');
          }
        }

        if (dictateAllBtn) {
          dictateAllBtn.addEventListener('click', startDictateAll);
          if (!supportsSpeech) {
            dictateAllBtn.disabled = true;
          }
        }

        async function extractFieldWithAi(field, transcript) {
          var res = await fetch('/api/ai/signup-field', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ field: field, transcript: transcript })
          });

          var data = await res.json().catch(function () { return {}; });
          if (!res.ok) {
            throw new Error(data.message || 'IA indisponible.');
          }
          return (data && typeof data.value === 'string') ? data.value : '';
        }

        function startVoiceForField(field, inputEl, btnEl) {
          if (!supportsSpeech) {
            showSignupError('Saisie vocale non supportée par ce navigateur. Utilisez Chrome/Edge.');
            return;
          }
          if (!inputEl) return;

          var rec = new SpeechRecognition();
          rec.lang = 'fr-FR';
          rec.interimResults = false;
          rec.maxAlternatives = 1;

          if (btnEl) {
            btnEl.classList.add('is-listening');
            btnEl.disabled = true;
          }

          clearSignupError();
          setVoiceStatus(true, 'Parle maintenant...');

          var finished = false;
          function cleanup() {
            if (finished) return;
            finished = true;
            setVoiceStatus(false);
            if (btnEl) {
              btnEl.classList.remove('is-listening');
              btnEl.disabled = false;
            }
          }

          rec.onerror = function () {
            cleanup();
            showSignupError('Erreur de reconnaissance vocale.');
          };

          rec.onresult = async function (evt) {
            try {
              var transcript = '';
              if (evt && evt.results && evt.results[0] && evt.results[0][0]) {
                transcript = (evt.results[0][0].transcript || '').trim();
              }
              if (!transcript) {
                cleanup();
                showSignupError('Aucun texte détecté.');
                return;
              }

              setVoiceStatus(true, 'Analyse IA en cours...');
              var value = await extractFieldWithAi(field, transcript);
              cleanup();

              if (!value) {
                showSignupError('Impossible de comprendre. Réessaie en parlant plus clairement.');
                return;
              }

              inputEl.value = value;
              try { inputEl.focus(); } catch (e) {}
            } catch (e) {
              cleanup();
              showSignupError((e && e.message) ? e.message : 'Erreur IA.');
            }
          };

          rec.onend = function () {
            cleanup();
          };

          try {
            rec.start();
          } catch (e) {
            cleanup();
            showSignupError('Impossible de démarrer le micro.');
          }
        }

        var voiceFields = [
          { field: 'nom', id: 'nom' },
          { field: 'prenom', id: 'prenom' },
          { field: 'email', id: 'email' },
          { field: 'date_naissance', id: 'date_naissance' },
          { field: 'cin', id: 'cin' },
          { field: 'telephone', id: 'telephone' }
        ];

        voiceFields.forEach(function (vf) {
          var inputEl = document.getElementById(vf.id);
          if (!inputEl) return;
          var fieldset = inputEl.closest('fieldset') || inputEl.parentElement;
          if (!fieldset) return;

          var wrapper = document.createElement('div');
          wrapper.className = 'voice-field';
          fieldset.appendChild(wrapper);

          wrapper.appendChild(inputEl);
          var micBtn = createMicButton();
          wrapper.appendChild(micBtn);

          if (!supportsSpeech) {
            micBtn.disabled = true;
          }

          micBtn.addEventListener('click', function () {
            startVoiceForField(vf.field, inputEl, micBtn);
          });
        });

        function showSignupError(message) {
          var existing = form.querySelector('.signup-validation-alert');
          if (existing) existing.remove();

          var alertDiv = document.createElement('div');
          alertDiv.className = 'alert alert-danger signup-validation-alert';
          alertDiv.setAttribute('role', 'alert');
          alertDiv.innerHTML = message;
          form.prepend(alertDiv);
        }

        function clearSignupError() {
          var existing = form.querySelector('.signup-validation-alert');
          if (existing) existing.remove();
        }

        form.addEventListener('submit', async function (e) {
          e.preventDefault();

          clearSignupError();

          var nom = document.getElementById('nom') ? document.getElementById('nom').value : '';
          var prenom = document.getElementById('prenom') ? document.getElementById('prenom').value : '';
          var email = document.getElementById('email') ? document.getElementById('email').value : '';
          var dateNaissance = document.getElementById('date_naissance') ? document.getElementById('date_naissance').value : '';
          var cin = document.getElementById('cin') ? document.getElementById('cin').value : '';
          var telephone = document.getElementById('telephone') ? document.getElementById('telephone').value : '';
          var password = document.getElementById('password') ? document.getElementById('password').value : '';
          var passwordConfirm = document.getElementById('password_confirm') ? document.getElementById('password_confirm').value : '';

          nom = (nom || '').trim();
          prenom = (prenom || '').trim();
          email = (email || '').trim();
          cin = (cin || '').trim();
          telephone = (telephone || '').trim();
          password = (password || '').trim();
          passwordConfirm = (passwordConfirm || '').trim();

          if (!nom || nom.length < 3) {
            showSignupError('Le nom doit contenir au moins 3 caractères.');
            return;
          }

          if (!prenom || prenom.length < 3) {
            showSignupError('Le prénom doit contenir au moins 3 caractères.');
            return;
          }

          if (!email) {
            showSignupError('L\'adresse e-mail est obligatoire.');
            return;
          }

          if (!/^\S+@\S+\.\S+$/.test(email)) {
            showSignupError('Veuillez saisir une adresse e-mail valide.');
            return;
          }

          if (!cin || !/^\d{8}$/.test(cin)) {
            showSignupError('Le CIN doit contenir exactement 8 chiffres.');
            return;
          }

          if (!telephone || !/^\d{8}$/.test(telephone)) {
            showSignupError('Le numéro de téléphone doit contenir exactement 8 chiffres.');
            return;
          }

          if (!password || password.length < 8) {
            showSignupError('Le mot de passe doit contenir au moins 8 caractères.');
            return;
          }

          if (!passwordConfirm || passwordConfirm.length < 8) {
            showSignupError('La confirmation du mot de passe doit contenir au moins 8 caractères.');
            return;
          }

          if (password !== passwordConfirm) {
            showSignupError('Les mots de passe ne correspondent pas.');
            return;
          }

          try {
            var recaptchaToken = '';
            try {
              recaptchaToken = (typeof grecaptcha !== 'undefined' && grecaptcha.getResponse) ? grecaptcha.getResponse() : '';
            } catch (e) {}

            if (!recaptchaToken) {
              showSignupError('Veuillez confirmer que vous n\'êtes pas un robot.');
              return;
            }

            var res = await fetch('/api/register', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({
                nom: nom,
                prenom: prenom,
                email: email,
                date_naissance: dateNaissance,
                cin: cin,
                telephone: telephone,
                password: password,
                password_confirm: passwordConfirm,
                recaptcha_token: recaptchaToken
              })
            });

            var data = await res.json().catch(function () { return {}; });
            if (!res.ok) {
              if (data && data.errors) {
                var msgs = [];
                Object.keys(data.errors).forEach(function (field) {
                  (data.errors[field] || []).forEach(function (msg) {
                    msgs.push(msg);
                  });
                });

                if (msgs.length > 0) {
                  showSignupError(msgs.join('<br>'));
                  return;
                }
              }

              showSignupError(data.message || 'Inscription impossible.');
              return;
            }

            window.location.href = '{{ path('front_login') }}';
          } catch (err) {
            showSignupError('Erreur réseau. Réessaie.');
          }
        });
      })();
    </script>

  </body>
</html>
