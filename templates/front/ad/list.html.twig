<!DOCTYPE html>
<html lang="fr">

  <head>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="TemplateMo">
    <link href="https://fonts.googleapis.com/css?family=Poppins:100,200,300,400,500,600,700,800,900&display=swap" rel="stylesheet">

    <title>Finovate - Annonces Publicitaires</title>

    <base href="{{ asset('front/') }}">

    <!-- Bootstrap core CSS -->
    <link href="{{ asset('front/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">

    <!-- Additional CSS Files -->
    <link rel="stylesheet" href="{{ asset('front/assets/css/fontawesome.css') }}">
    <link rel="stylesheet" href="{{ asset('front/assets/css/templatemo-finance-business.css') }}">
    <link rel="stylesheet" href="{{ asset('front/assets/css/owl.css') }}">

  </head>

  <body>

    <!-- ***** Preloader Start ***** -->
    <div id="preloader">
        <div class="jumper">
            <div></div>
            <div></div>
            <div></div>
        </div>
    </div>  
    <!-- ***** Preloader End ***** -->

    <header class="">
      <nav class="navbar navbar-expand-lg">
        <div class="container">
          <a class="navbar-brand" href="{{ path('front_home') }}"><h2>Finovate</h2></a>
          <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarResponsive" aria-controls="navbarResponsive" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarResponsive">
            <ul class="navbar-nav ml-auto">
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_home') }}">Accueil</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_about') }}">À propos</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_services') }}">Nos services</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_products') }}">Produits</a>
              </li>
              <li class="nav-item active">
                <a class="nav-link" href="{{ path('front_ads') }}">Annonces</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_contact') }}">Contact</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_one_page') }}">Présentation</a>
              </li>
              <li class="nav-item" id="nav-login">
                <a class="nav-link" href="{{ path('front_login') }}">Connexion</a>
              </li>
              <li class="nav-item" id="nav-dashboard" style="display: none;">
                <a class="nav-link" href="{{ path('user_dashboard') }}">Mon espace</a>
              </li>
              <li class="nav-item" id="nav-logout" style="display: none;">
                <a class="nav-link" href="{{ path('front_logout') }}">Déconnexion</a>
              </li>
            </ul>
          </div>
        </div>
      </nav>
    </header>

    <!-- Page Content -->
    <div class="page-heading header-text">
      <div class="container">
        <div class="row">
          <div class="col-md-12">
            <h1>Annonces Publicitaires</h1>
            <span>Gagnez des points en cliquant sur nos annonces</span>
          </div>
        </div>
      </div>
    </div>

    <div class="ads-section">
      <div class="container">
        <div class="row mb-5">
          <div class="col-md-12">
            <form action="{{ path('front_ads') }}" method="get" style="display: flex; gap: 10px;">
              <input type="text" name="search" class="form-control" placeholder="Rechercher une annonce..." value="{{ search }}" style="flex: 1;">
              <button type="submit" class="filled-button">
                <i class="fa fa-search"></i> Rechercher
              </button>
              {% if search %}
                <a href="{{ path('front_ads') }}" class="filled-button" style="background-color: #999;">Réinitialiser</a>
              {% endif %}
            </form>
          </div>
        </div>

        {% if ads is empty %}
          <div class="row">
            <div class="col-md-12 text-center" style="padding: 60px 0;">
              <i class="fa fa-bullhorn" style="font-size: 60px; color: #ccc; margin-bottom: 20px;"></i>
              <h3>Aucune annonce disponible</h3>
              <p>Revenez bientôt pour découvrir nos nouvelles campagnes publicitaires!</p>
            </div>
          </div>
        {% else %}
          <div class="row" style="margin-top: 40px;">
            {% for ad in ads %}
            <div class="col-md-6 col-lg-4">
              <div class="ad-item" style="background: white; border-radius: 10px; box-shadow: 0 0 20px rgba(0,0,0,0.1); overflow: hidden; margin-bottom: 30px; transition: all 0.3s ease;">
                <div class="ad-image" style="position: relative; height: 250px; overflow: hidden; background: #f5f5f5;">
                  {% if ad.imagePath %}
                    <img src="{{ asset(ad.imagePath) }}" alt="{{ ad.title }}" style="width: 100%; height: 100%; object-fit: cover;">
                  {% else %}
                    <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #ccc;">
                      <i class="fa fa-image" style="font-size: 60px;"></i>
                    </div>
                  {% endif %}
                  <div style="position: absolute; top: 10px; right: 10px; background: #ff6b35; color: white; padding: 8px 12px; border-radius: 5px; font-weight: 600;">
                    {{ ad.rewardPoints }} pts
                  </div>
                </div>
                
                <div class="ad-body" style="padding: 20px;">
                  <h5 style="margin-bottom: 10px; font-weight: 600; color: #1a1a1a;">{{ ad.title }}</h5>
                  
                  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; padding-bottom: 15px; border-bottom: 1px solid #eee;">
                    <span style="font-size: 12px; color: #999;">
                      <i class="fa fa-clock-o"></i> {{ ad.duration }} secondes
                    </span>
                    <span style="padding: 4px 8px; border-radius: 3px; font-size: 11px; font-weight: 600; color: white; background-color: #28a745;">
                      Actif
                    </span>
                  </div>
                  
                  <p style="font-size: 14px; color: #666; margin-bottom: 15px; min-height: 30px;">
                    Cliquez et gagnez {{ ad.rewardPoints }} points
                  </p>
                  
                  <a href="{{ path('front_ad_detail', {'id': ad.id}) }}" class="filled-button" style="width: 100%; text-align: center; display: block;">
                    <i class="fa fa-eye"></i> Voir l'annonce
                  </a>
                </div>
              </div>
            </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>

    <!-- Scripts -->
    <script src="{{ asset('front/vendor/jquery/jquery.min.js') }}"></script>
    <script src="{{ asset('front/vendor/bootstrap/js/bootstrap.min.js') }}"></script>
    <script src="{{ asset('front/assets/js/custom.js') }}"></script>

  </body>

</html>

