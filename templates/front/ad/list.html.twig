<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <title>Finovate - Annonces Publicitaires</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="{{ asset('front/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
  <link rel="stylesheet" href="{{ asset('front/assets/css/fontawesome.css') }}">
  <link rel="stylesheet" href="{{ asset('front/assets/css/templatemo-finance-business.css') }}">
  <link rel="stylesheet" href="{{ asset('front/assets/css/owl.css') }}">
  <style>
    .card { transition: transform 0.3s; border: none; }
    .card:hover { transform: translateY(-5px); box-shadow: 0 10px 30px rgba(0,0,0,0.2); }
    .ad-image { height: 250px; object-fit: cover; }
    .reward-badge { font-size: 1.5rem; font-weight: bold; }
  </style>
</head>
<body>
  <!-- NAVIGATION -->
  <header class="">
    <nav class="navbar navbar-expand-lg">
      <div class="container">
        <a class="navbar-brand" href="{{ path('front_home') }}"><h2>Finovate</h2></a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarResponsive">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarResponsive">
          <ul class="navbar-nav ml-auto">
            <li class="nav-item"><a class="nav-link" href="{{ path('front_home') }}">Accueil</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('front_about') }}">À propos</a></li>
            <li class="nav-item active"><a class="nav-link" href="{{ path('front_ads') }}">Annonces</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('app_forum_home') }}">Forums</a></li>
            
            {% if app.user %}
              <li class="nav-item"><a class="nav-link" href="{{ path('user_dashboard') }}">Mon espace</a></li>
              <li class="nav-item"><a class="nav-link" href="{{ path('front_logout') }}">Déconnexion</a></li>
              <li class="nav-item" style="margin-left: 8px;">
                <a class="nav-link" href="{{ path('app_forum_alerts') }}" style="position:relative;display:inline-flex;align-items:center" title="Alertes et notifications">
                  🔔
                  <span id="notif-badge" style="display:none;position:absolute;top:-8px;right:-8px;background:#ef4444;color:white;border-radius:50%;width:20px;height:20px;font-size:10px;font-weight:bold;display:flex;align-items:center;justify-content:center"></span>
                </a>
              </li>
              <li class="nav-item" style="margin-left: 8px;">
                <a class="nav-link" href="{{ path('forum_policy') }}" style="display:inline-flex;align-items:center" title="Règles de la communauté">
                  📜
                </a>
              </li>
              <li class="nav-item" style="margin-left: 8px;">
                <a class="nav-link" href="{{ path('app_forum_blocked_users') }}" style="display:inline-flex;align-items:center" title="Utilisateurs bloqués">
                  🚫
                </a>
              </li>
            {% else %}
              <li class="nav-item"><a class="nav-link" href="{{ path('front_login') }}">Connexion</a></li>
            {% endif %}
          </ul>
        </div>
      </div>
    </nav>
  </header>

  <!-- MAIN CONTENT -->
  <main class="py-5">
    <div class="container">
      <div class="row mb-4 align-items-center">
        <div class="col-md-6">
          <h1 class="display-4">Annonces Publicitaires</h1>
          <p class="lead text-muted">Gagnez des points en cliquant sur nos annonces</p>
        </div>
        <div class="col-md-6">
          <form action="{{ path('front_ads') }}" method="get" class="d-flex gap-2">
            <input type="text" name="search" class="form-control" placeholder="Rechercher une annonce..." value="{{ search }}">
            <button type="submit" class="btn btn-primary">
              <i class="fas fa-search"></i> Rechercher
            </button>
            {% if search %}
              <a href="{{ path('front_ads') }}" class="btn btn-outline-secondary">Réinitialiser</a>
            {% endif %}
          </form>
        </div>
      </div>

      {% if ads is empty %}
        <div class="alert alert-info text-center py-5">
          <i class="fas fa-bullhorn fa-3x mb-3"></i>
          <h4>Aucune annonce disponible</h4>
          <p>Revenez bientôt pour découvrir nos nouvelles campagnes publicitaires!</p>
        </div>
      {% else %}
        <div class="row g-4">
          {% for ad in ads %}
          <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm">
              {% if ad.imagePath %}
                <img src="{{ ad.imagePath }}" class="card-img-top ad-image" alt="{{ ad.title }}">
              {% else %}
                <div class="card-img-top ad-image bg-light d-flex align-items-center justify-content-center">
                  <i class="fas fa-image fa-3x text-muted"></i>
                </div>
              {% endif %}
              <div class="card-body">
                <h5 class="card-title">{{ ad.title }}</h5>
                
                <div class="d-flex justify-content-between align-items-center mb-3">
                  <div class="d-flex gap-2">
                    <span class="badge bg-success reward-badge">{{ ad.rewardPoints }} pts</span>
                      <span class="badge bg-secondary">{{ ad.duration }} s</span>
                <p class="card-text text-muted small">
                  <i class="fas fa-gift"></i> Gagnez {{ ad.rewardPoints }} points en cliquant!
                </p>
                
                <a href="{{ path('front_ad_detail', {'id': ad.id}) }}" class="btn btn-primary btn-sm w-100">
                  <i class="fas fa-eye"></i> Voir l'annonce
                </a>
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </main>

  <script src="{{ asset('front/vendor/jquery/jquery.min.js') }}"></script>
  <script src="{{ asset('front/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
</body>
</html>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>