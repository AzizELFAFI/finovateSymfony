<!DOCTYPE html>
<html lang="fr">

  <head>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="TemplateMo">
    <link href="https://fonts.googleapis.com/css?family=Poppins:100,200,300,400,500,600,700,800,900&display=swap" rel="stylesheet">

    <title>Finovate - {{ ad.title }}</title>

    <base href="{{ asset('front/') }}">

    <!-- Bootstrap core CSS -->
    <link href="{{ asset('front/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">

    <!-- Additional CSS Files -->
    <link rel="stylesheet" href="{{ asset('front/assets/css/fontawesome.css') }}">
    <link rel="stylesheet" href="{{ asset('front/assets/css/templatemo-finance-business.css') }}">
    <link rel="stylesheet" href="{{ asset('front/assets/css/owl.css') }}">

  </head>

  <body>

    <!-- ***** Preloader Start ***** -->
    <div id="preloader">
        <div class="jumper">
            <div></div>
            <div></div>
            <div></div>
        </div>
    </div>  
    <!-- ***** Preloader End ***** -->

    <header class="">
      <nav class="navbar navbar-expand-lg">
        <div class="container">
          <a class="navbar-brand" href="{{ path('front_home') }}"><h2>Finovate</h2></a>
          <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarResponsive" aria-controls="navbarResponsive" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarResponsive">
            <ul class="navbar-nav ml-auto">
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_home') }}">Accueil</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_about') }}">À propos</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_services') }}">Nos services</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_products') }}">Produits</a>
              </li>
              <li class="nav-item active">
                <a class="nav-link" href="{{ path('front_ads') }}">Annonces</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_contact') }}">Contact</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_one_page') }}">Présentation</a>
              </li>
              <li class="nav-item" id="nav-login">
                <a class="nav-link" href="{{ path('front_login') }}">Connexion</a>
              </li>
              <li class="nav-item" id="nav-dashboard" style="display: none;">
                <a class="nav-link" href="{{ path('user_dashboard') }}">Mon espace</a>
              </li>
              <li class="nav-item" id="nav-logout" style="display: none;">
                <a class="nav-link" href="{{ path('front_logout') }}">Déconnexion</a>
              </li>
            </ul>
          </div>
        </div>
      </nav>
    </header>

    <!-- Page Content -->
    <div class="page-heading header-text">
      <div class="container">
        <div class="row">
          <div class="col-md-12">
            <h1>{{ ad.title }}</h1>
            <span>Détails de l'annonce</span>
          </div>
        </div>
      </div>
    </div>

    <div class="ad-detail-section">
      <div class="container">
        <div class="row" style="margin-top: 40px;">
          <div class="col-md-6">
            <div style="background: white; border-radius: 10px; overflow: hidden; box-shadow: 0 0 20px rgba(0,0,0,0.1); padding: 0;">
              {% if ad.imagePath %}
                <img src="{{ asset(ad.imagePath) }}" alt="{{ ad.title }}" style="width: 100%; display: block;">
              {% else %}
                <div style="width: 100%; height: 400px; background: #f5f5f5; display: flex; align-items: center; justify-content: center;">
                  <i class="fa fa-image" style="font-size: 80px; color: #ccc;"></i>
                </div>
              {% endif %}
            </div>
          </div>

          <div class="col-md-6">
            <div style="background: white; border-radius: 10px; padding: 30px; box-shadow: 0 0 20px rgba(0,0,0,0.1); margin-bottom: 30px;">
              <h2 style="color: #1a1a1a; margin-bottom: 20px; font-weight: 600;">{{ ad.title }}</h2>
              
              <!-- Reward Section -->
              <div style="background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%); color: white; padding: 25px; border-radius: 10px; margin-bottom: 30px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                  <div>
                    <p style="margin: 0; font-size: 14px; opacity: 0.9;">Gagnez des points en cliquant</p>
                    <h3 style="margin: 5px 0 0 0; font-size: 28px; font-weight: bold;">{{ ad.rewardPoints }} points</h3>
                  </div>
                  <div style="font-size: 50px; opacity: 0.7;">
                    <i class="fa fa-gift"></i>
                  </div>
                </div>
              </div>

              <!-- Details -->
              <div style="margin-bottom: 30px; padding-bottom: 30px; border-bottom: 1px solid #eee;">
                <h4 style="color: #1a1a1a; margin-bottom: 15px;">Informations</h4>
                <div style="display: flex; gap: 20px; flex-direction: column;">
                  <div style="display: flex; align-items: center; gap: 10px;">
                    <i class="fa fa-hourglass-end" style="font-size: 18px; color: #ff6b35; width: 30px;"></i>
                    <div>
                      <span style="font-size: 12px; color: #999;">Durée</span>
                      <div style="font-weight: 600; color: #1a1a1a;">{{ ad.duration }} secondes</div>
                    </div>
                  </div>
                  <div style="display: flex; align-items: center; gap: 10px;">
                    <i class="fa fa-star" style="font-size: 18px; color: #ff6b35; width: 30px;"></i>
                    <div>
                      <span style="font-size: 12px; color: #999;">Récompense</span>
                      <div style="font-weight: 600; color: #1a1a1a;">{{ ad.rewardPoints }} points par clic</div>
                    </div>
                  </div>
                  <div style="display: flex; align-items: center; gap: 10px;">
                    <i class="fa fa-check-circle" style="font-size: 18px; color: #28a745; width: 30px;"></i>
                    <div>
                      <span style="font-size: 12px; color: #999;">Limite</span>
                      <div style="font-weight: 600; color: #1a1a1a;">1 clic par jour</div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Call to Action -->
              <form action="{{ path('front_ad_click', {'id': ad.id}) }}" method="POST" style="display: flex; gap: 10px;">
                <input type="hidden" name="_token" value="{{ csrf_token('ad_click_' ~ ad.id) }}">
                <button type="submit" class="filled-button" style="flex: 1;">
                  <i class="fa fa-mouse-pointer"></i> Cliquer et gagner
                </button>
                <a href="{{ path('front_ads') }}" class="filled-button" style="flex: 1; background-color: #999; text-align: center;">
                  <i class="fa fa-arrow-left"></i> Retour
                </a>
              </form>

              <div style="background: #f0f0f0; padding: 15px; border-radius: 8px; margin-top: 20px; font-size: 12px; color: #666;">
                <i class="fa fa-info-circle" style="color: #ff6b35; margin-right: 10px;"></i>
                <strong>Important:</strong> Vous pouvez cliquer une seule fois par jour sur cette annonce pour gagner les points.
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scripts -->
    <script src="{{ asset('front/vendor/jquery/jquery.min.js') }}"></script>
    <script src="{{ asset('front/vendor/bootstrap/js/bootstrap.min.js') }}"></script>
    <script src="{{ asset('front/assets/js/custom.js') }}"></script>

  </body>

</html>

