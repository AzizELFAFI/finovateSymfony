<!DOCTYPE html>
<html lang="fr">

  <head>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="TemplateMo">
    <link href="https://fonts.googleapis.com/css?family=Poppins:100,200,300,400,500,600,700,800,900&display=swap" rel="stylesheet">

    <title>Finovate - Contact</title>

    <base href="{{ asset('front/') }}">

    <!-- Bootstrap core CSS -->
    <link href="vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">

    <!-- Additional CSS Files -->
    <link rel="stylesheet" href="assets/css/fontawesome.css">
    <link rel="stylesheet" href="assets/css/templatemo-finance-business.css">
    <link rel="stylesheet" href="assets/css/owl.css">
<!--

Finance Business TemplateMo

https://templatemo.com/tm-545-finance-business

-->
  </head>

  <body>

    <!-- ***** Preloader Start ***** -->
    <div id="preloader">
        <div class="jumper">
            <div></div>
            <div></div>
            <div></div>
        </div>
    </div>  
    <!-- ***** Preloader End ***** -->

    
    
    <header class="">
      <nav class="navbar navbar-expand-lg">
        <div class="container">
          <a class="navbar-brand" href="{{ path('front_home') }}"><h2>Finovate</h2></a>
          <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarResponsive">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarResponsive">
            <ul class="navbar-nav ml-auto">
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_home') }}">Accueil
                  <span class="sr-only">(current)</span>
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_about') }}">À propos</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_ads') }}">Annonces</a>
              </li>
              <li class="nav-item active">
                <a class="nav-link" href="{{ path('app_forum_home') }}">Forums</a>
              </li>
              
              {% if app.user %}
                <li class="nav-item"><a class="nav-link" href="{{ path('user_dashboard') }}">Mon espace</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('front_logout') }}">Déconnexion</a></li>
                <li class="nav-item" style="margin-left: 8px;">
                  <a class="nav-link" href="{{ path('app_forum_alerts') }}" style="position:relative;display:inline-flex;align-items:center" title="Alertes et notifications">
                    🔔
                    <span id="notif-badge" style="display:none;position:absolute;top:-8px;right:-8px;background:#ef4444;color:white;border-radius:50%;width:20px;height:20px;font-size:10px;font-weight:bold;display:flex;align-items:center;justify-content:center"></span>
                  </a>
                </li>
                <li class="nav-item" style="margin-left: 8px;">
                  <a class="nav-link" href="{{ path('forum_policy') }}" style="display:inline-flex;align-items:center" title="Règles de la communauté">
                    📜
                  </a>
                </li>
                <li class="nav-item" style="margin-left: 8px;">
                  <a class="nav-link" href="{{ path('app_forum_blocked_users') }}" style="display:inline-flex;align-items:center" title="Utilisateurs bloqués">
                    🚫
                  </a>
                </li>
              {% else %}
                <li class="nav-item"><a class="nav-link" href="{{ path('front_login') }}">Connexion</a></li>
              {% endif %}
            </ul>
          </div>
        </div>
      </nav>
    </header>

    <!-- Page Content -->
    <div class="page-heading header-text">
      <div class="container">
        <div class="row">
          <div class="col-md-12">
            <h1>Contact</h1>
            <span>Une question ? Un conseiller Finovate vous répond rapidement.</span>
          </div>
        </div>
      </div>
    </div>

    <div class="contact-information">
      <div class="container">
        <div class="row">
          <div class="col-md-4">
            <div class="contact-item">
              <i class="fa fa-phone"></i>
              <h4>Téléphone</h4>
              <p>Du lundi au vendredi, de 09:00 à 17:00.</p>
              <a href="tel:0900800760">090-080-0760</a>
            </div>
          </div>
          <div class="col-md-4">
            <div class="contact-item">
              <i class="fa fa-envelope"></i>
              <h4>Email</h4>
              <p>Support et accompagnement pour l'ouverture de compte, cartes et opérations.</p>
              <a href="mailto:support@finovate.tn">support@finovate.tn</a>
            </div>
          </div>
          <div class="col-md-4">
            <div class="contact-item">
              <i class="fa fa-map-marker"></i>
              <h4>Adresse</h4>
              <p>1020 New Mountain Street<br>Forest Park, FP 11220</p>
              <a href="#">Voir sur Google Maps</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="callback-form contact-us">
      <div class="container">
        <div class="row">
          <div class="col-md-12">
            <div class="section-heading">
              <h2>Envoyez-nous un <em>message</em></h2>
              <span>Nous sommes là pour répondre à toutes vos questions.</span>
            </div>
          </div>
          <div class="col-md-12">
            <div class="contact-form">
              {% for label, messages in app.flashes %}
                {% for message in messages %}
                  <div class="alert alert-{{ label }}" role="alert">{{ message }}</div>
                {% endfor %}
              {% endfor %}

              <form id="contact" action="{{ path('front_contact_send') }}" method="post" novalidate="novalidate">
                <input type="hidden" name="_token" value="{{ csrf_token('contact_form') }}">
                <div class="row">
                  <div class="col-lg-4 col-md-12 col-sm-12">
                    <fieldset>
                      <input name="name" type="text" class="form-control" id="name" placeholder="Nom complet" required="" pattern=".*\D.*" title="Le nom complet ne doit pas être un entier.">
                    </fieldset>
                  </div>
                  <div class="col-lg-4 col-md-12 col-sm-12">
                    <fieldset>
                      <input name="email" type="email" class="form-control" id="email" placeholder="Adresse e-mail" required="">
                    </fieldset>
                  </div>
                  <div class="col-lg-4 col-md-12 col-sm-12">
                    <fieldset>
                      <input name="subject" type="text" class="form-control" id="subject" placeholder="Sujet" required="" pattern=".*\D.*" title="Le sujet ne doit pas être un entier.">
                    </fieldset>
                  </div>
                  <div class="col-lg-12">
                    <fieldset>
                      <textarea name="message" rows="6" class="form-control" id="message" placeholder="Votre message" required=""></textarea>
                    </fieldset>
                  </div>
                  <div class="col-lg-12">
                    <fieldset>
                      <button type="submit" id="form-submit" class="filled-button">Envoyer</button>
                    </fieldset>
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div >
      
    </div>


    <!-- Footer Starts Here -->
    <footer>
      <div class="container">
        <div class="row">
          <div class="col-md-3 footer-item">
            <h4>Liens utiles</h4>
            <ul class="menu-list">
              <li><a href="{{ path('front_home') }}">Accueil</a></li>
              <li><a href="{{ path('front_services') }}">Nos services</a></li>
              <li><a href="{{ path('front_about') }}">À propos</a></li>
              <li><a href="{{ path('front_contact') }}">Contact</a></li>
              <li><a href="{{ path('front_one_page') }}">Présentation</a></li>
            </ul>
          </div>
          
          <div class="col-md-3 footer-item last-item">
            <h4>Nous écrire</h4>
            <div class="contact-form">
              <form id="contact-footer" action="{{ path('front_contact_send') }}" method="post" novalidate="novalidate">
                <input type="hidden" name="_token" value="{{ csrf_token('contact_form') }}">
                <input type="hidden" name="subject" value="Contact depuis le footer (Contact Page)">
                <div class="row">
                  <div class="col-lg-12 col-md-12 col-sm-12">
                    <fieldset>
                      <input name="name" type="text" class="form-control" id="name" placeholder="Nom complet" required="" pattern=".*\D.*" title="Le nom complet ne doit pas être un entier.">
                    </fieldset>
                  </div>
                  <div class="col-lg-12 col-md-12 col-sm-12">
                    <fieldset>
                      <input name="email" type="email" class="form-control" id="email" placeholder="Adresse e-mail" required="">
                    </fieldset>
                  </div>
                  <div class="col-lg-12">
                    <fieldset>
                      <textarea name="message" rows="6" class="form-control" id="message" placeholder="Votre message" required=""></textarea>
                    </fieldset>
                  </div>
                  <div class="col-lg-12">
                    <fieldset>
                      <button type="submit" id="form-submit" class="filled-button">Envoyer</button>
                    </fieldset>
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </footer>
    
    <div class="sub-footer">
      <div class="container">
        <div class="row">
          <div class="col-md-12">
            <p>Copyright &copy; 2026 Finovate.
            
            
          </div>
        </div>
      </div>
    </div>

    <!-- Bootstrap core JavaScript -->
    <script src="vendor/jquery/jquery.min.js"></script>
    <script src="vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

    <!-- Additional Scripts -->
    <script src="assets/js/custom.js"></script>
    <script src="assets/js/owl.js"></script>
    <script src="assets/js/slick.js"></script>
    <script src="assets/js/accordions.js"></script>

    <script>
      (function () {
        var loginItem = document.getElementById('nav-login');
        var dashboardItem = document.getElementById('nav-dashboard');
        var logoutItem = document.getElementById('nav-logout');

        if (!loginItem || !dashboardItem || !logoutItem) return;

        var token = null;
        try {
          token = localStorage.getItem('finovate_token') || sessionStorage.getItem('finovate_token');
        } catch (e) {}

        var isAuthed = !!token;
        loginItem.style.display = isAuthed ? 'none' : '';
        dashboardItem.style.display = isAuthed ? '' : 'none';
        logoutItem.style.display = isAuthed ? '' : 'none';
      })();
    </script>

    <script language = "text/Javascript"> 
      cleared[0] = cleared[1] = cleared[2] = 0; //set a cleared flag for each field
      function clearField(t){                   //declaring the array outside of the
      if(! cleared[t.id]){                      // function makes it static and global
          cleared[t.id] = 1;  // you could use true and false, but that's more typing
          t.value='';         // with more chance of typos
          t.style.color='#fff';
          }
      }
    </script>

  </body>
</html>