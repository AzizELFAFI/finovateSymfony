<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <title>Finovate - Mes demandes d’investissement</title>

  <link href="{{ asset('front/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
  <link rel="stylesheet" href="{{ asset('front/assets/css/fontawesome.css') }}">
  <link rel="stylesheet" href="{{ asset('front/assets/css/templatemo-finance-business.css') }}">
  <link rel="stylesheet" href="{{ asset('front/assets/css/owl.css') }}">
  {% include 'front/partials/investissement_ui_enhancements.html.twig' %}

  <style>
    .page-shell { padding: 36px 0; }

    .sidebar {
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(15, 118, 110, 0.14);
      box-shadow: 0 14px 38px rgba(0, 0, 0, 0.06);
      padding: 16px;
      position: sticky;
      top: 16px;
    }

    .sidebar .title { font-weight: 900; margin: 0 0 10px 0; }

    .sidebar a {
      display: block;
      padding: 10px 12px;
      border-radius: 12px;
      color: #111827;
      font-weight: 700;
      text-decoration: none;
      border: 1px solid transparent;
    }

    .sidebar a:hover {
      background: rgba(16, 185, 129, 0.08);
      border-color: rgba(16, 185, 129, 0.18);
      color: #0f766e;
    }

    .sidebar a.active {
      background: rgba(16, 185, 129, 0.12);
      border-color: rgba(16, 185, 129, 0.26);
      color: #0f766e;
    }

    .forum-folder { display: flex; justify-content: space-between; align-items: center; cursor: pointer; }
    .f-arrow { font-size: 10px; transition: transform 0.2s; }
    .f-arrow.open { transform: rotate(90deg); }
    .forum-sub { display: none; padding-left: 10px; }
    .forum-sub.show { display: block; }
    .forum-sub a { display: block; padding: 7px 12px; font-size: 13px; border-left: 2px solid rgba(15,118,110,0.15); border-radius: 8px; margin-bottom: 1px; color: #111827; font-weight: 700; text-decoration: none; }
    .forum-sub a:hover { border-left-color: #0f766e; background: rgba(16,185,129,0.08); color: #0f766e; }

    .card-shell {
      background: rgba(255, 255, 255, 0.92);
      border-radius: 18px;
      border: 1px solid rgba(15, 118, 110, 0.14);
      box-shadow: 0 14px 38px rgba(0, 0, 0, 0.08);
      padding: 22px;
    }

    .demande-card {
      background: #fff;
      border-radius: 16px;
      border: 1px solid rgba(15, 118, 110, 0.12);
      box-shadow: 0 12px 26px rgba(0, 0, 0, 0.06);
      padding: 18px;
      margin-bottom: 16px;
    }

    .demande-title { font-weight: 900; margin: 0; color: #0f172a; font-size: 1.05rem; }

    .meta { color: rgba(0, 0, 0, 0.55); font-weight: 600; font-size: 0.85rem; }

    .badge-soft {
      display: inline-block;
      padding: 6px 10px;
      border-radius: 999px;
      font-weight: 800;
      font-size: 0.75rem;
      letter-spacing: 0.2px;
    }

    .badge-soft.ok { background: rgba(16,185,129,0.15); color: #0f766e; }
    .badge-soft.run { background: rgba(59,130,246,0.12); color: #1d4ed8; }
    .badge-soft.warn { background: rgba(245,158,11,0.15); color: #b45309; }
    .badge-soft.neutral { background: rgba(107,114,128,0.12); color: #374151; }
  </style>
</head>

<body class="inv-subpage">

  <header>
    <nav class="navbar navbar-expand-lg">
      <div class="container">
        <a class="navbar-brand" href="{{ path('front_home') }}">
          <h2>Finovate</h2>
        </a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarResponsive">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarResponsive">
          <ul class="navbar-nav ml-auto">
            <li class="nav-item"><a class="nav-link" href="{{ path('front_home') }}">Accueil</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('front_about') }}">À propos</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ app.user ? path('front_products') : path('front_products_public') }}">Produits</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('app_forum_home') }}">Forums</a></li>
            
            {% if app.user %}
              <li class="nav-item active"><a class="nav-link" href="{{ path('user_dashboard') }}">Mon espace</a></li>
              <li class="nav-item"><a class="nav-link" href="{{ path('front_logout') }}">Déconnexion</a></li>
              <li class="nav-item" style="margin-left: 8px;">
                <a class="nav-link" href="{{ path('app_forum_alerts') }}" style="position:relative;display:inline-flex;align-items:center" title="Alertes et notifications">
                  🔔
                  <span id="notif-badge" style="display:none;position:absolute;top:-8px;right:-8px;background:#ef4444;color:white;border-radius:50%;width:20px;height:20px;font-size:10px;font-weight:bold;display:flex;align-items:center;justify-content:center"></span>
                </a>
              </li>
              <li class="nav-item" style="margin-left: 8px;">
                <a class="nav-link" href="{{ path('forum_policy') }}" style="display:inline-flex;align-items:center" title="Règles de la communauté">
                  📜
                </a>
              </li>
              <li class="nav-item" style="margin-left: 8px;">
                <a class="nav-link" href="{{ path('app_forum_blocked_users') }}" style="display:inline-flex;align-items:center" title="Utilisateurs bloqués">
                  🚫
                </a>
              </li>
            {% else %}
              <li class="nav-item"><a class="nav-link" href="{{ path('front_login') }}">Connexion</a></li>
            {% endif %}
          </ul>
        </div>
      </div>
    </nav>
  </header>

  <div class="page-heading header-text">
    <div class="container">
      <div class="row">
        <div class="col-md-12">
          <h1>Mes demandes</h1>
          <span>Suivez vos demandes d’investissement et modifiez celles en attente</span>
        </div>
      </div>
    </div>
  </div>

  <div class="page-shell">
    <div class="container">
      <div class="row">
        <div class="col-lg-3 mb-4">
          <div class="sidebar">
            <div class="title">Mon espace</div>
                <a href="#" id="nav-dashboard-side" >Dashboard</a>
                <a href="{{ path('user_transactions') }}" id="nav-transactions">Transactions</a>
                <a href="{{ path('user_goals') }}" id="nav-goals">Goals</a>
                <a href="{{ path('user_bills') }}" id="nav-bills">Factures</a>
                <a href="{{ path('investissement_index') }}" id="nav-investissement" class="active">Investissement</a>
                <a href="{{ path('front_products') }}">Produits</a>
                <a href="{{ path('front_ads') }}">Annonces</a>
                <a href="{{ path('user_topup') }}" id="nav-topup">Alimenter carte</a>
                <a href="#" id="nav-edit-profile">Modifier le profil</a>
                
          </div>
        </div>

        <div class="col-lg-9">
          <div class="card-shell mb-4">
            {% for label, messages in app.flashes %}
              {% for message in messages %}
                <div class="alert alert-{{ label }}" role="alert">{{ message }}</div>
              {% endfor %}
            {% endfor %}

            <div class="d-flex justify-content-between align-items-start flex-wrap" style="gap:12px">
              <div>
                <h4 style="font-weight:900;margin:0">Demandes d’investissement</h4>
                <div class="meta">En attente, acceptées ou refusées par les porteurs de projet</div>
              </div>
              <div class="d-flex flex-wrap" style="gap:8px">
                <a href="{{ path('investissement_mes_investissements') }}" class="btn btn-outline-success" style="border-radius:12px;font-weight:800;white-space:nowrap">
                  <i class="fa fa-line-chart mr-1"></i> Mes investissements
                </a>
                <a href="{{ path('investissement_index') }}" class="btn btn-outline-success" style="border-radius:12px;font-weight:800;white-space:nowrap">
                  <i class="fa fa-search mr-1"></i> Voir les projets
                </a>
              </div>
            </div>
          </div>

          {% if demandes is empty %}
            <div class="card-shell">
              <p class="meta mb-0" style="font-weight:600">Vous n’avez pas encore de demande. Parcourez les projets sur la page <a href="{{ path('investissement_index') }}" style="font-weight:800;color:#0f766e">Investissement</a>.</p>
            </div>
          {% endif %}

          {% for d in demandes %}
            {% set st = d.status|default('')|upper %}
            <div class="demande-card">
              <div class="d-flex justify-content-between align-items-start flex-wrap" style="gap:10px">
                <div style="flex:1;min-width:200px">
                  <p class="demande-title">{{ d.project ? d.project.title : 'Projet' }}</p>
                  <div class="meta mt-1">
                    Demandé le {{ d.investmentDate|date('d/m/Y à H:i') }}
                  </div>
                </div>
                <div>
                  {% if st == 'PENDING' %}
                    <span class="badge-soft run">En attente</span>
                  {% elseif st == 'CONFIRMED' %}
                    <span class="badge-soft ok">Acceptée</span>
                  {% elseif st == 'REJECTED' %}
                    <span class="badge-soft warn">Refusée</span>
                  {% else %}
                    <span class="badge-soft neutral">{{ d.status ?? '—' }}</span>
                  {% endif %}
                </div>
              </div>

              <div class="mt-3" style="font-weight:800;color:#0f766e;font-size:1.1rem">
                {{ (d.amount|default('0')|replace({',': '.'}) + 0)|number_format(2, ',', ' ') }} <span class="meta" style="font-weight:700">(montant)</span>
              </div>
              {% if d.revenuePercentage is not null %}
                <div class="mt-1" style="font-weight:700;color:#0f766e;font-size:0.95rem">
                  {{ d.revenuePercentage }}% <span class="meta" style="font-weight:600">(revenu souhaité)</span>
                </div>
              {% endif %}

              {% if st == 'PENDING' %}
                <div class="mt-3 pt-3" style="border-top:1px dashed rgba(15,118,110,0.2)">
                  <div class="meta mb-2" style="font-weight:800;color:#0f766e">Modifier ou annuler</div>
                  <div class="d-flex flex-wrap align-items-end" style="gap:12px">
                    <form method="post" action="{{ path('investissement_demande_montant', { id: d.id }) }}" class="d-flex flex-wrap align-items-end" style="gap:8px">
                      <input type="hidden" name="_token" value="{{ csrf_token('invest_demande_investor_' ~ d.id) }}">
                      <div class="form-group mb-0">
                        <label for="amount-{{ d.id }}" class="meta mb-1" style="display:block">Nouveau montant</label>
                        <input type="text" name="amount" id="amount-{{ d.id }}" class="form-control" value="{{ d.amount }}" inputmode="decimal" required autocomplete="off" style="border-radius:10px;max-width:160px;font-weight:600">
                      </div>
                      <div class="form-group mb-0">
                        <label for="revenue-pct-{{ d.id }}" class="meta mb-1" style="display:block">% revenu</label>
                        <div class="input-group" style="max-width:140px">
                          <input type="number" name="revenue_percentage" id="revenue-pct-{{ d.id }}" class="form-control"
                            value="{{ d.revenuePercentage is not null ? d.revenuePercentage : '' }}"
                            min="0" max="100" step="0.01" placeholder="—" autocomplete="off"
                            style="border-radius:10px 0 0 10px;font-weight:600">
                          <div class="input-group-append">
                            <span class="input-group-text" style="font-weight:700;background:rgba(15,118,110,0.08);border-color:#ced4da;color:#0f766e;border-radius:0 10px 10px 0">%</span>
                          </div>
                        </div>
                      </div>
                      <button type="submit" class="btn btn-success btn-sm" style="border-radius:10px;font-weight:800">Mettre à jour</button>
                    </form>
                    <form method="post" action="{{ path('investissement_demande_annuler', { id: d.id }) }}" class="mb-0"
                      onsubmit="return confirm('Annuler cette demande ?');">
                      <input type="hidden" name="_token" value="{{ csrf_token('invest_demande_investor_' ~ d.id) }}">
                      <button type="submit" class="btn btn-outline-secondary btn-sm" style="border-radius:10px;font-weight:700">Annuler la demande</button>
                    </form>
                  </div>
                </div>
              {% else %}
                <p class="meta mb-0 mt-3">Cette demande est close — aucune modification possible.</p>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

  <script src="{{ asset('front/vendor/jquery/jquery.min.js') }}"></script>
  <script src="{{ asset('front/assets/js/auth-guard.js') }}"></script>
  <script src="{{ asset('front/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
  <script>function toggleForums(e){e.preventDefault();var b=e.currentTarget;var s=b.nextElementSibling;var a=b.querySelector('.f-arrow');s.classList.toggle('show');a.classList.toggle('open');b.classList.toggle('active');}</script>
</body>

</html>
