                <div class="current-points" id="current-points-display">
                  {{ app.user ? app.user.points : 0 }} points
                </div>
                <p style="font-size: 0.9rem; opacity: 0.9;">Votre solde actuel</p>
              </div>

              <div class="info-box">
                <h6>&#128161; Comment ça marche ?</h6>
                <p>Les points vous permettent d'acheter des produits dans notre boutique. Regardez des publicités pour gagner des points gratuits, ou achetez-en directement ici.</p>
              </div>

              <h5 style="font-weight: 800; margin-bottom: 16px; color: #0f766e;">Choisissez votre package</h5>
              <div class="points-packages">
                <div class="package-card" data-points="100" data-amount="3.00">
                  <div class="points-value">100</div>
                  <div class="points-label">points</div>
                  <div class="price">3,00 TND</div>
                </div>
                <div class="package-card" data-points="250" data-amount="7.00">
                  <div class="points-value">250</div>
                  <div class="points-label">points</div>
                  <div class="price">7,00 TND</div>
                </div>
                <div class="package-card" data-points="500" data-amount="12.00">
                  <div class="points-value">500</div>
                  <div class="points-label">points</div>
                  <div class="price">12,00 TND</div>
                </div>
                <div class="package-card" data-points="1000" data-amount="22.00">
                  <div class="best-value">Populaire</div>
                  <div class="points-value">1000</div>
                  <div class="points-label">points</div>
                  <div class="price">22,00 TND</div>
                </div>
                <div class="package-card" data-points="2500" data-amount="50.00">
                  <div class="points-value">2500</div>
                  <div class="points-label">points</div>
                  <div class="price">50,00 TND</div>
                </div>
                <div class="package-card" data-points="5000" data-amount="90.00">
                  <div class="best-value">Meilleur prix</div>
                  <div class="points-value">5000</div>
