  </header>

  <div class="page-heading header-text">
    <div class="container">
      <div class="row">
        <div class="col-md-12">
          <h1>Acheter des points</h1>
          <span>Obtenez des points pour accéder aux produits exclusifs</span>
        </div>
      </div>
    </div>
  </div>

  <div class="page-shell">
    <div class="container">
      <div class="row">
        <div class="col-lg-3 mb-4">
          <div class="sidebar">
            <div class="title">Mon espace</div>
            <a href="{{ path('user_dashboard') }}" id="nav-dashboard-side">Dashboard</a>
            <a href="{{ path('user_transactions') }}" id="nav-transactions">Transactions</a>
            <a href="{{ path('user_goals') }}" id="nav-goals">Goals</a>
            <a href="{{ path('user_bills') }}" id="nav-bills">Factures</a>
            <a href="{{ path('investissement_index') }}" id="nav-investissement">Investissement</a>
            <a href="{{ path('front_products') }}">Produits</a>
            <a href="{{ path('front_ads') }}">Annonces</a>
            <a href="{{ path('user_topup') }}" id="nav-topup">Alimenter carte</a>
            <a href="{{ path('user_buy_points') }}" id="nav-buy-points" class="active">Acheter des points</a>
            <a href="#" id="nav-edit-profile">Modifier le profil</a>
            <a href="{{ path('front_logout') }}">Déconnexion</a>
          </div>
        </div>

        <div class="col-lg-9">
          <div class="card-shell">
            <div id="buy-points-form">
              <div class="points-header">
