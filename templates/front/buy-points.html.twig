  <link href="{{ asset('front/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
  <link rel="stylesheet" href="{{ asset('front/assets/css/fontawesome.css') }}">
  <link rel="stylesheet" href="{{ asset('front/assets/css/templatemo-finance-business.css') }}">
  <link rel="stylesheet" href="{{ asset('front/assets/css/owl.css') }}">

  <style>
    .page-shell { padding: 36px 0; }

    .sidebar {
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(15, 118, 110, 0.14);
      box-shadow: 0 14px 38px rgba(0, 0, 0, 0.06);
      padding: 16px;
      position: sticky;
      top: 16px;
    }

    .sidebar .title { font-weight: 900; margin: 0 0 10px 0; }

    .sidebar a {
      display: block;
      padding: 10px 12px;
      border-radius: 12px;
      color: #111827;
      font-weight: 700;
      text-decoration: none;
      border: 1px solid transparent;
    }

    .sidebar a:hover {
      background: rgba(16, 185, 129, 0.08);
      border-color: rgba(16, 185, 129, 0.18);
      color: #0f766e;
    }

    .sidebar a.active {
      background: rgba(16, 185, 129, 0.12);
      border-color: rgba(16, 185, 129, 0.26);
      color: #0f766e;
    }

    .card-shell {
      background: rgba(255, 255, 255, 0.92);
      border-radius: 18px;
      border: 1px solid rgba(15, 118, 110, 0.14);
      box-shadow: 0 14px 38px rgba(0, 0, 0, 0.08);
      padding: 28px;
    }

    .points-header {
      background: linear-gradient(135deg, #0f766e 0%, #10b981 100%);
      border-radius: 20px;
      padding: 32px;
      color: white;
      margin-bottom: 24px;
      text-align: center;
    }

    .points-header h2 {
      font-weight: 900;
      margin: 0 0 8px 0;
      font-size: 1.5rem;
    }

    .points-header .current-points {
      font-size: 2.5rem;
      font-weight: 900;
      margin: 16px 0;
    }

    .points-packages {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-bottom: 24px;
    }

    @media (max-width: 768px) {
      .points-packages {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 576px) {
      .points-packages {
        grid-template-columns: 1fr;
      }
    }

    .package-card {
      border-radius: 16px;
      border: 2px solid rgba(15, 118, 110, 0.2);
      background: white;
      padding: 24px 16px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      position: relative;
      overflow: hidden;
    }

    .package-card:hover {
      border-color: #0f766e;
      transform: translateY(-3px);
      box-shadow: 0 12px 28px rgba(15, 118, 110, 0.15);
    }

    .package-card.selected {
      border-color: #0f766e;
      background: rgba(15, 118, 110, 0.08);
    }

    .package-card .points-value {
      font-size: 2rem;
      font-weight: 900;
      color: #0f766e;
      margin-bottom: 8px;
    }

    .package-card .points-label {
      font-size: 0.85rem;
      color: #6b7280;
      margin-bottom: 12px;
    }

    .package-card .price {
      font-size: 1.25rem;
      font-weight: 800;
      color: #111827;
      background: rgba(15, 118, 110, 0.08);
      padding: 8px 16px;
      border-radius: 20px;
      display: inline-block;
    }

    .package-card .best-value {
      position: absolute;
      top: 8px;
      right: -30px;
      background: #f59e0b;
      color: white;
      font-size: 0.7rem;
      font-weight: 800;
      padding: 4px 32px;
      transform: rotate(45deg);
    }

    .pay-btn {
      width: 100%;
      padding: 18px;
      border-radius: 14px;
      border: none;
      background: linear-gradient(135deg, #0f766e 0%, #10b981 100%);
      color: white;
      font-weight: 800;
      font-size: 1.1rem;
      cursor: pointer;
      transition: all 0.2s;
      box-shadow: 0 8px 24px rgba(15, 118, 110, 0.3);
    }

    .pay-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px rgba(15, 118, 110, 0.4);
    }

    .pay-btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
    }

    .payment-element-container {
      margin-bottom: 24px;
      padding: 20px;
      border-radius: 14px;
      border: 1px solid rgba(15, 118, 110, 0.15);
      background: #f9fafb;
    }

    .success-message {
      text-align: center;
      padding: 40px 20px;
    }

    .success-icon {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: rgba(16, 185, 129, 0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
    }

    .success-message h3 {
      font-weight: 900;
      color: #0f766e;
      margin-bottom: 10px;
    }

    .success-message p {
      color: #6b7280;
    }

    .info-box {
      background: rgba(15, 118, 110, 0.08);
      border-radius: 12px;
      padding: 16px;
      margin-bottom: 24px;
      border-left: 4px solid #0f766e;
    }

    .info-box h6 {
      font-weight: 800;
      color: #0f766e;
      margin-bottom: 8px;
    }

    .info-box p {
      margin: 0;
      font-size: 0.9rem;
      color: #374151;
    }
  </style>
</head>

<body>

