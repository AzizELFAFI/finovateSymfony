  <script src="{{ asset('front/vendor/jquery/jquery.min.js') }}"></script>
  <script src="{{ asset('front/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
  <script src="https://js.stripe.com/v3/"></script>

  <script>
    var token = null;
    try {
      token = localStorage.getItem('finovate_token') || sessionStorage.getItem('finovate_token');
    } catch (e) {}

    if (!token) {
      window.location.href = '{{ path('front_login') }}';
    }

    var selectedPoints = 0;
    var selectedAmount = 0;
    var stripe = null;
    var elements = null;
    var paymentElement = null;

    var packageCards = document.querySelectorAll('.package-card');
    var paymentSection = document.getElementById('payment-section');
    var amountDisplay = document.getElementById('amount-display');
    var pointsDisplay = document.getElementById('points-display');
    var submitBtn = document.getElementById('submit-payment');
    var btnText = document.getElementById('btn-text');
    var btnSpinner = document.getElementById('btn-spinner');
    var errorMessage = document.getElementById('error-message');
    var buyPointsForm = document.getElementById('buy-points-form');
    var successContainer = document.getElementById('success-container');
    var successDetails = document.getElementById('success-details');

    packageCards.forEach(function(card) {
      card.addEventListener('click', function() {
        packageCards.forEach(function(c) { c.classList.remove('selected'); });
        card.classList.add('selected');

        selectedPoints = parseInt(card.dataset.points);
        selectedAmount = parseFloat(card.dataset.amount);
        
        amountDisplay.textContent = selectedAmount.toFixed(2).replace('.', ',');
        pointsDisplay.textContent = selectedPoints;
        
        initPayment(selectedPoints, selectedAmount);
      });
    });

    function showError(msg) {
      errorMessage.textContent = msg;
      errorMessage.style.display = '';
    }

    function hideError() {
      errorMessage.style.display = 'none';
    }

    function resetPayButton() {
      submitBtn.disabled = false;
      btnText.style.display = '';
      btnSpinner.style.display = 'none';
    }

    function initPayment(points, amount) {
      hideError();
      resetPayButton();
      paymentSection.style.display = '';

      fetch('/api/stripe/create-points-payment-intent', {
        method: 'POST',
        headers: {
          'Authorization': 'Bearer ' + token,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ points: points, amount: amount })
      })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.message && !data.client_secret) {
            showError(data.message);
            paymentSection.style.display = 'none';
            resetPayButton();
            return;
          }

          if (!stripe) {
            stripe = Stripe(data.publishable_key);
          }

          elements = stripe.elements({
            clientSecret: data.client_secret,
            appearance: {
              theme: 'stripe',
              variables: {
                colorPrimary: '#0f766e',
                colorBackground: '#ffffff',
                colorText: '#1f2937',
                borderRadius: '12px',
                fontFamily: 'system-ui, sans-serif'
              }
            }
          });

          if (paymentElement) {
            document.getElementById('payment-element').innerHTML = '';
          }

          paymentElement = elements.create('payment', {
            layout: 'tabs'
          });
          paymentElement.mount('#payment-element');
        })
        .catch(function(err) {
          showError('Erreur lors de l\'initialisation du paiement.');
          resetPayButton();
        });
    }

    submitBtn.addEventListener('click', function() {
      if (!stripe || !elements) {
        showError('Veuillez d\'abord sélectionner un package de points.');
        return;
      }

      hideError();
      submitBtn.disabled = true;
      btnText.style.display = 'none';
      btnSpinner.style.display = '';

      stripe.confirmPayment({
        elements: elements,
        confirmParams: {
          return_url: window.location.href,
        },
        redirect: 'if_required'
      }).then(function(result) {
        if (result.error) {
          showError(result.error.message || 'Une erreur est survenue lors du paiement.');
          submitBtn.disabled = false;
          btnText.style.display = '';
          btnSpinner.style.display = 'none';
        } else if (result.paymentIntent) {
          confirmPayment(result.paymentIntent.id);
        }
      });
    });

    function confirmPayment(paymentIntentId) {
      fetch('/api/stripe/confirm-points-payment', {
        method: 'POST',
        headers: {
          'Authorization': 'Bearer ' + token,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ payment_intent_id: paymentIntentId })
      })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.success) {
            buyPointsForm.style.display = 'none';
            successContainer.style.display = '';
            successDetails.textContent = 'Vous avez reçu ' + data.points + ' points. Montant débité: ' + data.amount_debited.toFixed(2) + ' TND. Nouveau solde: ' + data.new_balance.toFixed(2) + ' TND.';
          } else {
            showError(data.message || 'Erreur lors de la confirmation.');
            submitBtn.disabled = false;
            btnText.style.display = '';
            btnSpinner.style.display = 'none';
          }
        })
        .catch(function() {
          showError('Erreur réseau lors de la confirmation.');
          submitBtn.disabled = false;
          btnText.style.display = '';
          btnSpinner.style.display = 'none';
        });
    }
  </script>
</body>

</html>
