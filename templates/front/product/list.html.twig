<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Finovate - Marché des Produits</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('backoffice/assets/images/favicon_io/apple-touch-icon.png') }}">
  <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('backoffice/assets/images/favicon_io/favicon-32x32.png') }}">
  <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('backoffice/assets/images/favicon_io/favicon-16x16.png') }}">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    body { padding-top: 80px; }
    .navbar { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .card { transition: transform 0.3s; border: none; }
    .card:hover { transform: translateY(-5px); box-shadow: 0 10px 30px rgba(0,0,0,0.2); }
    .product-image { height: 200px; object-fit: cover; }
    .price-badge { font-size: 1.5rem; font-weight: bold; }
  </style>
</head>
<body>
  <!-- NAVIGATION -->
  <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="{{ path('front_home') }}">Finovate</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link active" href="{{ path('front_products') }}">Produits</a></li>
          <li class="nav-item"><a class="nav-link" href="{{ path('front_ads') }}">Annonces</a></li>
          <li class="nav-item"><a class="nav-link" href="{{ path('user_dashboard') }}">Dashboard</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- MAIN CONTENT -->
  <main class="py-5">
    <div class="container">
      <div class="row mb-4 align-items-center">
        <div class="col-md-6">
          <h1 class="display-4">Marché des Produits</h1>
          <p class="lead text-muted">Découvrez nos produits exclusifs et échangez vos points</p>
        </div>
        <div class="col-md-6">
          <form action="{{ path('front_products') }}" method="get" class="d-flex gap-2">
            <input type="text" name="search" class="form-control" placeholder="Rechercher un produit..." value="{{ search }}">
            <button type="submit" class="btn btn-primary">
              <i class="fas fa-search"></i> Rechercher
            </button>
            {% if search %}
              <a href="{{ path('front_products') }}" class="btn btn-outline-secondary">Réinitialiser</a>
            {% endif %}
          </form>
        </div>
      </div>

      {% if products is empty %}
        <div class="alert alert-info text-center py-5">
          <i class="fas fa-box-open fa-3x mb-3"></i>
          <h4>Aucun produit trouvé</h4>
          <p>Revenez bientôt pour découvrir nos nouveaux produits!</p>
        </div>
      {% else %}
        <div class="row g-4">
          {% for product in products %}
          <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm">
              {% if product.image %}
                <img src="{{ asset(product.image) }}" class="card-img-top product-image" alt="{{ product.name }}">
              {% else %}
                <div class="card-img-top product-image bg-light d-flex align-items-center justify-content-center">
                  <i class="fas fa-image fa-3x text-muted"></i>
                </div>
              {% endif %}
              <div class="card-body">
                <h5 class="card-title">{{ product.name }}</h5>
                <p class="card-text text-muted">{{ product.description ? product.description : 'Pas de description' }}</p>
                
                <div class="d-flex justify-content-between align-items-center mb-3">
                  <span class="badge bg-warning text-dark price-badge">{{ product.pricePoints }} pts</span>
                  <span class="badge {{ product.stock > 0 ? 'bg-success' : 'bg-danger' }}">
                    {{ product.stock > 0 ? 'En stock' : 'Rupture' }}
                  </span>
                </div>
                
                <a href="{{ path('front_product_detail', {'id': product.id}) }}" class="btn btn-primary btn-sm w-100">
                  <i class="fas fa-eye"></i> Détails
                </a>
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
