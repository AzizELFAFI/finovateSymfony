<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <title>{{ product.name }} - Finovate</title>

  <link href="{{ asset('front/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
  <link rel="stylesheet" href="{{ asset('front/assets/css/fontawesome.css') }}">
  <link rel="stylesheet" href="{{ asset('front/assets/css/templatemo-finance-business.css') }}">
  <link rel="stylesheet" href="{{ asset('front/assets/css/owl.css') }}">
  <link rel="stylesheet" type="text/css" href="{{ asset('bundles/starrating/css/rating.css') }}" />

  <style>
    .page-shell { padding: 36px 0; }

    .sidebar {
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(15, 118, 110, 0.14);
      box-shadow: 0 14px 38px rgba(0, 0, 0, 0.06);
      padding: 16px;
      position: sticky;
      top: 16px;
    }

    .sidebar .title { font-weight: 900; margin: 0 0 10px 0; }

    .sidebar a {
      display: block;
      padding: 10px 12px;
      border-radius: 12px;
      color: #111827;
      font-weight: 700;
      text-decoration: none;
      border: 1px solid transparent;
    }

    .sidebar a:hover {
      background: rgba(16, 185, 129, 0.08);
      border-color: rgba(16, 185, 129, 0.18);
      color: #0f766e;
    }

    .sidebar a.active {
      background: rgba(16, 185, 129, 0.12);
      border-color: rgba(16, 185, 129, 0.26);
      color: #0f766e;
    }

    .card-shell {
      background: rgba(255, 255, 255, 0.92);
      border-radius: 18px;
      border: 1px solid rgba(15, 118, 110, 0.14);
      box-shadow: 0 14px 38px rgba(0, 0, 0, 0.08);
      padding: 22px;
    }

    .product-hero {
      background: #fff;
      border-radius: 16px;
      border: 1px solid rgba(15, 118, 110, 0.12);
      box-shadow: 0 12px 26px rgba(0, 0, 0, 0.06);
      padding: 18px;
    }

    .product-thumb {
      width: 100%;
      height: 360px;
      object-fit: cover;
      border-radius: 14px;
      background: rgba(15, 118, 110, 0.06);
    }

    .meta { color: rgba(0, 0, 0, 0.55); font-weight: 600; font-size: 0.85rem; }
    .price-badge { font-size: 1.1rem; font-weight: 800; }
  </style>
</head>

<body>
  <header>
    <nav class="navbar navbar-expand-lg">
      <div class="container">
        <a class="navbar-brand" href="{{ path('front_home') }}">
          <h2>Finovate</h2>
        </a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarResponsive">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarResponsive">
          <ul class="navbar-nav ml-auto">
            <li class="nav-item"><a class="nav-link" href="{{ path('front_home') }}">Accueil</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('front_about') }}">À propos</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ app.user ? path('front_products') : path('front_products_public') }}">Produits</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('app_forum_home') }}">Forums</a></li>

            {% if app.user %}
              <li class="nav-item active"><a class="nav-link" href="{{ path('user_dashboard') }}">Mon espace</a></li>
              <li class="nav-item"><a class="nav-link" href="{{ path('front_logout') }}">Déconnexion</a></li>
              <li class="nav-item" style="margin-left: 8px;">
                <a class="nav-link" href="{{ path('app_forum_alerts') }}" style="position:relative;display:inline-flex;align-items:center" title="Alertes et notifications">
                  🔔
                  <span id="notif-badge" style="display:none;position:absolute;top:-8px;right:-8px;background:#ef4444;color:white;border-radius:50%;width:20px;height:20px;font-size:10px;font-weight:bold;display:flex;align-items:center;justify-content:center"></span>
                </a>
              </li>
              <li class="nav-item" style="margin-left: 8px;">
                <a class="nav-link" href="{{ path('forum_policy') }}" style="display:inline-flex;align-items:center" title="Règles de la communauté">
                  📜
                </a>
              </li>
              <li class="nav-item" style="margin-left: 8px;">
                <a class="nav-link" href="{{ path('app_forum_blocked_users') }}" style="display:inline-flex;align-items:center" title="Utilisateurs bloqués">
                  🚫
                </a>
              </li>
            {% else %}
              <li class="nav-item"><a class="nav-link" href="{{ path('front_login') }}">Connexion</a></li>
            {% endif %}
          </ul>
        </div>
      </div>
    </nav>
  </header>

  <div class="page-heading header-text">
    <div class="container">
      <div class="row">
        <div class="col-md-12">
          <h1>Produits</h1>
          <span>Détails du produit</span>
        </div>
      </div>
    </div>
  </div>

  <div class="page-shell">
    <div class="container">
      <div class="row">
        <div class="col-lg-3 mb-4">
          <div class="sidebar">
            <div class="title">Mon espace</div>
            <a href="{{ path('user_dashboard') }}">Dashboard</a>
            <a href="{{ path('user_transactions') }}">Transactions</a>
            <a href="{{ path('user_goals') }}">Goals</a>
            <a href="{{ path('user_bills') }}">Factures</a>
            <a href="{{ path('investissement_index') }}">Investissement</a>
            <a href="{{ path('front_products') }}" class="active">Produits</a>
            <a href="{{ path('front_ads') }}">Annonces</a>
            <a href="{{ path('user_buy_points') }}">Acheter des points</a>
            <a href="{{ path('user_topup') }}">Alimenter carte</a>
            <a href="{{ path('user_dashboard') ~ '?section=edit' }}">Modifier le profil</a>
            
          </div>
        </div>

        <div class="col-lg-9">
          <div class="card-shell mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap" style="gap:12px">
              <div>
                <h4 style="font-weight:900;margin:0">{{ product.name }}</h4>
                <div class="meta">Consultez le stock et le prix en points</div>
              </div>
              <a href="{{ path('front_products') }}" class="btn btn-outline-secondary" style="border-radius:12px;font-weight:700;white-space:nowrap">
                <i class="fa fa-arrow-left mr-1"></i> Retour
              </a>
            </div>
          </div>

          <div class="product-hero">
            <div class="row">
              <div class="col-md-6 mb-4 mb-md-0">
                {% if product.image %}
                  <img src="{{ asset(product.image) }}" alt="{{ product.name }}" class="product-thumb">
                {% else %}
                  <div class="product-thumb d-flex align-items-center justify-content-center">
                    <i class="fa fa-image fa-3x text-muted"></i>
                  </div>
                {% endif %}
              </div>

              <div class="col-md-6">
                <div class="mb-3">
                  <div class="meta" style="font-weight:800;color:#0f766e">Prix</div>
                  <div class="mt-2">
                    <span class="badge bg-warning text-dark price-badge">{{ product.pricePoints }} pts</span>
                  </div>
                </div>

                <div class="mb-3">
                  <div class="meta" style="font-weight:800;color:#0f766e">Stock disponible</div>
                  <div class="alert {{ product.stock > 10 ? 'alert-success' : (product.stock > 0 ? 'alert-warning' : 'alert-danger') }} mb-0" role="alert" style="border-radius:12px;font-weight:700">
                    <i class="fa {{ product.stock > 0 ? 'fa-check-circle' : 'fa-times-circle' }} mr-1"></i>
                    {{ product.stock > 0 ? product.stock ~ ' unité(s) en stock' : 'Produit actuellement indisponible' }}
                  </div>
                </div>

                <div class="mb-4">
                  <div class="meta" style="font-weight:800;color:#0f766e">Description</div>
                  <p class="mb-0" style="font-weight:600">{{ product.description ?? 'Pas de description disponible' }}</p>
                </div>

                <div class="mb-4">
                  <div class="meta" style="font-weight:800;color:#0f766e">Évaluation</div>
                  <div id="rating-container" class="mt-2" style="background:#f8fafc;border-radius:12px;padding:16px;border:1px solid #e2e8f0">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                      <div id="rating-display">
                        <span class="text-muted">Chargement...</span>
                      </div>
                      <div id="rating-stats" class="text-muted" style="font-size:13px;font-weight:600"></div>
                    </div>
                    <div id="rating-input-container" style="display:none">
                      <div class="meta mb-2" style="font-size:12px">Votre note:</div>
                      <div class="star-rating-interactive" id="star-rating-interactive"></div>
                    </div>
                    <div id="rating-message" class="mt-2" style="font-size:13px;display:none"></div>
                  </div>
                </div>

                <div id="purchase-message" class="alert mb-3" style="display:none;border-radius:12px"></div>
                <div class="d-flex flex-wrap" style="gap:10px">
                  {% if app.user %}
                    {% if product.stock > 0 %}
                      <button type="button" id="purchase-btn" class="btn btn-success" style="border-radius:12px;font-weight:800">
                        <i class="fa fa-shopping-cart mr-1"></i> Acheter maintenant ({{ product.pricePoints }} pts)
                      </button>
                    {% else %}
                      <button type="button" class="btn btn-secondary" disabled style="border-radius:12px;font-weight:800">
                        <i class="fa fa-ban mr-1"></i> Indisponible
                      </button>
                    {% endif %}
                  {% else %}
                    <a href="{{ path('front_login') }}" class="btn btn-primary" style="border-radius:12px;font-weight:800">
                      <i class="fa fa-sign-in mr-1"></i> Connecter pour acheter
                    </a>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Custom Purchase Modal -->
  <div id="purchase-modal" class="purchase-modal-overlay" style="display:none">
    <div class="purchase-modal">
      <div class="modal-header-section">
        <div class="modal-icon">
          <svg viewBox="0 0 24 24" fill="none" style="width:48px;height:48px;color:#10b981">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="modal-title">Confirmer votre achat</h3>
      </div>
      <div class="modal-body-section">
        <div class="product-preview">
          <div class="product-preview-icon">
            <i class="fa fa-gift" style="font-size:32px;color:#0f766e"></i>
          </div>
          <div class="product-preview-info">
            <div class="product-preview-name">{{ product.name }}</div>
            <div class="product-preview-desc">{{ product.description is defined ? (product.description|length > 50 ? product.description[:50] ~ '...' : product.description) : 'Produit exclusif' }}</div>
          </div>
        </div>
        <div class="price-summary">
          <div class="price-row">
            <span>Prix</span>
            <span class="price-value"><i class="fa fa-star" style="color:#f59e0b"></i> {{ product.pricePoints }} points</span>
          </div>
          <div class="price-row">
            <span>Votre solde</span>
            <span class="price-value">{{ app.user ? app.user.points : 0 }} points</span>
          </div>
          <div class="price-row total">
            <span>Solde après achat</span>
            <span class="price-value" id="new-balance">{{ app.user ? app.user.points - product.pricePoints : 0 }} points</span>
          </div>
        </div>
      </div>
      <div class="modal-footer-section">
        <button type="button" id="modal-cancel" class="modal-btn cancel">
          <i class="fa fa-times mr-1"></i> Annuler
        </button>
        <button type="button" id="modal-confirm" class="modal-btn confirm">
          <i class="fa fa-check mr-1"></i> Confirmer l'achat
        </button>
      </div>
    </div>
  </div>

  <script src="{{ asset('front/vendor/jquery/jquery.min.js') }}"></script>
  <script src="{{ asset('front/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
  <script src="{{ asset('bundles/starrating/js/rating.js') }}"></script>
  <style>
    .purchase-modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.6);
      backdrop-filter: blur(4px);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      animation: fadeIn 0.3s ease;
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes slideUp {
      from { transform: translateY(20px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }
    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.05); }
    }
    .purchase-modal {
      background: linear-gradient(145deg, #ffffff 0%, #f8fafc 100%);
      border-radius: 24px;
      width: 90%;
      max-width: 420px;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(15, 118, 110, 0.1);
      animation: slideUp 0.4s ease;
      overflow: hidden;
    }
    .modal-header-section {
      background: linear-gradient(135deg, #0f766e 0%, #10b981 100%);
      padding: 28px 24px;
      text-align: center;
    }
    .modal-icon {
      width: 72px;
      height: 72px;
      background: rgba(255, 255, 255, 0.2);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 12px;
    }
    .modal-title {
      color: #fff;
      font-size: 20px;
      font-weight: 800;
      margin: 0;
    }
    .modal-body-section {
      padding: 24px;
    }
    .product-preview {
      display: flex;
      align-items: center;
      gap: 16px;
      background: #f1f5f9;
      border-radius: 16px;
      padding: 16px;
      margin-bottom: 20px;
    }
    .product-preview-icon {
      width: 56px;
      height: 56px;
      background: linear-gradient(135deg, rgba(15, 118, 110, 0.1) 0%, rgba(16, 185, 129, 0.1) 100%);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .product-preview-info {
      flex: 1;
    }
    .product-preview-name {
      font-weight: 800;
      font-size: 16px;
      color: #1e293b;
      margin-bottom: 4px;
    }
    .product-preview-desc {
      font-size: 13px;
      color: #64748b;
    }
    .price-summary {
      background: #fff;
      border-radius: 16px;
      padding: 16px;
      border: 1px solid #e2e8f0;
    }
    .price-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0;
      border-bottom: 1px dashed #e2e8f0;
    }
    .price-row:last-child {
      border-bottom: none;
    }
    .price-row span:first-child {
      color: #64748b;
      font-weight: 600;
    }
    .price-value {
      font-weight: 800;
      color: #1e293b;
    }
    .price-row.total {
      background: linear-gradient(135deg, rgba(15, 118, 110, 0.08) 0%, rgba(16, 185, 129, 0.08) 100%);
      margin: 8px -16px -16px;
      padding: 16px;
      border-radius: 0 0 16px 16px;
      border-bottom: none;
    }
    .price-row.total span:first-child {
      color: #0f766e;
    }
    .price-row.total .price-value {
      color: #0f766e;
      font-size: 18px;
    }
    .modal-footer-section {
      display: flex;
      gap: 12px;
      padding: 20px 24px;
      background: #f8fafc;
      border-top: 1px solid #e2e8f0;
    }
    .modal-btn {
      flex: 1;
      padding: 14px 20px;
      border-radius: 12px;
      font-weight: 800;
      font-size: 15px;
      border: none;
      cursor: pointer;
      transition: all 0.2s ease;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .modal-btn.cancel {
      background: #fff;
      color: #64748b;
      border: 2px solid #e2e8f0;
    }
    .modal-btn.cancel:hover {
      background: #f1f5f9;
      border-color: #cbd5e1;
    }
    .modal-btn.confirm {
      background: linear-gradient(135deg, #0f766e 0%, #10b981 100%);
      color: #fff;
      box-shadow: 0 4px 14px rgba(15, 118, 110, 0.4);
    }
    .modal-btn.confirm:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(15, 118, 110, 0.5);
    }
    .modal-btn.confirm:active {
      transform: translateY(0);
    }
  </style>
  <script>
    var token = null;
    try {
      token = localStorage.getItem('finovate_token') || sessionStorage.getItem('finovate_token');
    } catch (e) {}

    var purchaseBtn = document.getElementById('purchase-btn');
    var purchaseMessage = document.getElementById('purchase-message');
    var purchaseModal = document.getElementById('purchase-modal');
    var modalCancel = document.getElementById('modal-cancel');
    var modalConfirm = document.getElementById('modal-confirm');

    if (purchaseBtn) {
      purchaseBtn.addEventListener('click', function() {
        if (!token) {
          window.location.href = '{{ path('front_login') }}';
          return;
        }
        // Show custom modal
        purchaseModal.style.display = 'flex';
      });
    }

    if (modalCancel) {
      modalCancel.addEventListener('click', function() {
        purchaseModal.style.display = 'none';
      });
    }

    // Close modal on overlay click
    if (purchaseModal) {
      purchaseModal.addEventListener('click', function(e) {
        if (e.target === purchaseModal) {
          purchaseModal.style.display = 'none';
        }
      });
    }

    if (modalConfirm) {
      modalConfirm.addEventListener('click', function() {
        purchaseModal.style.display = 'none';
        purchaseBtn.disabled = true;
        purchaseBtn.innerHTML = '<span class="spinner-border spinner-border-sm mr-1"></span> Traitement...';

        fetch('/api/product/{{ product.id }}/purchase', {
          method: 'POST',
          headers: {
            'Authorization': 'Bearer ' + token,
            'Content-Type': 'application/json'
          }
        })
          .then(function(res) { return res.json(); })
          .then(function(data) {
            if (data.success) {
              purchaseMessage.className = 'alert alert-success mb-3';
              purchaseMessage.style.display = '';
              purchaseMessage.innerHTML = '<i class="fa fa-check-circle mr-1"></i> ' + data.message;
              purchaseBtn.innerHTML = '<i class="fa fa-check mr-1"></i> Achat réussi';
              purchaseBtn.className = 'btn btn-success';
              purchaseBtn.disabled = true;
              
              setTimeout(function() {
                window.location.href = '{{ path('front_products') }}';
              }, 2000);
            } else {
              purchaseMessage.className = 'alert alert-danger mb-3';
              purchaseMessage.style.display = '';
              purchaseMessage.innerHTML = '<i class="fa fa-exclamation-circle mr-1"></i> ' + data.message;
              purchaseBtn.disabled = false;
              purchaseBtn.innerHTML = '<i class="fa fa-shopping-cart mr-1"></i> Acheter maintenant ({{ product.pricePoints }} pts)';
            }
          })
          .catch(function(err) {
            purchaseMessage.className = 'alert alert-danger mb-3';
            purchaseMessage.style.display = '';
            purchaseMessage.innerHTML = '<i class="fa fa-exclamation-circle mr-1"></i> Erreur réseau. Réessayez.';
            purchaseBtn.disabled = false;
            purchaseBtn.innerHTML = '<i class="fa fa-shopping-cart mr-1"></i> Acheter maintenant ({{ product.pricePoints }} pts)';
          });
      });
    }

    // Rating system
    var productId = {{ product.id }};
    var ratingDisplay = document.getElementById('rating-display');
    var ratingStats = document.getElementById('rating-stats');
    var ratingInputContainer = document.getElementById('rating-input-container');
    var ratingInteractive = document.getElementById('star-rating-interactive');
    var ratingMessage = document.getElementById('rating-message');
    var userRating = null;

    // Load rating data
    fetch('/api/product/' + productId + '/rating', {
      method: 'GET',
      headers: token ? { 'Authorization': 'Bearer ' + token } : {}
    })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        // Display average rating
        if (data.average !== null) {
          var stars = '';
          for (var i = 1; i <= 5; i++) {
            if (i <= Math.round(data.average)) {
              stars += '<i class="fa fa-star" style="color:#f59e0b;font-size:18px"></i>';
            } else if (i - 0.5 <= data.average) {
              stars += '<i class="fa fa-star-half-alt" style="color:#f59e0b;font-size:18px"></i>';
            } else {
              stars += '<i class="fa fa-star-o" style="color:#d1d5db;font-size:18px"></i>';
            }
          }
          ratingDisplay.innerHTML = stars + ' <span style="font-weight:800;color:#1e293b;margin-left:6px">' + data.average + '</span>';
          ratingStats.textContent = data.total + ' avis';
        } else {
          ratingDisplay.innerHTML = '<span class="text-muted">Aucune évaluation</span>';
          ratingStats.textContent = '';
        }

        // Show rating input if user is logged in
        if (token) {
          userRating = data.userRating;
          ratingInputContainer.style.display = 'block';
          renderInteractiveStars(userRating || 0);
        }
      })
      .catch(function(err) {
        ratingDisplay.innerHTML = '<span class="text-muted">Erreur de chargement</span>';
      });

    function renderInteractiveStars(rating) {
      var html = '';
      for (var i = 1; i <= 5; i++) {
        var isActive = i <= rating;
        html += '<i class="fa ' + (isActive ? 'fa-star' : 'fa-star-o') + '" data-rating="' + i + '" style="cursor:pointer;font-size:24px;color:' + (isActive ? '#f59e0b' : '#d1d5db') + ';margin-right:4px;transition:color 0.2s" onmouseover="highlightStars(' + i + ')" onmouseout="resetStars(' + (userRating || 0) + ')" onclick="submitRating(' + i + ')"></i>';
      }
      ratingInteractive.innerHTML = html;
    }

    window.highlightStars = function(n) {
      var stars = ratingInteractive.querySelectorAll('i');
      stars.forEach(function(star, idx) {
        star.style.color = (idx < n) ? '#f59e0b' : '#d1d5db';
        star.className = 'fa ' + (idx < n ? 'fa-star' : 'fa-star-o');
      });
    };

    window.resetStars = function(n) {
      renderInteractiveStars(n);
    };

    window.submitRating = function(rating) {
      if (!token) {
        window.location.href = '{{ path('front_login') }}';
        return;
      }

      fetch('/api/product/' + productId + '/rating', {
        method: 'POST',
        headers: {
          'Authorization': 'Bearer ' + token,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ rating: rating })
      })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.success) {
            userRating = rating;
            renderInteractiveStars(rating);
            ratingMessage.style.display = 'block';
            ratingMessage.className = 'mt-2 text-success';
            ratingMessage.innerHTML = '<i class="fa fa-check-circle mr-1"></i>' + data.message;

            // Update display
            if (data.average !== null) {
              var stars = '';
              for (var i = 1; i <= 5; i++) {
                if (i <= Math.round(data.average)) {
                  stars += '<i class="fa fa-star" style="color:#f59e0b;font-size:18px"></i>';
                } else if (i - 0.5 <= data.average) {
                  stars += '<i class="fa fa-star-half-alt" style="color:#f59e0b;font-size:18px"></i>';
                } else {
                  stars += '<i class="fa fa-star-o" style="color:#d1d5db;font-size:18px"></i>';
                }
              }
              ratingDisplay.innerHTML = stars + ' <span style="font-weight:800;color:#1e293b;margin-left:6px">' + data.average + '</span>';
              ratingStats.textContent = data.total + ' avis';
            }

            setTimeout(function() {
              ratingMessage.style.display = 'none';
            }, 3000);
          } else {
            ratingMessage.style.display = 'block';
            ratingMessage.className = 'mt-2 text-danger';
            ratingMessage.innerHTML = '<i class="fa fa-exclamation-circle mr-1"></i>' + data.message;
          }
        })
        .catch(function(err) {
          ratingMessage.style.display = 'block';
          ratingMessage.className = 'mt-2 text-danger';
          ratingMessage.innerHTML = '<i class="fa fa-exclamation-circle mr-1"></i> Erreur réseau';
        });
    };
  </script>
</body>

</html>