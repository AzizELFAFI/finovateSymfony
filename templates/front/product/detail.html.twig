<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{ product.name }} - Finovate</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    body { padding-top: 80px; }
    .navbar { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .product-header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 40px 0; }
  </style>
</head>
<body>
  <!-- NAVIGATION -->
  <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="{{ path('front_home') }}">Finovate</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link active" href="{{ path('front_products') }}">Produits</a></li>
          <li class="nav-item"><a class="nav-link" href="{{ path('front_ads') }}">Annonces</a></li>
          <li class="nav-item"><a class="nav-link" href="{{ path('user_topup') }}">Alimenter carte</a></li>
          <li class="nav-item"><a class="nav-link" href="{{ path('user_dashboard') }}">Dashboard</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- BREADCRUMB -->
  <div class="product-header">
    <div class="container">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb breadcrumb-light">
          <li class="breadcrumb-item"><a href="{{ path('front_home') }}" class="text-white">Accueil</a></li>
          <li class="breadcrumb-item"><a href="{{ path('front_products') }}" class="text-white">Produits</a></li>
          <li class="breadcrumb-item active text-white">{{ product.name }}</li>
        </ol>
      </nav>
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <main class="py-5">
    <div class="container">
      <div class="row">
        <!-- PRODUCT IMAGE -->
        <div class="col-md-6 mb-4">
          {% if product.image %}
            <img src="{{ product.image }}" alt="{{ product.name }}" class="img-fluid rounded-3 shadow-sm">
          {% else %}
            <div class="bg-light rounded-3 d-flex align-items-center justify-content-center" style="height: 500px;">
              <i class="fas fa-image fa-5x text-muted"></i>
            </div>
          {% endif %}
        </div>

        <!-- PRODUCT INFO -->
        <div class="col-md-6">
          <h1 class="display-5 mb-3">{{ product.name }}</h1>
          
          <div class="mb-4">
            <h4 class="text-muted mb-2">Prix</h4>
            <div class="bg-warning bg-opacity-10 p-3 rounded-3">
              <span class="display-6 fw-bold text-warning">{{ product.pricePoints }}</span>
              <span class="fs-5 text-muted"> points</span>
            </div>
          </div>

          <div class="mb-4">
            <h4 class="text-muted mb-2">Stock disponible</h4>
            <div class="alert {{ product.stock > 10 ? 'alert-success' : (product.stock > 0 ? 'alert-warning' : 'alert-danger') }}">
              <i class="fas {{ product.stock > 0 ? 'fa-check-circle' : 'fa-times-circle' }}"></i>
              {{ product.stock > 0 ? product.stock ~ ' unité(s) en stock' : 'Produit actuellement indisponible' }}
            </div>
          </div>

          <div class="mb-4">
            <h4 class="text-muted mb-2">Description</h4>
            <p class="lead">{{ product.description ?? 'Pas de description disponible' }}</p>
          </div>

          <div class="d-flex gap-2">
            {% if product.stock > 0 %}
              <button type="button" class="btn btn-primary btn-lg">
                <i class="fas fa-shopping-cart"></i> Acheter maintenant
              </button>
            {% else %}
              <button type="button" class="btn btn-secondary btn-lg" disabled>
                <i class="fas fa-ban"></i> Indisponible
              </button>
            {% endif %}
            <a href="{{ path('front_products') }}" class="btn btn-outline-secondary btn-lg">
              <i class="fas fa-arrow-left"></i> Retour
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>