                        </div>
                        <div class="form-group mb-0">
                          <button type="submit" class="btn btn-success inv-btn-submit-day"><i class="fa fa-save" aria-hidden="true"></i> Enregistrer ce jour</button>
                        </div>
                      </form>
                    </div>
                  {% else %}
                    <div class="inv-rev-scheduled">
                      <i class="fa fa-info-circle" style="margin-right:0.35rem" aria-hidden="true"></i>
                      {{ dr.message|default('Prochaine saisie à la date indiquée.') }}
                    </div>
                  {% endif %}
                </div>
              </article>
            {% endfor %}
            </div>
            {% endif %}
          </div>

