  <div class="modal fade" id="manageMyProjectsModal" tabindex="-1" role="dialog" aria-labelledby="manageMyProjectsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable" role="document">
      <div class="modal-content">
        <div class="modal-header border-0">
          <h5 class="modal-title mb-0" id="manageMyProjectsModalLabel">Gérer mes projets</h5>
          <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <div id="manage-projects-list"{% if openEditProjectPanel %} style="display:none"{% endif %}>
            {% if myProjects is empty %}
              <p class="text-muted mb-0" style="font-weight:600">Vous n’avez pas encore de projet. Utilisez <strong>Ajouter un projet</strong> pour en créer un.</p>
            {% else %}
            <div class="inv-manage-stack">
            {% for p in myProjects %}
              {% set g = p.goalAmount|default('0')|replace({',': '.'}) + 0 %}
              {% set cu = p.currentAmount|default('0')|replace({',': '.'}) + 0 %}
              {% set pctFund = (g > 0) ? ((cu / g) * 100) : 0 %}
              {% if pctFund > 100 %}{% set pctFund = 100 %}{% endif %}
              {% set dr = dailyRevenueUi[p.id]|default({}) %}
              {% set pend = pendingByProject[p.id] ?? [] %}

              <article class="inv-manage-card">
                <div class="inv-manage-card__top">
                  <div class="inv-manage-card__identity">
                    <div class="inv-thumb-wrap">
                      {% if p.imagePath %}
                        <img src="{{ asset(p.imagePath) }}" alt="">
                      {% else %}
                        <i class="fa fa-briefcase" aria-hidden="true"></i>
                      {% endif %}
                    </div>
                    <div>
                      <h3 class="inv-manage-card__title">{{ p.title }}</h3>
                      <div class="inv-pill-row">
                        <span class="inv-pill inv-pill--cat"><i class="fa fa-tag" aria-hidden="true"></i> {{ p.category ?? 'Sans catégorie' }}</span>
                        {% if pctFund >= 100 %}
                          <span class="inv-pill inv-pill--ok"><i class="fa fa-check-circle" aria-hidden="true"></i> Objectif atteint</span>
                        {% else %}
                          <span class="inv-pill inv-pill--wait"><i class="fa fa-clock-o" aria-hidden="true"></i> En financement</span>
                        {% endif %}
                      </div>
                    </div>
                  </div>
                  <div class="inv-manage-card__actions">
                    <button type="button" class="btn btn-success btn-sm js-open-edit-project" data-project-id="{{ p.id }}">
                      <i class="fa fa-pencil" aria-hidden="true"></i> Modifier
                    </button>
                    <form method="post" action="{{ path('investissement_project_delete', { id: p.id }) }}" class="d-inline"
                      onsubmit="return confirm('Supprimer ce projet et ses investissements ?');">
                      <input type="hidden" name="_token" value="{{ csrf_token('delete_project_' ~ p.id) }}">
                      <button type="submit" class="btn btn-outline-danger btn-sm"><i class="fa fa-trash" aria-hidden="true"></i> Supprimer</button>
                    </form>
                  </div>
                </div>

                {% if pend is not empty %}
                  <div class="inv-pending-wrap">
                    <div class="inv-section-label">Demandes en attente</div>
                    {% for inv in pend %}
                      <div class="inv-pending-row">
                        <div style="min-width:200px">
                          <strong>{{ inv.user.email }}</strong>
                          <div class="meta">{{ inv.amount }} — {{ inv.investmentDate|date('d/m/Y H:i') }}</div>
                          {% if inv.revenuePercentage is not null %}
                            <div class="meta" style="color:#0f766e;font-weight:700">Revenu souhaité : {{ inv.revenuePercentage }}%</div>
                          {% endif %}
                        </div>
                        <div class="d-flex flex-wrap" style="gap:6px">
                          <form method="post" action="{{ path('investissement_demande_accepter', { id: inv.id }) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('invest_demande_owner_' ~ inv.id) }}">
                            <button type="submit" class="btn btn-success btn-sm" style="border-radius:8px;font-weight:800"><i class="fa fa-check" aria-hidden="true"></i> Accepter</button>
                          </form>
                          <form method="post" action="{{ path('investissement_demande_refuser', { id: inv.id }) }}" class="d-inline"
                            onsubmit="return confirm('Refuser cette demande ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('invest_demande_owner_' ~ inv.id) }}">
                            <button type="submit" class="btn btn-outline-secondary btn-sm" style="border-radius:8px;font-weight:700">Refuser</button>
                          </form>
                        </div>
                      </div>
                    {% endfor %}
                  </div>
                {% endif %}

                <div class="inv-block inv-block--fund">
                  <div class="inv-block__head">
                    <div class="inv-block__head-left"><i class="fa fa-line-chart" aria-hidden="true"></i> Financement</div>
                    <span class="inv-fund-pct">{{ pctFund|round }}%</span>
                  </div>
                  <div class="inv-progress-track" aria-hidden="true">
                    <div class="inv-progress-fill" style="width: {{ pctFund }}%"></div>
                  </div>
                  <div class="inv-fund-nums">{{ cu|number_format(2, ',', ' ') }} collectés · objectif {{ g|number_format(2, ',', ' ') }}</div>
                </div>

                <div class="inv-block inv-block--rev">
                  <div class="inv-block__head">
                    <div class="inv-block__head-left"><i class="fa fa-calendar-check-o" aria-hidden="true"></i> Revenus quotidiens</div>
                  </div>

                  {% if dr.funded is not defined or not dr.funded %}
                    <div class="inv-rev-locked">
                      <i class="fa fa-lock" aria-hidden="true"></i>
                      <p>{{ dr.message|default('Les revenus quotidiens sont débloqués lorsque la collecte atteint 100 % de l’objectif.') }}</p>
                    </div>
                  {% elseif dr.show_form is defined and dr.show_form %}
                    {% if dr.message is defined and dr.message %}
                      <div class="inv-callout">
                        <i class="fa fa-exclamation-triangle" aria-hidden="true"></i>
                        <p>{{ dr.message }}</p>
                      </div>
                    {% endif %}
                    <p class="inv-rev-intro">
                      Saisie pour le <strong>{{ dr.next_label|default('—') }}</strong> — un jour calendaire à la fois (gain, zéro ou perte).
                    </p>
                    <div class="inv-rev-form-box">
                      <div class="inv-date-badge"><i class="fa fa-clock-o" aria-hidden="true"></i> Jour concerné : {{ dr.next_label|default('—') }}</div>
                      <form method="post" action="{{ path('investissement_daily_revenue', { id: p.id }) }}" class="inv-rev-form-row">
                        <input type="hidden" name="_token" value="{{ csrf_token('daily_revenue_' ~ p.id) }}">
