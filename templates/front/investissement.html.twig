  <script>
  /* ── Unsplash image picker ── */
  (function () {    var selectedUrl = '';

    function renderUnsplashResults(results) {
      var $wrap = $('#unsplash-results');
      $wrap.empty();
      if (!results.length) {
        $wrap.html('<span class="meta">Aucun résultat.</span>');
        return;
      }
      results.forEach(function (photo) {
        var $img = $('<img>')
          .attr('src', photo.thumb)
          .attr('alt', photo.alt || '')
          .attr('title', 'Photo par ' + photo.user + ' sur Unsplash')
          .css({
            width: '80px', height: '60px', objectFit: 'cover',
            borderRadius: '8px', cursor: 'pointer',
            border: '2px solid transparent', transition: 'border-color .15s'
          })
          .on('click', function () {
            selectedUrl = photo.full;
            $('#unsplash-image-url-input').val(photo.full);
            $('#unsplash-selected-preview').attr('src', photo.full);
            $('#unsplash-selected-credit').html(
              'Photo par <a href="' + photo.link + '" target="_blank" rel="noopener">' + photo.user + '</a> sur Unsplash'
            );
            $('#unsplash-selected-wrap').show();
            // Clear file input when Unsplash image is chosen
            $('#create-image-file').val('');
            $wrap.find('img').css('border-color', 'transparent');
            $(this).css('border-color', '#0f766e');
          });
        $wrap.append($img);
      });
    }

    $('#unsplash-search-btn').on('click', function () {
      var q = $('#unsplash-query').val().trim();
      if (!q) return;
      var $btn = $(this);
      $btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i>');
      $.get('/api/proxy/unsplash', { query: q })
        .done(function (data) { renderUnsplashResults(data.results || []); })
        .fail(function () { $('#unsplash-results').html('<span class="meta text-danger">Erreur Unsplash.</span>'); })
        .always(function () { $btn.prop('disabled', false).html('<i class="fa fa-search"></i> Chercher'); });
    });

    $('#unsplash-query').on('keydown', function (e) {
      if (e.key === 'Enter') { e.preventDefault(); $('#unsplash-search-btn').trigger('click'); }
    });

    // Auto-search when title is filled
    var unsplashAutoTimer;
    $(document).on('input', '#' + '{{ createForm.title.vars.id }}', function () {
      clearTimeout(unsplashAutoTimer);
      var val = $(this).val().trim();
      if (val.length < 3) return;
      unsplashAutoTimer = setTimeout(function () {
        $('#unsplash-query').val(val);
        $('#unsplash-search-btn').trigger('click');
      }, 800);
    });

    // Clear Unsplash selection when file is chosen
    $('#create-image-file').on('change', function () {
      if ($(this).val()) {
        selectedUrl = '';
        $('#unsplash-image-url-input').val('');
        $('#unsplash-selected-wrap').hide();
        $('#unsplash-results img').css('border-color', 'transparent');
      }
    });

    // Reset on modal close
    $('#addProjectModal').on('hidden.bs.modal', function () {
      selectedUrl = '';
      $('#unsplash-image-url-input').val('');
      $('#unsplash-selected-wrap').hide();
      $('#unsplash-results').empty();
      $('#unsplash-query').val('');
    });
  })();

  /* ── Exchange rate converter ── */
  (function () {
    var ratesCache = {};

    function convert() {
      var goalRaw = $('#{{ createForm.goalAmount.vars.id }}').val().replace(',', '.');
      var goal = parseFloat(goalRaw);
      var currency = $('#exchange-currency').val();
      var $result = $('#exchange-result');

      if (!goal || goal <= 0) {
        $result.text('Entrez d\'abord un objectif.');
        return;
      }

      if (ratesCache[currency] !== undefined) {
        var converted = (goal * ratesCache[currency]).toFixed(2);
        $result.text(goal.toFixed(2) + ' TND ≈ ' + converted + ' ' + currency);
        return;
      }

      var $btn = $('#exchange-btn');
      $btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i>');

      $.get('/api/proxy/exchange', { base: 'TND' })
        .done(function (data) {
          ratesCache = data.rates || {};
          var rate = ratesCache[currency];
          if (rate) {
            var converted = (goal * rate).toFixed(2);
            $result.text(goal.toFixed(2) + ' TND ≈ ' + converted + ' ' + currency);
          } else {
            $result.text('Devise non disponible.');
          }
        })
        .fail(function () { $result.text('Erreur de conversion.'); })
        .always(function () { $btn.prop('disabled', false).html('<i class="fa fa-refresh"></i> Convertir'); });
    }

    $('#exchange-btn').on('click', convert);
    $('#exchange-currency').on('change', function () { if ($('#exchange-result').text()) convert(); });
  })();

  /* ── Objectif création / édition : aperçu EUR · USD (taux indicatifs) ── */
  (function () {
    var invFxCache = null;
    var deb;

    function ensureFx(cb) {
      if (invFxCache) {
        cb(invFxCache);
        return;
      }
      $.getJSON("{{ path('investissement_api_fx_preview') }}").done(function (d) {
        if (d.ok && d.rates) {
          invFxCache = d.rates;
          cb(invFxCache);
        }
      });
    }

    function fillEquiv($out, goal) {
      if (!goal || goal <= 0) {
        $out.text('');
        return;
      }
      ensureFx(function (r) {
        var e = (goal * r.EUR).toFixed(2);
        var u = (goal * r.USD).toFixed(2);
        $out.text('À titre indicatif · objectif ≈ ' + e + ' EUR · ' + u + ' USD (taux du jour).');
      });
    }

    $('#{{ createForm.goalAmount.vars.id }}').on('input', function () {
      clearTimeout(deb);
      deb = setTimeout(function () {
        var goal = parseFloat(String($('#{{ createForm.goalAmount.vars.id }}').val()).replace(',', '.'));
        fillEquiv($('#create-goal-fx-equiv'), goal);
      }, 400);
    });

    $('#{{ editProjectForm.goalAmount.vars.id }}').on('input', function () {
      clearTimeout(deb);
      deb = setTimeout(function () {
        var goal = parseFloat(String($('#{{ editProjectForm.goalAmount.vars.id }}').val()).replace(',', '.'));
        fillEquiv($('#edit-goal-fx-equiv'), goal);
      }, 400);
    });

    $('#addProjectModal').on('shown.bs.modal', function () {
      var goal = parseFloat(String($('#{{ createForm.goalAmount.vars.id }}').val()).replace(',', '.'));
      fillEquiv($('#create-goal-fx-equiv'), goal);
    });
  })();

  /* ── Cartes projet : équivalents devise + points clés IA ── */
  (function () {
    var fxUrl = "{{ path('investissement_api_fx_preview') }}";
    var insightsTpl = "{{ path('investissement_api_project_insights', { id: 999999 }) }}";

    function refreshProjectCardsFx() {
      $.getJSON(fxUrl).done(function (d) {
        if (!d.ok || !d.rates) {
          $('.inv-card-fx').addClass('inv-card-fx-box--muted');
          $('.inv-card-fx-text').html(
            'Équivalents EUR/USD non disponibles pour le moment <span style="opacity:.85">(service de change ou réseau)</span>. ' +
              '<strong>Les montants TND ci-dessus font foi.</strong>'
          );
          return;
        }
        var r = d.rates;
        $('.inv-card-fx').removeClass('inv-card-fx-box--muted');
        $('.inv-card-fx').each(function () {
          var $w = $(this);
          var g = parseFloat($w.data('tnd-goal')) || 0;
          var c = parseFloat($w.data('tnd-current')) || 0;
          var ge = (g * r.EUR).toFixed(2);
          var gu = (g * r.USD).toFixed(2);
          var ce = (c * r.EUR).toFixed(2);
          var cu = (c * r.USD).toFixed(2);
          $w.find('.inv-card-fx-text').html(
            'À titre indicatif · objectif ≈ <strong>' + ge + '</strong> EUR · <strong>' + gu +
              '</strong> USD · collecté ≈ <strong>' + ce + '</strong> EUR · <strong>' + cu + '</strong> USD'
          );
        });
      }).fail(function () {
        $('.inv-card-fx').addClass('inv-card-fx-box--muted');
        $('.inv-card-fx-text').html(
          'Impossible de joindre le service de conversion. Vérifiez la connexion. <strong>Référence : montants en TND.</strong>'
        );
      });
    }

    $(refreshProjectCardsFx);

    $(document).on('click', '.inv-ia-load', function (e) {
      e.preventDefault();
      var $block = $(this).closest('.inv-card-ia');
      var pid = $block.data('project-id');
      var $list = $block.find('.inv-ia-list');
      var $foot = $block.find('.inv-ia-foot');
      var $btn = $(this);
      var defaultLabel = 'Afficher une synthèse risques / points clés';
      if ($list.is(':visible') && $list.children().length) {
        $list.slideUp(120);
        $foot.slideUp(80);
        $btn.text(defaultLabel);
        return;
      }
      $btn.prop('disabled', true).text('Génération en cours…');
      $.getJSON(insightsTpl.replace('999999', String(pid))).done(function (res) {
        $list.empty();
        (res.bullets || []).forEach(function (txt) {
          $list.append($('<li/>').text(txt));
        });
        $list.slideDown(160);
        $foot.slideDown(120);
        $btn.prop('disabled', false).text('Masquer la synthèse');
      }).fail(function () {
        $foot.hide();
        $list.empty().append($('<li/>').text('Service de synthèse momentanément indisponible. Réessayez plus tard ou vérifiez la configuration des clés IA.')).slideDown(160);
        $btn.prop('disabled', false).text(defaultLabel);
      });
    });
  })();

  /* ── MapLibre GL — location picker (CREATE) ── */
  (function () {
    var map = null;
    var marker = null;
    var DEFAULT_LNG = 9.5375, DEFAULT_LAT = 33.8869, DEFAULT_ZOOM = 5;
    var TILE = 'https://tile.openstreetmap.org/{z}/{x}/{y}.png';

    function buildStyle() {
      return {
        version: 8,
        sources: { osm: { type: 'raster', tiles: [TILE], tileSize: 256, attribution: '© OpenStreetMap contributors' } },
        layers: [{ id: 'osm', type: 'raster', source: 'osm' }]
      };
    }

    function initMap() {
      if (map) return;
      map = new maplibregl.Map({
        container: 'osm-map',
        style: buildStyle(),
        center: [DEFAULT_LNG, DEFAULT_LAT],
        zoom: DEFAULT_ZOOM,
        attributionControl: false
      });
      map.addControl(new maplibregl.NavigationControl(), 'top-right');
      map.addControl(new maplibregl.AttributionControl({ compact: true }));
      map.on('click', function (e) {
        placeMarker(e.lngLat.lng, e.lngLat.lat);
        reverseGeocode(e.lngLat.lat, e.lngLat.lng);
      });
    }

    function placeMarker(lng, lat) {
      if (marker) {
        marker.setLngLat([lng, lat]);
      } else {
        marker = new maplibregl.Marker({ draggable: true, color: '#0f766e' })
          .setLngLat([lng, lat])
          .addTo(map);
        marker.on('dragend', function () {
          var pos = marker.getLngLat();
          setCoords(pos.lat, pos.lng);
          reverseGeocode(pos.lat, pos.lng);
        });
      }
      map.easeTo({ center: [lng, lat] });
      setCoords(lat, lng);
    }

    function setCoords(lat, lng) {
      $('#project-latitude').val(lat.toFixed(6));
      $('#project-longitude').val(lng.toFixed(6));
    }

    function showLabel(text) {
      $('#osm-label-text').text(text);
    }

    function reverseGeocode(lat, lng) {
      showLabel('Chargement…');
      $.get('https://nominatim.openstreetmap.org/reverse', {
        lat: lat, lon: lng, format: 'json'
      }).done(function (d) {
        if (d && d.display_name) showLabel(d.display_name);
      }).fail(function () {
        showLabel(lat.toFixed(5) + ', ' + lng.toFixed(5));
      });
    }

    // Search by text
    $('#osm-search-btn').on('click', function () {
      var q = $('#osm-search-input').val().trim();
      if (!q) return;
      var $btn = $(this);
      $btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i>');

      $.get('https://nominatim.openstreetmap.org/search', {
        q: q, format: 'json', limit: 1
      }).done(function (results) {
        if (!results.length) {
          showLabel('Aucun résultat pour "' + q + '".');
          return;
        }
        var r = results[0];
        var lat = parseFloat(r.lat);
        var lng = parseFloat(r.lon);
        map.flyTo({ center: [lng, lat], zoom: 13, speed: 1.4 });
        placeMarker(lng, lat);
        showLabel(r.display_name);
      }).fail(function () {
        showLabel('Erreur de géolocalisation.');
      }).always(function () {
        $btn.prop('disabled', false).html('<i class="fa fa-search"></i> Rechercher');
      });
    });

    $('#osm-search-input').on('keydown', function (e) {
      if (e.key === 'Enter') { e.preventDefault(); $('#osm-search-btn').trigger('click'); }
    });

    // Locate me
    $('#osm-locate-me-btn').on('click', function () {
      if (!navigator.geolocation) { alert('Géolocalisation non supportée.'); return; }
      var $btn = $(this);
      $btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i>');
      navigator.geolocation.getCurrentPosition(function (pos) {
        var lat = pos.coords.latitude;
        var lng = pos.coords.longitude;
        map.flyTo({ center: [lng, lat], zoom: 15, speed: 1.4 });
        placeMarker(lng, lat);
        reverseGeocode(lat, lng);
        $btn.prop('disabled', false).html('<i class="fa fa-crosshairs"></i>');
      }, function () {
        alert('Impossible d\'obtenir votre position.');
        $btn.prop('disabled', false).html('<i class="fa fa-crosshairs"></i>');
      });
    });

    // Init map when modal opens
    $('#addProjectModal').on('shown.bs.modal', function () {
      initMap();
      setTimeout(function () { if (map) map.resize(); }, 200);
    });

    // Reset on modal close
    $('#addProjectModal').on('hidden.bs.modal', function () {
      $('#project-latitude').val('');
      $('#project-longitude').val('');
      $('#osm-label-text').text('Cliquez sur la carte pour choisir un emplacement');
      $('#osm-search-input').val('');
      if (marker) { marker.remove(); marker = null; }
    });
  })();

