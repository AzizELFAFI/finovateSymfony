  /* ── MapLibre GL — location picker (EDIT) ── */
  (function () {
    var map = null;
    var marker = null;
    var DEFAULT_LNG = 9.5375, DEFAULT_LAT = 33.8869, DEFAULT_ZOOM = 5;
    var TILE = 'https://tile.openstreetmap.org/{z}/{x}/{y}.png';

    function buildStyle() {
      return {
        version: 8,
        sources: { osm: { type: 'raster', tiles: [TILE], tileSize: 256, attribution: '© OpenStreetMap contributors' } },
        layers: [{ id: 'osm', type: 'raster', source: 'osm' }]
      };
    }

    function initMap(lat, lng, zoom) {
      if (map) {
        map.easeTo({ center: [lng, lat], zoom: zoom || 13 });
        return;
      }
      map = new maplibregl.Map({
        container: 'edit-osm-map',
        style: buildStyle(),
        center: [lng || DEFAULT_LNG, lat || DEFAULT_LAT],
        zoom: zoom || DEFAULT_ZOOM,
        attributionControl: false
      });
      map.addControl(new maplibregl.NavigationControl(), 'top-right');
      map.addControl(new maplibregl.AttributionControl({ compact: true }));
      map.on('click', function (e) {
        placeMarker(e.lngLat.lng, e.lngLat.lat);
        reverseGeocode(e.lngLat.lat, e.lngLat.lng);
      });
    }

    function placeMarker(lng, lat) {
      if (marker) {
        marker.setLngLat([lng, lat]);
      } else {
        marker = new maplibregl.Marker({ draggable: true, color: '#0f766e' })
          .setLngLat([lng, lat])
          .addTo(map);
        marker.on('dragend', function () {
          var pos = marker.getLngLat();
          setCoords(pos.lat, pos.lng);
          reverseGeocode(pos.lat, pos.lng);
        });
      }
      map.easeTo({ center: [lng, lat] });
      setCoords(lat, lng);
    }

    function setCoords(lat, lng) {
      $('#edit-project-latitude').val(lat.toFixed(6));
      $('#edit-project-longitude').val(lng.toFixed(6));
    }

    function showLabel(text) { $('#edit-osm-label-text').text(text); }

    function reverseGeocode(lat, lng) {
      showLabel('Chargement…');
      $.get('https://nominatim.openstreetmap.org/reverse', { lat: lat, lon: lng, format: 'json' })
        .done(function (d) { if (d && d.display_name) showLabel(d.display_name); })
        .fail(function () { showLabel(lat.toFixed(5) + ', ' + lng.toFixed(5)); });
    }

    $('#edit-osm-search-btn').on('click', function () {
      var q = $('#edit-osm-search-input').val().trim();
      if (!q) return;
      var $btn = $(this);
      $btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i>');
      $.get('https://nominatim.openstreetmap.org/search', { q: q, format: 'json', limit: 1 })
        .done(function (results) {
          if (!results.length) { showLabel('Aucun résultat.'); return; }
          var r = results[0];
          var lat = parseFloat(r.lat), lng = parseFloat(r.lon);
          map.flyTo({ center: [lng, lat], zoom: 13, speed: 1.4 });
          placeMarker(lng, lat);
          showLabel(r.display_name);
        })
        .fail(function () { showLabel('Erreur de géolocalisation.'); })
        .always(function () { $btn.prop('disabled', false).html('<i class="fa fa-search"></i> Rechercher'); });
    });

    $('#edit-osm-search-input').on('keydown', function (e) {
      if (e.key === 'Enter') { e.preventDefault(); $('#edit-osm-search-btn').trigger('click'); }
    });

    $('#edit-osm-locate-me-btn').on('click', function () {
      if (!navigator.geolocation) { alert('Géolocalisation non supportée.'); return; }
      var $btn = $(this);
      $btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i>');
      navigator.geolocation.getCurrentPosition(function (pos) {
        var lat = pos.coords.latitude, lng = pos.coords.longitude;
        map.flyTo({ center: [lng, lat], zoom: 15, speed: 1.4 });
        placeMarker(lng, lat);
        reverseGeocode(lat, lng);
        $btn.prop('disabled', false).html('<i class="fa fa-crosshairs"></i>');
      }, function () {
        alert('Impossible d\'obtenir votre position.');
        $btn.prop('disabled', false).html('<i class="fa fa-crosshairs"></i>');
      });
    });

    $(document).on('click', '.js-open-edit-project', function () {
      setTimeout(function () {
        var coords = window._editProjectInitCoords;
        if (coords) {
          initMap(coords.lat, coords.lng, 13);
          setTimeout(function () {
            if (map) { map.resize(); placeMarker(coords.lng, coords.lat); reverseGeocode(coords.lat, coords.lng); }
          }, 300);
        } else {
          initMap(DEFAULT_LAT, DEFAULT_LNG, DEFAULT_ZOOM);
          setTimeout(function () { if (map) map.resize(); }, 300);
        }
      }, 350);
    });

    $(document).on('click', '.js-back-manage-list', function () {
      $('#edit-project-latitude').val('');
      $('#edit-project-longitude').val('');
      $('#edit-osm-label-text').text('Cliquez sur la carte pour choisir un emplacement');
      $('#edit-osm-search-input').val('');
      if (marker) { marker.remove(); marker = null; }
    });

    $('#manageMyProjectsModal').on('shown.bs.modal', function () {
      if (map) setTimeout(function () { map.resize(); }, 200);
    });
  })();
  </script>
</body>

</html>
