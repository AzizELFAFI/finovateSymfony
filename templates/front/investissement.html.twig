  (function () {
    var ratesCache = {};

    function convert() {
      var goalRaw = $('#{{ editProjectForm.goalAmount.vars.id }}').val().replace(',', '.');
      var goal = parseFloat(goalRaw);
      var currency = $('#edit-exchange-currency').val();
      var $result = $('#edit-exchange-result');
