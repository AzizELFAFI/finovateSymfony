<!DOCTYPE html>
<html lang="fr">

  <head>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="TemplateMo">
    <link href="https://fonts.googleapis.com/css?family=Poppins:100,200,300,400,500,600,700,800,900&display=swap" rel="stylesheet">

    <title>Finovate - Mot de passe oublié</title>

    <base href="{{ asset('front/') }}">

    <link href="vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="assets/css/fontawesome.css">
    <link rel="stylesheet" href="assets/css/templatemo-finance-business.css">
    <link rel="stylesheet" href="assets/css/owl.css">

  </head>

  <body>

    <div id="preloader">
        <div class="jumper">
            <div></div>
            <div></div>
            <div></div>
        </div>
    </div>

    <header class="">
      <nav class="navbar navbar-expand-lg">
        <div class="container">
          <a class="navbar-brand" href="{{ path('front_home') }}"><h2>Finovate</h2></a>
          <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarResponsive" aria-controls="navbarResponsive" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarResponsive">
            <ul class="navbar-nav ml-auto">
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_home') }}">Accueil</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_about') }}">À propos</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_services') }}">Nos services</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_contact') }}">Contact</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="{{ path('front_one_page') }}">Présentation</a>
              </li>
              <li class="nav-item active">
                <a class="nav-link" href="{{ path('front_login') }}">Connexion</a>
              </li>
            </ul>
          </div>
        </div>
      </nav>
    </header>

    <div class="page-heading header-text">
      <div class="container">
        <div class="row">
          <div class="col-md-12">
            <h1>Mot de passe oublié</h1>
            <span>Entrez votre e-mail pour recevoir un lien de réinitialisation</span>
          </div>
        </div>
      </div>
    </div>

    <div class="callback-form contact-us">
      <div class="container">
        <div class="row">
          <div class="col-md-12">
            <div class="section-heading">
              <h2>Réinitialiser <em>mon mot de passe</em></h2>
              <span>Un lien vous sera envoyé si l'e-mail existe</span>
            </div>
          </div>
          <div class="col-lg-6 col-md-10 mx-auto">
            <div class="contact-form p-4" style="border-radius: 0; background-color: #e8f5e9;">

              {% for label, messages in app.flashes %}
                {% for message in messages %}
                  <div class="alert alert-{{ label }}" role="alert">{{ message }}</div>
                {% endfor %}
              {% endfor %}

              {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
                <div class="row">
                  <div class="col-lg-12 col-md-12 col-sm-12">
                    <fieldset>
                      {{ form_widget(form.email, { attr: { class: 'form-control', id: 'email' } }) }}
                      {{ form_errors(form.email) }}
                    </fieldset>
                  </div>
                  <div class="col-lg-12 d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                    <fieldset class="mb-3 mb-md-0">
                      <button type="submit" class="filled-button">Envoyer</button>
                    </fieldset>
                    <div>
                      <a href="{{ path('front_login') }}">Retour à la connexion</a>
                    </div>
                  </div>
                </div>
              {{ form_end(form) }}
            </div>
          </div>
        </div>
      </div>
    </div>

    <footer>
      <div class="container">
        <div class="row">
          <div class="col-md-3 footer-item">
            <h4>Liens utiles</h4>
            <ul class="menu-list">
              <li><a href="{{ path('front_home') }}">Accueil</a></li>
              <li><a href="{{ path('front_services') }}">Nos services</a></li>
              <li><a href="{{ path('front_about') }}">À propos</a></li>
              <li><a href="{{ path('front_contact') }}">Contact</a></li>
              <li><a href="{{ path('front_one_page') }}">Présentation</a></li>
            </ul>
          </div>
          <div class="col-md-3 footer-item">
            <h4>Informations</h4>
            <ul class="menu-list">
              <li><a href="#">Tarifs</a></li>
              <li><a href="#">Sécurité</a></li>
              <li><a href="#">FAQ</a></li>
              <li><a href="#">Support</a></li>
              <li><a href="#">Politique de confidentialité</a></li>
            </ul>
          </div>
        </div>
      </div>
    </footer>

    <div class="sub-footer">
      <div class="container">
        <div class="row">
          <div class="col-md-12">
            <p>Copyright &copy; 2026 Finovate.
            
            - Design: <a rel="nofollow noopener" href="https://templatemo.com" target="_blank">TemplateMo</a><br>
            Distribué par: <a rel="nofollow noopener" href="https://themewagon.com" target="_blank">ThemeWagon</a>
          </p>
          </div>
        </div>
      </div>
    </div>

    <script src="vendor/jquery/jquery.min.js"></script>
    <script src="vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

    <script src="assets/js/custom.js"></script>
    <script src="assets/js/owl.js"></script>
    <script src="assets/js/slick.js"></script>
    <script src="assets/js/accordions.js"></script>

  </body>
</html>
