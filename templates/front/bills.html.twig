<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <title>Finovate - Factures</title>

  <link href="{{ asset('front/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
  <link rel="stylesheet" href="{{ asset('front/assets/css/fontawesome.css') }}">
  <link rel="stylesheet" href="{{ asset('front/assets/css/templatemo-finance-business.css') }}">
  <link rel="stylesheet" href="{{ asset('front/assets/css/owl.css') }}">

  <style>
    .page-shell { padding: 36px 0; }

    .sidebar {
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(15, 118, 110, 0.14);
      box-shadow: 0 14px 38px rgba(0, 0, 0, 0.06);
      padding: 16px;
      position: sticky;
      top: 16px;
    }

    .sidebar .title { font-weight: 900; margin: 0 0 10px 0; }

    .sidebar a {
      display: block;
      padding: 10px 12px;
      border-radius: 12px;
      color: #111827;
      font-weight: 700;
      text-decoration: none;
      border: 1px solid transparent;
    }

    .sidebar a:hover {
      background: rgba(16, 185, 129, 0.08);
      border-color: rgba(16, 185, 129, 0.18);
      color: #0f766e;
    }

    .sidebar a.active {
      background: rgba(16, 185, 129, 0.12);
      border-color: rgba(16, 185, 129, 0.26);
      color: #0f766e;
    }

    .card-shell {
      background: rgba(255, 255, 255, 0.92);
      border-radius: 18px;
      border: 1px solid rgba(15, 118, 110, 0.14);
      box-shadow: 0 14px 38px rgba(0, 0, 0, 0.08);
      padding: 22px;
    }

    .small-error { color: #dc3545; font-size: 0.85rem; }

    .table td, .table th { vertical-align: middle; }
  </style>
</head>

<body>
  <div class="sub-header">
    <div class="container">
      <div class="row">
        <div class="col-md-8 col-xs-12">
          <ul class="left-info">
            <li><a href="#"><i class="fa fa-clock-o"></i>Lun-Ven 09:00-17:00</a></li>
            <li><a href="#"><i class="fa fa-phone"></i>+216 00 000 000</a></li>
          </ul>
        </div>
        <div class="col-md-4">
          <ul class="right-icons">
            <li><a href="#"><i class="fa fa-facebook"></i></a></li>
            <li><a href="#"><i class="fa fa-twitter"></i></a></li>
            <li><a href="#"><i class="fa fa-linkedin"></i></a></li>
            <li><a href="#"><i class="fa fa-behance"></i></a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <header>
    <nav class="navbar navbar-expand-lg">
      <div class="container">
        <a class="navbar-brand" href="{{ path('front_home') }}">
          <h2>Finovate</h2>
        </a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarResponsive"
          aria-controls="navbarResponsive" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarResponsive">
          <ul class="navbar-nav ml-auto">
            <li class="nav-item"><a class="nav-link" href="{{ path('front_home') }}">Accueil</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('front_about') }}">À propos</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('front_services') }}">Nos services</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('front_contact') }}">Contact</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('front_one_page') }}">One-page</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('user_dashboard') }}">Mon espace</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('front_logout') }}">Déconnexion</a></li>
          </ul>
        </div>
      </div>
    </nav>
  </header>

  <div class="page-heading header-text">
    <div class="container">
      <div class="row">
        <div class="col-md-12">
          <h1>Factures</h1>
          <span>Payer une facture par référence</span>
        </div>
      </div>
    </div>
  </div>

  <div class="page-shell">
    <div class="container">
      <div class="row">
        <div class="col-lg-3 mb-4">
          <div class="sidebar">
            <div class="title">Mon espace</div>
            <a href="{{ path('user_dashboard') }}">Dashboard</a>
            <a href="{{ path('user_transactions') }}">Transactions</a>
            <a href="{{ path('user_goals') }}">Goals</a>
            <a href="{{ path('user_bills') }}" class="active">Factures</a>
            <a href="{{ path('user_dashboard') ~ '?section=edit' }}">Modifier le profil</a>
            <a href="{{ path('front_logout') }}">Déconnexion</a>
          </div>
        </div>

        <div class="col-lg-9">
          <div class="card-shell mb-4">
            {% for label, messages in app.flashes %}
              {% for message in messages %}
                <div class="alert alert-{{ label }}" role="alert">{{ message }}</div>
              {% endfor %}
            {% endfor %}

            <h4 style="font-weight:900;margin:0">Payer une facture</h4>
            <div class="text-muted" style="font-weight:600">Saisis la référence et le montant</div>

            <div style="height:14px"></div>

            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
              {% set globalErrors = form_errors(form) %}
              {% if globalErrors|trim is not empty %}
                <div class="alert alert-danger" role="alert">{{ globalErrors }}</div>
              {% endif %}

              <div class="form-row">
                <div class="form-group col-md-7">
                  <label for="{{ form.reference.vars.id }}">Référence</label>
                  {{ form_widget(form.reference, {'attr': {'class': 'form-control'}}) }}
                  <div class="small-error">{{ form_errors(form.reference) }}</div>
                </div>
                <div class="form-group col-md-5">
                  <label for="{{ form.amount.vars.id }}">Montant</label>
                  {{ form_widget(form.amount, {'attr': {'class': 'form-control'}}) }}
                  <div class="small-error">{{ form_errors(form.amount) }}</div>
                </div>
              </div>

              <button type="submit" class="btn btn-success">Payer</button>
            {{ form_end(form) }}
          </div>

          <div class="card-shell">
            <h4 style="font-weight:900;margin:0">Historique</h4>
            <div class="text-muted" style="font-weight:600">Tes factures payées</div>

            <div style="height:14px"></div>

            {% if bills is empty %}
              <div class="alert alert-info" role="alert">Aucune facture payée.</div>
            {% else %}
              <div class="table-responsive">
                <table class="table table-bordered">
                  <thead class="thead-light">
                    <tr>
                      <th>Référence</th>
                      <th>Montant</th>
                      <th>Date</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for bill in bills %}
                      <tr>
                        <td>{{ bill.reference }}</td>
                        <td>{{ bill.amount }}</td>
                        <td>{{ bill.date_paiement ? bill.date_paiement|date('Y-m-d') : '' }}</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            {% endif %}
          </div>

        </div>
      </div>
    </div>
  </div>

  <script src="{{ asset('front/vendor/jquery/jquery.min.js') }}"></script>
  <script src="{{ asset('front/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
</body>

</html>
