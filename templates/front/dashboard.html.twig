  <script>
    (function () {
      var loginItem = document.getElementById('nav-login');
      var dashboardItem = document.getElementById('nav-dashboard');
      var logoutItem = document.getElementById('nav-logout');

      function setAuthedUI(isAuthed) {
        if (!loginItem || !dashboardItem || !logoutItem) return;
        loginItem.style.display = isAuthed ? 'none' : '';
        dashboardItem.style.display = isAuthed ? '' : 'none';
        logoutItem.style.display = isAuthed ? '' : 'none';
      }

      var token = null;
      try {
        token = localStorage.getItem('finovate_token');
      } catch (e) {}

      if (!token) {
        setAuthedUI(false);
        window.location.href = '{{ path('front_login') }}';
        return;
      }

      setAuthedUI(true);

      var elLoading = document.getElementById('loading');
      var elError = document.getElementById('error');
      var elProfile = document.getElementById('profile');

      function showError(message) {
        if (elLoading) elLoading.style.display = 'none';
        if (elProfile) elProfile.style.display = 'none';
        if (elError) {
          elError.textContent = message;
          elError.style.display = '';
        }
      }

      function showProfile(data) {
        if (elLoading) elLoading.style.display = 'none';
        if (elError) elError.style.display = 'none';
        if (elProfile) elProfile.style.display = '';

        var welcomeTitleEl = document.getElementById('welcome-title');
        var welcomeSubEl = document.getElementById('welcome-sub');

        var nomEl = document.getElementById('p-nom');
        var prenomEl = document.getElementById('p-prenom');
        var soldeEl = document.getElementById('p-solde');
        var pointsEl = document.getElementById('p-points');
        var numeroCarteEl = document.getElementById('p-numero-carte');
        var cardHolderEl = document.getElementById('card-holder');

        var editNomEl = document.getElementById('edit-nom');
        var editPrenomEl = document.getElementById('edit-prenom');
        var editTelephoneEl = document.getElementById('edit-telephone');
        var editEmailEl = document.getElementById('edit-email');
        var editBirthdateEl = document.getElementById('edit-date-naissance');
        var editCinEl = document.getElementById('edit-cin');

        if (nomEl) nomEl.textContent = data.nom || '';
        if (prenomEl) prenomEl.textContent = data.prenom || '';
        if (soldeEl) soldeEl.textContent = data.solde != null ? String(data.solde) : '';
        if (pointsEl) pointsEl.textContent = data.points != null ? String(data.points) : '';
        if (numeroCarteEl) numeroCarteEl.textContent = data.numero_carte || '';

        var fullName = ((data.prenom || '') + ' ' + (data.nom || '')).trim();
        if (welcomeTitleEl) welcomeTitleEl.textContent = fullName ? ('Bienvenue, ' + fullName) : 'Bienvenue';
        if (welcomeSubEl) welcomeSubEl.textContent = 'Voici un résumé de votre compte.';
        if (cardHolderEl) cardHolderEl.textContent = fullName || '';

        if (editNomEl) editNomEl.value = data.nom || '';
        if (editPrenomEl) editPrenomEl.value = data.prenom || '';
        if (editTelephoneEl) editTelephoneEl.value = data.telephone != null ? String(data.telephone) : '';
        if (editEmailEl) editEmailEl.value = data.email || '';
        if (editBirthdateEl) editBirthdateEl.value = data.date_naissance || '';
        if (editCinEl) editCinEl.value = data.cin || '';

        var navAdminSide = document.getElementById('nav-admin-side');
        if (navAdminSide && data.roles && data.roles.includes('ROLE_ADMIN')) {
          navAdminSide.style.display = 'block';
        }
      }

      function setActiveSide(which) {
        var aDashboard = document.getElementById('nav-dashboard-side');
        var aEdit = document.getElementById('nav-edit-profile');
        var panelDashboard = document.getElementById('panel-dashboard');
        var panelEdit = document.getElementById('panel-edit-profile');

        if (!aDashboard || !aEdit || !panelDashboard || !panelEdit) return;

        if (which === 'edit') {
          aDashboard.classList.remove('active');
          aEdit.classList.add('active');
          panelDashboard.style.display = 'none';
          panelEdit.style.display = '';
        } else {
          aEdit.classList.remove('active');
          aDashboard.classList.add('active');
          panelEdit.style.display = 'none';
          panelDashboard.style.display = '';
        }
      }

      var navDashboardSide = document.getElementById('nav-dashboard-side');
      var navEditProfile = document.getElementById('nav-edit-profile');
      if (navDashboardSide) {
        navDashboardSide.addEventListener('click', function (e) {
          e.preventDefault();
          setActiveSide('dashboard');
        });
      }
      if (navEditProfile) {
        navEditProfile.addEventListener('click', function (e) {
          e.preventDefault();
          setActiveSide('edit');
        });
      }

      try {
        var params = new URLSearchParams(window.location.search || '');
        if (params.get('section') === 'edit') {
          setActiveSide('edit');
        }
      } catch (e) {}

      var editForm = document.getElementById('edit-profile-form');
      if (editForm) {
        editForm.addEventListener('submit', function (e) {
          e.preventDefault();

          var successEl = document.getElementById('edit-success');
          var errorEl = document.getElementById('edit-error');
          if (successEl) successEl.style.display = 'none';
          if (errorEl) errorEl.style.display = 'none';

          var nom = document.getElementById('edit-nom') ? document.getElementById('edit-nom').value : '';
          var prenom = document.getElementById('edit-prenom') ? document.getElementById('edit-prenom').value : '';
          var telephone = document.getElementById('edit-telephone') ? document.getElementById('edit-telephone').value : '';
          var email = document.getElementById('edit-email') ? document.getElementById('edit-email').value : '';
          var dateNaissance = document.getElementById('edit-date-naissance') ? document.getElementById('edit-date-naissance').value : '';
          var cin = document.getElementById('edit-cin') ? document.getElementById('edit-cin').value : '';
          var password = document.getElementById('edit-password') ? document.getElementById('edit-password').value : '';
          var passwordConfirm = document.getElementById('edit-password-confirm') ? document.getElementById('edit-password-confirm').value : '';

          if (password && !passwordConfirm) {
            if (errorEl) {
              errorEl.textContent = 'Confirmation du mot de passe obligatoire.';
              errorEl.style.display = '';
            }
            return;
          }

          if ((password || passwordConfirm) && password !== passwordConfirm) {
            if (errorEl) {
              errorEl.textContent = 'Les mots de passe ne correspondent pas.';
              errorEl.style.display = '';
            }
            return;
          }

          fetch('/api/me', {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': 'Bearer ' + token
            },
            body: JSON.stringify({ nom: nom, prenom: prenom, email: email, date_naissance: dateNaissance, cin: cin, telephone: telephone, password: password, password_confirm: passwordConfirm })
          })
            .then(function (res) {
              return res.json().then(function (data) {
                return { ok: res.ok, data: data };
              }).catch(function () {
                return { ok: res.ok, data: {} };
              });
            })
            .then(function (result) {
              if (!result.ok) {
                if (errorEl) {
                  errorEl.textContent = (result.data && result.data.message) ? result.data.message : 'Mise à jour impossible.';
                  errorEl.style.display = '';
                }
                return;
              }

              if (successEl) {
                successEl.textContent = (result.data && result.data.message) ? result.data.message : 'Profil mis à jour.';
                successEl.style.display = '';
              }

              fetch('/api/me', {
                method: 'GET',
                headers: {
                  'Authorization': 'Bearer ' + token
                }
              })
                .then(function (r) { return r.json(); })
                .then(function (d) { showProfile(d || {}); });
            })
            .catch(function () {
              if (errorEl) {
                errorEl.textContent = 'Erreur réseau.';
                errorEl.style.display = '';
              }
            });
        });
      }

      fetch('/api/me', {
        method: 'GET',
        headers: {
          'Authorization': 'Bearer ' + token
        }
      })
        .then(function (res) {
          return res.json().then(function (data) {
            return { ok: res.ok, status: res.status, data: data };
          }).catch(function () {
            return { ok: res.ok, status: res.status, data: {} };
          });
        })
        .then(function (result) {
          if (!result.ok) {
            try {
              localStorage.removeItem('finovate_token');
            } catch (e) {}
            showError(result.data && result.data.message ? result.data.message : 'Session expirée. Veuillez vous reconnecter.');
            setTimeout(function () {
              window.location.href = '{{ path('front_login') }}';
            }, 900);
            return;
          }

          showProfile(result.data || {});
        })
        .catch(function () {
          showError('Erreur réseau.');
        });
    })();
  </script>
</body>

