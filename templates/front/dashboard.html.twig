  <style>
    .welcome-title {
      font-weight: 900;
      font-size: 1.65rem;
      letter-spacing: 0.2px;
      margin: 0;
      color: #0f766e;
    }

    .welcome-sub {
      margin: 6px 0 0 0;
      color: rgba(0, 0, 0, 0.55);
      font-weight: 600;
    }

    .dashboard-card {
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(8px);
      border-radius: 18px;
      border: 1px solid rgba(15, 118, 110, 0.14);
      box-shadow: 0 14px 38px rgba(0, 0, 0, 0.08);
      padding: 26px;
    }

    .dashboard-title {
      font-weight: 800;
      margin-bottom: 18px;
      letter-spacing: 0.2px;
    }

    .label {
      color: #6c757d;
      font-size: 0.9rem;
      margin-bottom: 4px;
    }

    .value {
      font-weight: 600;
      word-break: break-word;
    }

    .metric {
      border-radius: 14px;
      padding: 14px 14px;
      border: 1px solid rgba(15, 118, 110, 0.12);
      background: linear-gradient(180deg, rgba(236, 253, 245, 1) 0%, rgba(255, 255, 255, 1) 100%);
      height: 100%;
    }

    .metric .k {
      color: #0f766e;
      font-weight: 800;
      font-size: 1.35rem;
      margin: 0;
      line-height: 1.1;
    }

    .metric .t {
      color: #6c757d;
      margin: 2px 0 0 0;
      font-weight: 600;
      font-size: 0.85rem;
    }

    .sidebar {
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(15, 118, 110, 0.14);
      box-shadow: 0 6px 24px rgba(0, 0, 0, 0.06);
      padding: 10px 16px;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 6px;
      margin-bottom: 24px;
    }

    .sidebar .title {
      font-weight: 900;
      margin: 0 10px 0 0;
      letter-spacing: 0.2px;
      white-space: nowrap;
      color: #0f766e;
    }

    .sidebar a {
      display: inline-block;
      padding: 8px 16px;
      border-radius: 10px;
      color: #111827;
      font-weight: 700;
      text-decoration: none;
      border: 1px solid transparent;
      white-space: nowrap;
    }

    .sidebar a:hover {
      background: rgba(16, 185, 129, 0.08);
      border-color: rgba(16, 185, 129, 0.18);
      color: #0f766e;
    }

    .sidebar a.active {
      background: rgba(16, 185, 129, 0.12);
      border-color: rgba(16, 185, 129, 0.26);
      color: #0f766e;
    }

    .content-panel {
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.0);
    }

    .bank-card {
      position: relative;
      border-radius: 18px;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.25);
      background: linear-gradient(135deg, #0b1220 0%, #0f766e 45%, #10b981 100%);
      box-shadow: 0 18px 45px rgba(16, 185, 129, 0.18);
      padding: 18px;
      color: rgba(255, 255, 255, 0.92);
      min-height: 150px;
    }

    .bank-card::before {
      content: '';
      position: absolute;
      top: -90px;
      right: -110px;
      width: 260px;
      height: 260px;
      background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.38), rgba(255, 255, 255, 0));
      transform: rotate(15deg);
    }

    .bank-card::after {
      content: '';
      position: absolute;
      bottom: -120px;
      left: -140px;
      width: 340px;
      height: 340px;
      background: radial-gradient(circle at 70% 70%, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0));
      transform: rotate(-10deg);
    }

    .bank-card .brand {
      position: relative;
      z-index: 1;
      font-weight: 800;
      letter-spacing: 0.6px;
      opacity: 0.95;
      font-size: 0.9rem;
    }

    .bank-card .chip {
      position: relative;
      z-index: 1;
      width: 52px;
      height: 40px;
      border-radius: 10px;
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.65) 0%, rgba(255, 255, 255, 0.15) 100%);
      border: 1px solid rgba(255, 255, 255, 0.35);
      margin-top: 10px;
    }

    .bank-card .number {
      position: relative;
      z-index: 1;
      margin-top: 16px;
      font-weight: 900;
      font-size: 1.1rem;
      letter-spacing: 2px;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    }

    .bank-card .holder {
      position: relative;
      z-index: 1;
      margin-top: 12px;
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
    }

    .bank-card .holder .label {
      color: rgba(255, 255, 255, 0.75);
      margin: 0;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.5px;
    }

    .bank-card .holder .value {
      margin: 0;
      font-weight: 800;
      color: rgba(255, 255, 255, 0.95);
    }

    .skeleton {
      background: linear-gradient(90deg, #f2f2f2 25%, #e6e6e6 37%, #f2f2f2 63%);
      background-size: 400% 100%;
      animation: shimmer 1.4s ease infinite;
      border-radius: 4px;
      height: 14px;
      margin: 8px 0;
    }

    @keyframes shimmer {
      0% {
        background-position: 100% 0
      }

      100% {
        background-position: -100% 0
      }
    }
  </style>
</head>

