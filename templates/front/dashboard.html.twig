  <script>
    (function () {
      var loginItem = document.getElementById('nav-login');
      var dashboardItem = document.getElementById('nav-dashboard');
      var logoutItem = document.getElementById('nav-logout');

      var defaultAvatarUrl = '{{ asset('backoffice/assets/images/avatar-user.jpg') }}';

      function setAuthedUI(isAuthed) {
        if (!loginItem || !dashboardItem || !logoutItem) return;
        loginItem.style.display = isAuthed ? 'none' : '';
        dashboardItem.style.display = isAuthed ? '' : 'none';
        logoutItem.style.display = isAuthed ? '' : 'none';
      }

      var token = null;
      try {
        token = localStorage.getItem('finovate_token') || sessionStorage.getItem('finovate_token');
      } catch (e) {}

      if (!token) {
        setAuthedUI(false);
        window.location.href = '{{ path('front_login') }}';
        return;
      }

      setAuthedUI(true);

      var elLoading = document.getElementById('loading');
      var elError = document.getElementById('error');
      var elProfile = document.getElementById('profile');

      function showError(message) {
        if (elLoading) elLoading.style.display = 'none';
        if (elProfile) elProfile.style.display = 'none';
        if (elError) {
          elError.textContent = message;
          elError.style.display = '';
        }
      }

      function confirmDisableFace() {
        return new Promise(function (resolve) {
          var modalEl = document.getElementById('confirmDisableFaceModal');
          if (!modalEl || typeof $ !== 'function') return resolve(false);

          var confirmBtn = document.getElementById('confirm-disable-face');
          var cancelBtn = document.getElementById('cancel-disable-face');
          var resolved = false;

          function done(val) {
            if (resolved) return;
            resolved = true;
            try { $(modalEl).modal('hide'); } catch (e) {}
            resolve(val);
          }

          function onConfirm(e) {
            if (e) e.preventDefault();
            done(true);
          }

          function onCancel(e) {
            if (e) e.preventDefault();
            done(false);
          }

          function onHidden() {
            done(false);
          }

          if (confirmBtn) confirmBtn.addEventListener('click', onConfirm, { once: true });
          if (cancelBtn) cancelBtn.addEventListener('click', onCancel, { once: true });
          $(modalEl).one('hidden.bs.modal', onHidden);
          $(modalEl).modal('show');
        });
      }

      function showProfile(data) {
        if (elLoading) elLoading.style.display = 'none';
        if (elError) elError.style.display = 'none';
        if (elProfile) elProfile.style.display = '';

        var welcomeTitleEl = document.getElementById('welcome-title');
        var welcomeSubEl = document.getElementById('welcome-sub');

        var nomEl = document.getElementById('p-nom');
        var prenomEl = document.getElementById('p-prenom');
        var soldeEl = document.getElementById('p-solde');
        var pointsEl = document.getElementById('p-points');
        var numeroCarteEl = document.getElementById('p-numero-carte');
        var cardHolderEl = document.getElementById('card-holder');

