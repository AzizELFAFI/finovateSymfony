          passwordConfirm = (passwordConfirm || '').trim();

          var onlyDigitsTelephone = (telephone || '').replace(/\D+/g, '');
          if (telephone && !/^\d{8}$/.test(onlyDigitsTelephone)) {
            if (errorEl) {
              errorEl.textContent = 'Le numéro de téléphone doit contenir exactement 8 chiffres.';
              errorEl.style.display = '';
            }
            return;
          }

          if (cin && !/^\d{8}$/.test(cin)) {
            if (errorEl) {
              errorEl.textContent = 'Le CIN doit contenir exactement 8 chiffres.';
              errorEl.style.display = '';
            }
            return;
          }

          if (password && !passwordConfirm) {
            if (errorEl) {
              errorEl.textContent = 'Confirmation du mot de passe obligatoire.';
              errorEl.style.display = '';
            }
            return;
          }

          if ((password || passwordConfirm) && password !== passwordConfirm) {
            if (errorEl) {
              errorEl.textContent = 'Les mots de passe ne correspondent pas.';
              errorEl.style.display = '';
            }
            return;
          }

          fetch('/api/me', {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': 'Bearer ' + token
            },
            body: JSON.stringify({ nom: nom, prenom: prenom, email: email, date_naissance: dateNaissance, cin: cin, telephone: onlyDigitsTelephone || telephone, password: password, password_confirm: passwordConfirm })
          })
            .then(function (res) {
              return res.json().then(function (data) {
                return { ok: res.ok, data: data };
              }).catch(function () {
                return { ok: res.ok, data: {} };
              });
            })
            .then(function (result) {
              if (!result.ok) {
                if (errorEl) {
                  if (result.data && result.data.errors) {
                    var msgs = [];
                    Object.keys(result.data.errors).forEach(function (field) {
                      (result.data.errors[field] || []).forEach(function (msg) {
                        msgs.push(msg);
                      });
                    });
                    if (msgs.length > 0) {
                      errorEl.innerHTML = msgs.join('<br>');
                      errorEl.style.display = '';
                      return;
                    }
                  }

                  errorEl.textContent = (result.data && result.data.message) ? result.data.message : 'Mise à jour impossible.';
                  errorEl.style.display = '';
                }
                return;
              }

              if (successEl) {
                successEl.textContent = (result.data && result.data.message) ? result.data.message : 'Profil mis à jour.';
                successEl.style.display = '';
              }

              fetch('/api/me', {
                method: 'GET',
                headers: {
                  'Authorization': 'Bearer ' + token
                }
              })
                .then(function (r) { return r.json(); })
                .then(function (d) { showProfile(d || {}); });
            })
            .catch(function () {
              if (errorEl) {
                errorEl.textContent = 'Erreur réseau.';
                errorEl.style.display = '';
              }
            });
        });
      }

      fetch('/api/me', {
        method: 'GET',
        headers: {
          'Authorization': 'Bearer ' + token
        }
      })
        .then(function (res) {
          return res.json().then(function (data) {
            return { ok: res.ok, status: res.status, data: data };
          }).catch(function () {
            return { ok: res.ok, status: res.status, data: {} };
          });
        })
        .then(function (result) {
          if (!result.ok) {
            try {
              localStorage.removeItem('finovate_token');
            } catch (e) {}
            showError(result.data && result.data.message ? result.data.message : 'Session expirée. Veuillez vous reconnecter.');
            setTimeout(function () {
              window.location.href = '{{ path('front_login') }}';
            }, 900);
            return;
          }

          showProfile(result.data || {});
        })
        .catch(function () {
          showError('Erreur réseau.');
        });

      // AI Advice Button Handler
      var aiAdviceBtn = document.getElementById('ai-advice-btn');
      var aiAdviceModal = document.getElementById('aiAdviceModal');
      var aiAdviceLoading = document.getElementById('ai-advice-loading');
      var aiAdviceContent = document.getElementById('ai-advice-content');
      var aiAdviceError = document.getElementById('ai-advice-error');
      var aiAdviceText = document.getElementById('ai-advice-text');
      var regenerateBtn = document.getElementById('regenerate-advice-btn');

      function fetchAIAdvice() {
        if (!aiAdviceLoading || !aiAdviceContent || !aiAdviceError || !aiAdviceText) return;

        aiAdviceLoading.style.display = '';
        aiAdviceContent.style.display = 'none';
        aiAdviceError.style.display = 'none';
        if (aiAdviceBtn) aiAdviceBtn.classList.add('loading');

        fetch('/api/ai/financial-advice', {
          method: 'POST',
          headers: {
            'Authorization': 'Bearer ' + token,
            'Content-Type': 'application/json'
          }
        })
          .then(function (res) {
            return res.json().then(function (data) {
              return { ok: res.ok, data: data };
            });
          })
          .then(function (result) {
            if (aiAdviceBtn) aiAdviceBtn.classList.remove('loading');
            aiAdviceLoading.style.display = 'none';

            if (result.ok && result.data && result.data.advice) {
              aiAdviceText.textContent = result.data.advice;
              aiAdviceContent.style.display = '';
            } else {
              aiAdviceError.style.display = '';
            }
          })
          .catch(function () {
            if (aiAdviceBtn) aiAdviceBtn.classList.remove('loading');
            aiAdviceLoading.style.display = 'none';
            aiAdviceError.style.display = '';
          });
      }

      if (aiAdviceBtn) {
        aiAdviceBtn.addEventListener('click', function () {
          if (typeof $ === 'function' && aiAdviceModal) {
            $(aiAdviceModal).modal('show');
            fetchAIAdvice();
          }
        });
      }

      if (regenerateBtn) {
        regenerateBtn.addEventListener('click', function (e) {
          e.preventDefault();
          fetchAIAdvice();
        });
      }
    })();
  </script>
</body>

</html>