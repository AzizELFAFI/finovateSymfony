        enrollFaceBtn.addEventListener('click', async function () {
          var successEl = document.getElementById('edit-success');
          var errorEl = document.getElementById('edit-error');
          var scanEl = document.getElementById('face-enroll-scan');
          var scanTextEl = document.getElementById('face-enroll-scan-text');
          if (successEl) successEl.style.display = 'none';
          if (errorEl) errorEl.style.display = 'none';

          var isEnabled = enrollFaceBtn.dataset.faceEnabled === '1';
          if (isEnabled) {
            var ok = await confirmDisableFace();
            if (!ok) return;

            enrollFaceBtn.disabled = true;
            if (scanTextEl) scanTextEl.textContent = 'Désactivation en cours...';
            if (scanEl) scanEl.style.display = '';

            var disableConfirmBtn = document.getElementById('confirm-disable-face');
            var disableConfirmText = document.getElementById('confirm-disable-face-text');
            var disableConfirmSpinner = document.getElementById('confirm-disable-face-spinner');
            if (disableConfirmBtn) disableConfirmBtn.disabled = true;
            if (disableConfirmText) disableConfirmText.textContent = 'Désactivation...';
            if (disableConfirmSpinner) disableConfirmSpinner.style.display = '';

            try {
              var resDisable = await fetch('/api/face/disable', {
                method: 'POST',
                headers: {
                  'Authorization': 'Bearer ' + token
                }
              });

              var dataDisable = await resDisable.json().catch(function () { return {}; });
              if (!resDisable.ok) {
                if (errorEl) {
                  errorEl.textContent = dataDisable.message || 'Désactivation impossible.';
                  errorEl.style.display = '';
                }
                return;
              }

              if (successEl) {
                successEl.textContent = dataDisable.message || 'Face ID désactivé.';
                successEl.style.display = '';
              }

              fetch('/api/me', {
                method: 'GET',
                headers: {
                  'Authorization': 'Bearer ' + token
                }
              })
                .then(function (r) { return r.json(); })
                .then(function (d) { showProfile(d || {}); });
            } catch (e) {
              if (errorEl) {
                errorEl.textContent = 'Erreur réseau.';
                errorEl.style.display = '';
              }
            } finally {
              if (disableConfirmBtn) disableConfirmBtn.disabled = false;
              if (disableConfirmText) disableConfirmText.textContent = 'Désactiver';
              if (disableConfirmSpinner) disableConfirmSpinner.style.display = 'none';
              enrollFaceBtn.disabled = false;
              if (scanEl) scanEl.style.display = 'none';
            }
            return;
          }

          if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
            if (errorEl) {
              errorEl.textContent = 'Caméra non supportée par ce navigateur.';
              errorEl.style.display = '';

            }
            return;
          }

          enrollFaceBtn.disabled = true;
          if (scanTextEl) scanTextEl.textContent = 'Ouverture de la caméra...';
          if (scanEl) scanEl.style.display = '';

          var stream = null;
          try {
            stream = await navigator.mediaDevices.getUserMedia({
              video: {
                facingMode: 'user',
                width: { ideal: 1280 },
                height: { ideal: 720 },
                frameRate: { ideal: 30 }
              },
              audio: false
            });
          } catch (e) {
            enrollFaceBtn.disabled = false;
            if (scanEl) scanEl.style.display = 'none';
            if (errorEl) {
              errorEl.textContent = 'Accès caméra refusé.';
              errorEl.style.display = '';

            }
            return;
          }

          try {
            var video = document.createElement('video');
            video.autoplay = true;
            video.playsInline = true;
            video.muted = true;
            video.srcObject = stream;

            video.style.position = 'fixed';
            video.style.left = '-9999px';
            video.style.top = '-9999px';
            video.style.width = '1px';
            video.style.height = '1px';
            document.body.appendChild(video);

            await new Promise(function (resolve) {
              if (video.readyState >= 2) return resolve();
              video.onloadedmetadata = function () { resolve(); };
            });

            try { await video.play(); } catch (e) {}

            await new Promise(function (resolve) {
              var tries = 0;
              (function tick() {
                tries++;
                if ((video.videoWidth || 0) > 0 && (video.videoHeight || 0) > 0) return resolve();
                if (tries > 60) return resolve();
                requestAnimationFrame(tick);
              })();
            });

            await new Promise(function (resolve) {
              if (typeof video.requestVideoFrameCallback === 'function') {
                video.requestVideoFrameCallback(function () { resolve(); });
                return;
              }
              setTimeout(resolve, 250);
            });

            await new Promise(function (resolve) { setTimeout(resolve, 600); });

            if (scanTextEl) scanTextEl.textContent = 'Capture du visage...';

            async function isBlackBlob(b) {
              try {
                var img = await createImageBitmap(b);
                var c = document.createElement('canvas');
                c.width = Math.max(1, img.width);
                c.height = Math.max(1, img.height);
                var x = c.getContext('2d');
                x.drawImage(img, 0, 0);
                var data = x.getImageData(0, 0, c.width, c.height).data;
                var step = Math.max(4, Math.floor((data.length / 4) / 2000)) * 4;
                var sum = 0;
                var count = 0;
                for (var i = 0; i < data.length; i += step) {
                  sum += data[i] + data[i + 1] + data[i + 2];
                  count++;
                }
                var avg = count ? (sum / (count * 3)) : 0;
                return avg < 8;
              } catch (e) {
                return false;
              }
            }

            async function captureBlob() {
              var b = null;
              try {
                if (window.ImageCapture && stream.getVideoTracks && stream.getVideoTracks().length) {
                  var track = stream.getVideoTracks()[0];
                  var imageCapture = new ImageCapture(track);
                  b = await imageCapture.takePhoto();
                }
              } catch (e) {
                b = null;
              }

              if (!b) {
                var canvas = document.createElement('canvas');
                canvas.width = video.videoWidth || 640;
                canvas.height = video.videoHeight || 480;
                var ctx = canvas.getContext('2d');
                ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

                b = await new Promise(function (resolve) {
                  canvas.toBlob(function (bb) { resolve(bb); }, 'image/jpeg', 0.9);
                });
              }

              return b;
            }

            var blob = null;
            for (var attempt = 0; attempt < 3; attempt++) {
              blob = await captureBlob();
              if (!blob) break;
              var black = await isBlackBlob(blob);
              if (!black) break;
              await new Promise(function (resolve) { setTimeout(resolve, 250); });
            }

            if (!blob) {
              if (errorEl) {
                errorEl.textContent = 'Capture caméra impossible.';
                errorEl.style.display = '';

              }
              return;
            }

            if (scanTextEl) scanTextEl.textContent = 'Enrôlement en cours...';

            var formData = new FormData();
            formData.append('image', blob, 'face.jpg');

            var res = await fetch('/api/face/enroll', {
              method: 'POST',
              headers: {
                'Authorization': 'Bearer ' + token
              },
              body: formData
            });

            var data = await res.json().catch(function () { return {}; });
            if (!res.ok) {
              if (errorEl) {
                errorEl.textContent = data.message || 'Enrôlement visage impossible.';
                errorEl.style.display = '';

              }
              return;
            }

            if (successEl) {
              successEl.textContent = data.message || 'Visage enregistré.';
              successEl.style.display = '';
            }

            fetch('/api/me', {
              method: 'GET',
              headers: {
                'Authorization': 'Bearer ' + token
              }
            })
              .then(function (r) { return r.json(); })
              .then(function (d) { showProfile(d || {}); });
          } catch (e) {
            if (errorEl) {
              errorEl.textContent = 'Erreur réseau.';
              errorEl.style.display = '';
            }
          } finally {
            try {
              try {
                if (video && video.parentNode) {
                  video.pause();
                  video.srcObject = null;
                  video.parentNode.removeChild(video);
                }
              } catch (e) {}
              if (stream) {
                stream.getTracks().forEach(function (t) { t.stop(); });
              }
            } catch (e) {}
            if (scanEl) scanEl.style.display = 'none';
            enrollFaceBtn.disabled = false;
          }
        });
      }

