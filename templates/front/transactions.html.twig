<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <title>Finovate - Transactions</title>

  <link href="{{ asset('front/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
  <link rel="stylesheet" href="{{ asset('front/assets/css/fontawesome.css') }}">
  <link rel="stylesheet" href="{{ asset('front/assets/css/templatemo-finance-business.css') }}">
  <link rel="stylesheet" href="{{ asset('front/assets/css/owl.css') }}">

  <style>
    .page-shell {
      padding: 36px 0;
    }

    .card-shell {
      background: rgba(255, 255, 255, 0.92);
      border-radius: 18px;
      border: 1px solid rgba(15, 118, 110, 0.14);
      box-shadow: 0 14px 38px rgba(0, 0, 0, 0.08);
      padding: 26px;
    }

    .sidebar {
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(15, 118, 110, 0.14);
      box-shadow: 0 14px 38px rgba(0, 0, 0, 0.06);
      padding: 16px;
      position: sticky;
      top: 16px;
    }

    .sidebar .title {
      font-weight: 900;
      margin: 0 0 10px 0;
    }

    .sidebar a {
      display: block;
      padding: 10px 12px;
      border-radius: 12px;
      color: #111827;
      font-weight: 700;
      text-decoration: none;
      border: 1px solid transparent;
    }

    .sidebar a:hover {
      background: rgba(16, 185, 129, 0.08);
      border-color: rgba(16, 185, 129, 0.18);
      color: #0f766e;
    }

    .sidebar a.active {
      background: rgba(16, 185, 129, 0.12);
      border-color: rgba(16, 185, 129, 0.26);
      color: #0f766e;
    }

    .forum-folder { display: flex; justify-content: space-between; align-items: center; cursor: pointer; }
    .f-arrow { font-size: 10px; transition: transform 0.2s; }
    .f-arrow.open { transform: rotate(90deg); }
    .forum-sub { display: none; padding-left: 10px; }
    .forum-sub.show { display: block; }
    .forum-sub a { display: block; padding: 7px 12px; font-size: 13px; border-left: 2px solid rgba(15,118,110,0.15); border-radius: 8px; margin-bottom: 1px; color: #111827; font-weight: 700; text-decoration: none; }
    .forum-sub a:hover { border-left-color: #0f766e; background: rgba(16,185,129,0.08); color: #0f766e; }

    .form-error-list {
      margin: 0;
      padding-left: 18px;
    }
  </style>
</head>

<body>
  

  <header>
    <nav class="navbar navbar-expand-lg">
      <div class="container">
        <a class="navbar-brand" href="{{ path('front_home') }}">
          <h2>Finovate</h2>
        </a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarResponsive">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarResponsive">
          <ul class="navbar-nav ml-auto">
            <li class="nav-item"><a class="nav-link" href="{{ path('front_home') }}">Accueil</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('front_about') }}">À propos</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ app.user ? path('front_products') : path('front_products_public') }}">Produits</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('app_forum_home') }}">Forums</a></li>
            
            {% if app.user %}
              <li class="nav-item active"><a class="nav-link" href="{{ path('user_dashboard') }}">Mon espace</a></li>
              <li class="nav-item"><a class="nav-link" href="{{ path('front_logout') }}">Déconnexion</a></li>
              <li class="nav-item" style="margin-left: 8px;">
                <a class="nav-link" href="{{ path('app_forum_alerts') }}" style="position:relative;display:inline-flex;align-items:center" title="Alertes et notifications">
                  🔔
                  <span id="notif-badge" style="display:none;position:absolute;top:-8px;right:-8px;background:#ef4444;color:white;border-radius:50%;width:20px;height:20px;font-size:10px;font-weight:bold;display:flex;align-items:center;justify-content:center"></span>
                </a>
              </li>
              <li class="nav-item" style="margin-left: 8px;">
                <a class="nav-link" href="{{ path('forum_policy') }}" style="display:inline-flex;align-items:center" title="Règles de la communauté">
                  📜
                </a>
              </li>
              <li class="nav-item" style="margin-left: 8px;">
                <a class="nav-link" href="{{ path('app_forum_blocked_users') }}" style="display:inline-flex;align-items:center" title="Utilisateurs bloqués">
                  🚫
                </a>
              </li>
            {% else %}
              <li class="nav-item"><a class="nav-link" href="{{ path('front_login') }}">Connexion</a></li>
            {% endif %}
          </ul>
        </div>
      </div>
    </nav>
  </header>

  <div class="page-heading header-text">
    <div class="container">
      <div class="row">
        <div class="col-md-12">
          <h1>Transactions</h1>
          <span>Envoyer du solde vers un autre compte</span>
        </div>
      </div>
    </div>
  </div>

  <div class="page-shell">
    <div class="container">
      <div class="row">
        <div class="col-lg-3 mb-4">
          <div class="sidebar">
            <div class="title">Mon espace</div>
            <a href="{{ path('user_dashboard') }}">Dashboard</a>
            <a href="{{ path('user_transactions') }}" class="active">Transactions</a>
            <a href="{{ path('user_goals') }}">Goals</a>
            <a href="{{ path('user_bills') }}">Factures</a>
            <a href="{{ path('investissement_index') }}">Investissement</a>
            <a href="{{ path('front_products') }}">Produits</a>
            <a href="{{ path('front_ads') }}">Annonces</a>
            <a href="{{ path('user_buy_points') }}">Acheter des points</a>
            <a href="{{ path('user_topup') }}">Alimenter carte</a>
            <a href="{{ path('user_dashboard') ~ '?section=edit' }}">Modifier le profil</a>
            <a href="{{ path('front_logout') }}">Déconnexion</a>
          </div>
        </div>

        <div class="col-lg-9">
          <div class="card-shell">
            {% for label, messages in app.flashes %}
              {% for message in messages %}
                <div class="alert alert-{{ label }}" role="alert">{{ message | raw }}</div>
              {% endfor %}
            {% endfor %}

            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

              {% set globalErrors = form_errors(form) %}
              {% if globalErrors|trim is not empty %}
                <div class="alert alert-danger" role="alert">{{ globalErrors }}</div>
              {% endif %}

              <div class="form-group">
                <label for="{{ form.cin.vars.id }}">CIN du bénéficiaire</label>
                {{ form_widget(form.cin, {'attr': {'class': 'form-control', 'autocomplete': 'off'}}) }}
                <div class="text-danger small">{{ form_errors(form.cin) }}</div>
              </div>

              <div class="form-group">
                <label for="{{ form.numeroCarte.vars.id }}">Numéro de carte</label>
                {{ form_widget(form.numeroCarte, {'attr': {'class': 'form-control', 'readonly': 'readonly'}}) }}
                <small class="text-muted">Se remplit automatiquement à partir du CIN.</small>
              </div>

              <div class="form-group">
                <label for="{{ form.montant.vars.id }}">Montant</label>
                {{ form_widget(form.montant, {'attr': {'class': 'form-control'}}) }}
                <div class="text-danger small">{{ form_errors(form.montant) }}</div>
              </div>

              <div class="form-group">
                <label for="{{ form.description.vars.id }}">Description</label>
                {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                <div class="text-danger small">{{ form_errors(form.description) }}</div>
              </div>

              <button type="submit" class="btn btn-success">Envoyer</button>

            {{ form_end(form) }}
          </div>

          <!-- QR Code Section -->
          <div class="card-shell mt-4">
            <h4 style="font-weight: 800; color: #0f766e; margin-bottom: 20px;">
              <span style="display:inline-flex; width: 32px; height: 32px; border-radius: 10px; align-items:center; justify-content:center; background: rgba(15, 118, 110, 0.12); margin-right: 10px;">
                <svg viewBox="0 0 24 24" fill="none" style="width: 18px; height: 18px;">
                  <path d="M3 3h6v6H3V3zm2 2v2h2V5H5zm8-2h6v6h-6V3zm2 2v2h2V5h-2zM3 15h6v6H3v-6zm2 2v2h2v-2H5zm13-2h1v1h-1v-1zm-3 0h1v1h-1v-1zm-1 1h1v1h-1v-1zm2 0h1v1h-1v-1zm1 1h1v1h-1v-1zm-2 0h1v1h-1v-1zm2 2h1v1h-1v-1zm0-2h1v1h-1v-1zm-2 0h1v1h-1v-1zm0 2h1v1h-1v-1zm4 0h1v1h-1v-1z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              QR Code Historique Transactions
            </h4>
            
            <div class="row align-items-end">
              <div class="col-md-4">
                <label for="qr-period" class="form-label" style="font-weight: 700;">Période</label>
                <select id="qr-period" class="form-select" style="border-radius: 12px; padding: 12px; font-weight: 600;">
                  <option value="day">Aujourd'hui</option>
                  <option value="month" selected>Ce mois</option>
                  <option value="3months">3 derniers mois</option>
                  <option value="year">Cette année</option>
                </select>
              </div>
              <div class="col-md-4">
                <button type="button" id="generate-qr-btn" class="btn btn-primary w-100" style="border-radius: 12px; padding: 12px; font-weight: 700;">
                  <span id="qr-btn-text">Générer QR Code</span>
                  <span id="qr-btn-spinner" class="spinner-border spinner-border-sm" style="display: none;"></span>
                </button>
              </div>
            </div>

            <div id="qr-result" style="display: none; margin-top: 24px; text-align: center;">
              <div style="background: #f8fafc; border-radius: 16px; padding: 24px; display: inline-block; border: 1px solid rgba(15, 118, 110, 0.2);">
                <img id="qr-image" src="" alt="QR Code" style="max-width: 300px; border-radius: 12px;">
                <p id="qr-info" style="margin-top: 12px; color: #64748b; font-weight: 600; font-size: 14px;"></p>
              </div>
              <p class="text-muted mt-3" style="font-size: 13px;">Scannez ce QR code pour voir l'historique de vos transactions.</p>
            </div>

            <div id="qr-error" class="alert alert-warning mt-3" style="display: none; border-radius: 12px;"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="{{ asset('front/vendor/jquery/jquery.min.js') }}"></script>
  <script src="{{ asset('front/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
  <script>function toggleForums(e){e.preventDefault();var b=e.currentTarget;var s=b.nextElementSibling;var a=b.querySelector('.f-arrow');s.classList.toggle('show');a.classList.toggle('open');b.classList.toggle('active');}</script>
  <script>
    (function () {
      var cinInput = document.getElementById('{{ form.cin.vars.id }}');
      var cardInput = document.getElementById('{{ form.numeroCarte.vars.id }}');
      if (!cinInput || !cardInput) return;

      var timer = null;
      function fetchCard() {
        var cin = (cinInput.value || '').trim();
        if (!/^\d{8}$/.test(cin)) {
          cardInput.value = '';
          return;
        }

        fetch('{{ path('user_beneficiary_card') }}?cin=' + encodeURIComponent(cin), {
          method: 'GET',
          headers: {
            'Accept': 'application/json'
          }
        })
          .then(function (res) {
            return res.json().then(function (data) {
              return { ok: res.ok, data: data };
            }).catch(function () {
              return { ok: res.ok, data: {} };
            });
          })
          .then(function (result) {
            if (!result.ok) {
              cardInput.value = '';
              return;
            }
            cardInput.value = result.data && result.data.numero_carte ? String(result.data.numero_carte) : '';
          })
          .catch(function () {
            cardInput.value = '';
          });
      }

      cinInput.addEventListener('input', function () {
        if (timer) clearTimeout(timer);
        timer = setTimeout(fetchCard, 250);
      });
    })();

    // QR Code generation
    (function() {
      var token = null;
      try {
        token = localStorage.getItem('finovate_token') || sessionStorage.getItem('finovate_token');
      } catch (e) { console.error('Erreur récupération token:', e); }

      var generateBtn = document.getElementById('generate-qr-btn');
      var periodSelect = document.getElementById('qr-period');
      var qrResult = document.getElementById('qr-result');
      var qrImage = document.getElementById('qr-image');
      var qrInfo = document.getElementById('qr-info');
      var qrError = document.getElementById('qr-error');
      var btnText = document.getElementById('qr-btn-text');
      var btnSpinner = document.getElementById('qr-btn-spinner');

      console.log('QR Code init - Button:', generateBtn, 'Token exists:', !!token);

      if (!generateBtn) {
        console.error('Bouton generate-qr-btn non trouvé');
        return;
      }

      generateBtn.addEventListener('click', function() {
        console.log('Bouton cliqué');
        
        if (!token) {
          qrError.textContent = 'Vous devez être connecté pour générer un QR code.';
          qrError.style.display = '';
          console.error('Pas de token');
          return;
        }

        var period = periodSelect.value;
        console.log('Période sélectionnée:', period);
        
        qrError.style.display = 'none';
        btnText.style.display = 'none';
        btnSpinner.style.display = '';
        generateBtn.disabled = true;

        fetch('/api/transactions/qr-code', {
          method: 'POST',
          headers: {
            'Authorization': 'Bearer ' + token,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ period: period })
        })
          .then(function(res) {
            console.log('Response status:', res.status);
            
            if (!res.ok) {
              return res.text().then(function(text) {
                console.error('Erreur réponse:', text);
                try {
                  var data = JSON.parse(text);
                  throw new Error(data.message || 'Erreur lors de la génération du QR code.');
                } catch (parseErr) {
                  throw new Error('Erreur serveur: ' + res.status);
                }
              });
            }
            return res.text().then(function(base64) {
              console.log('Base64 reçu, longueur:', base64.length);
              return {
                base64: base64,
                period: res.headers.get('X-Period'),
                count: res.headers.get('X-Transaction-Count')
              };
            });
          })
          .then(function(result) {
            console.log('QR code généré avec succès');
            qrImage.src = 'data:image/png;base64,' + result.base64;
            var periodLabels = {
              'day': "Aujourd'hui",
              'month': 'Ce mois',
              '3months': '3 derniers mois',
              'year': 'Cette année'
            };
            qrInfo.textContent = periodLabels[result.period] + ' - ' + result.count + ' transaction(s)';
            qrResult.style.display = '';
          })
          .catch(function(err) {
            console.error('Erreur:', err);
            qrError.textContent = err.message;
            qrError.style.display = '';
            qrResult.style.display = 'none';
          })
          .finally(function() {
            btnText.style.display = '';
            btnSpinner.style.display = 'none';
            generateBtn.disabled = false;
          });
      });
    })();
  </script>
</body>

</html>
