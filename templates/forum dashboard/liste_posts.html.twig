{% extends 'forum dashboard/_layout.html.twig' %}
{% block title %}Liste des Posts — FINOVATE Admin{% endblock %}

{% block admin_content %}
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between">
    <h4 class="mb-0">Liste des posts</h4>
    <span class="badge bg-light text-dark">{{ posts|length }}</span>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover table-centered mb-0 text-nowrap">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Titre</th>
            <th>Auteur</th>
            <th>Forum</th>
            <th>Commentaires</th>
            <th>Créé le</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for post in posts %}
          <tr>
            <td>{{ post.id }}</td>
            <td class="fw-bold">{{ post.title }}</td>
            <td>
              {% if post.author %}
                {{ post.author.firstname }} {{ post.author.lastname }}
              {% else %}
                <span class="text-muted">—</span>
              {% endif %}
            </td>
            <td>{{ post.forum ? post.forum.title : '—' }}</td>
            <td>{{ post.comments|length }}</td>
            <td>{{ post.createdAt|date('d/m/Y') }}</td>
            <td>
              <form method="post" action="{{ path('admin_post_delete', {id: post.id}) }}"
                    onsubmit="return confirm('Supprimer ce post et ses commentaires ?')">
                <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
              </form>
            </td>
          </tr>
          {% else %}
          <tr>
            <td colspan="7" class="text-center py-4">Aucun post trouvé.</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
{% endblock %}
