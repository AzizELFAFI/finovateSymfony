{% extends 'forum dashboard/_layout.html.twig' %}
{% block title %}Contenu signalé #{{ flag.id }}{% endblock %}

{% block admin_content %}
<div class="view-header">
    <a href="{{ path('admin_ai_flags') }}" class="btn-back-mod">← Retour aux flags IA</a>
    <div class="header-badges">
        {% if flag.severity == 'high' %}<span class="sev-badge high">🔴 ÉLEVÉ</span>
        {% elseif flag.severity == 'medium' %}<span class="sev-badge medium">🟡 MOYEN</span>
        {% else %}<span class="sev-badge low">🟢 FAIBLE</span>{% endif %}
        <span class="type-badge">{{ flag.flagType == 'misinformation' ? '📰 Désinformation' : '☠️ Toxique' }}</span>
    </div>
</div>

{# AI Verdict #}
<div class="verdict-card">
    <div class="verdict-label">🤖 Verdict IA</div>
    <div class="verdict-text">{{ flag.verdict }}</div>
    {% if flag.issues %}
    <div class="issues-list">
        {% for issue in flag.issues %}<span class="issue-tag">⚠ {{ issue }}</span>{% endfor %}
    </div>
    {% endif %}
    <div class="verdict-meta">Détecté le {{ flag.detectedAt|date('d/m/Y à H:i') }} — {{ flag.contentType|capitalize }} #{{ flag.contentId }}</div>
</div>

{# Actual content #}
{% if content %}
<div class="view-card">
    <div class="view-meta-row">
        <div class="view-type-badge">{{ flag.contentType == 'post' ? '📝 Post' : '💬 Commentaire' }}</div>
        <div class="view-date">{{ content.createdAt|date('d/m/Y à H:i') }}</div>
    </div>
    {% if flag.contentType == 'post' %}
        <h2 class="view-title">{{ content.title }}</h2>
        {% if content.imageUrl %}<img src="/{{ content.imageUrl }}" alt="" class="view-image">{% endif %}
        <div class="view-body">{{ content.content }}</div>
        <div class="view-refs">📁 Forum : <a href="{{ path('admin_view_forum', {id: content.forum.id}) }}" class="ref-link">{{ content.forum.title }}</a></div>
    {% else %}
        <div class="view-body">{{ content.content }}</div>
        <div class="view-refs">
            📝 Post : <a href="{{ path('admin_view_post', {id: content.post.id}) }}" class="ref-link">{{ content.post.title }}</a>
            &nbsp;·&nbsp;
            📁 Forum : <a href="{{ path('admin_view_forum', {id: content.post.forum.id}) }}" class="ref-link">{{ content.post.forum.title }}</a>
        </div>
    {% endif %}
</div>
{% else %}
<div class="missing-content">⚠ Le contenu original a déjà été supprimé.</div>
{% endif %}

{# Author card — simple display + one Gérer button #}
{% if author %}
<div class="author-card">
    <div class="vac-label">👤 Auteur du contenu</div>
    <div class="author-row">
        <div class="vac-avatar">{{ author.firstname|first|upper }}{{ author.lastname|first|upper }}</div>
        <div class="author-info">
            <div class="vac-name">{{ author.firstname }} {{ author.lastname }}</div>
            <div class="vac-email">{{ author.email }}</div>
            <div class="vac-role">
                {% if author.role == 'BANNED' %}<span class="badge-ban">🚫 Banni</span>
                {% elseif restriction %}<span class="badge-restrict">⏱ Restreint</span>
                {% else %}<span class="badge-active">✅ Actif</span>{% endif %}
            </div>
        </div>
        <button class="btn-gerer" onclick="openPanel()">⚙️ Gérer</button>
    </div>
</div>
{% endif %}

{# Bottom actions #}
<div class="flag-bottom-actions">
    {% if content %}
    <button class="btn-delete-content" onclick="deleteContent()">🗑️ Supprimer le contenu</button>
    {% endif %}
    <form method="post" action="{{ path('admin_ignore_flag', {id: flag.id}) }}" style="display:inline">
        <button class="btn-ignore">✓ Ignorer ce flag</button>
    </form>
</div>

{# Slide-in panel from right #}
{% if author %}
<div class="panel-overlay" id="panelOverlay" style="display:none" onclick="closePanel()"></div>
<div class="detail-panel" id="detailPanel" style="display:none">
    <div class="panel-header">
        <div class="panel-avatar">{{ author.firstname|first|upper }}{{ author.lastname|first|upper }}</div>
        <div>
            <div class="panel-name">{{ author.firstname }} {{ author.lastname }}</div>
            <div class="panel-email">{{ author.email }}</div>
        </div>
        <button onclick="closePanel()" class="panel-close">×</button>
    </div>

    {% if author.role == 'BANNED' %}
        <div class="already-banned">🚫 Cet utilisateur est déjà définitivement banni.</div>
    {% else %}

    <div class="panel-actions">
        <div class="action-section">
            <div class="action-label">📧 1ère infraction — Avertissement</div>
            <div class="action-row">
                <input type="text" id="warnReason" class="action-input" value="{{ flag.verdict|slice(0,80) }}" placeholder="Raison...">
                <button class="btn-warn" onclick="warnUser({{ author.id }})">Envoyer</button>
            </div>
        </div>

        <div class="action-section">
            <div class="action-label">⏱ 2ème infraction — Restriction</div>
            <div class="restrict-grid">
                <label class="toggle-label"><input type="checkbox" id="rCanPost"> Peut poster</label>
                <label class="toggle-label"><input type="checkbox" id="rCanComment"> Peut commenter</label>
                <label class="toggle-label"><input type="checkbox" id="rCanForum"> Peut créer forum</label>
            </div>
            <div class="action-row">
                <input type="number" id="rDays" value="7" min="1" class="action-input-sm">
                <input type="text" id="rReason" class="action-input" value="{{ flag.verdict|slice(0,80) }}" placeholder="Raison...">
                <button class="btn-restrict" onclick="restrictUser({{ author.id }})">Restreindre</button>
            </div>
        </div>

        <div class="action-section action-danger">
            <div class="action-label">🚫 3ème infraction — Bannissement définitif</div>
            <div class="action-row">
                <input type="text" id="banReason" class="action-input" value="{{ flag.verdict|slice(0,80) }}" placeholder="Raison...">
                <button class="btn-ban" onclick="banUser({{ author.id }})">Bannir</button>
            </div>
        </div>
    </div>
    {% endif %}
</div>
{% endif %}

<style>
.view-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 10px; }
.btn-back-mod { color: #64748b; font-size: 13px; text-decoration: none; padding: 7px 14px; border: 1px solid #e5e7eb; border-radius: 8px; background: white; }
.header-badges { display: flex; gap: 8px; }
.sev-badge { font-size: 12px; font-weight: 700; padding: 4px 12px; border-radius: 20px; }
.sev-badge.high { background: #fef2f2; color: #dc2626; }
.sev-badge.medium { background: rgba(245,158,11,0.15); color: #fbbf24; }
.sev-badge.low { background: rgba(34,197,94,0.15); color: #237f4e; }
.type-badge { background: rgba(102,126,234,0.15); color: #818cf8; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; }
.verdict-card { background: rgba(239,68,68,0.05); border: 1px solid rgba(239,68,68,0.2); border-radius: 12px; padding: 20px; margin-bottom: 16px; }
.verdict-label { font-size: 11px; font-weight: 700; color: #dc2626; text-transform: uppercase; margin-bottom: 8px; }
.verdict-text { font-size: 14px; color: #1a1a1b; line-height: 1.7; margin-bottom: 12px; }
.issues-list { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; }
.issue-tag { background: rgba(239,68,68,0.1); color: #dc2626; padding: 3px 10px; border-radius: 4px; font-size: 12px; }
.verdict-meta { font-size: 11px; color: #4a5568; }
.view-card { background: white; border: 1px solid #e5e7eb; border-radius: 12px; padding: 24px; margin-bottom: 16px; }
.view-meta-row { display: flex; justify-content: space-between; margin-bottom: 12px; }
.view-type-badge { background: #f0fdf4; color: #237f4e; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; }
.view-date { font-size: 12px; color: #4a5568; }
.view-title { font-size: 20px; font-weight: 700; color: #1a1a1b; margin-bottom: 12px; }
.view-image { max-width: 100%; border-radius: 8px; margin-bottom: 12px; max-height: 250px; object-fit: cover; }
.view-body { font-size: 14px; color: #64748b; line-height: 1.8; white-space: pre-wrap; margin-bottom: 12px; }
.view-refs { font-size: 12px; color: #4a5568; }
.ref-link { color: #818cf8; text-decoration: none; }
.missing-content { background: white; border: 1px solid #e5e7eb; border-radius: 10px; padding: 20px; color: #64748b; font-size: 13px; margin-bottom: 16px; }
/* Author card */
.author-card { background: white; border: 1px solid #e5e7eb; border-radius: 12px; padding: 20px; margin-bottom: 16px; }
.vac-label { font-size: 11px; font-weight: 600; color: #4a5568; text-transform: uppercase; margin-bottom: 12px; }
.author-row { display: flex; align-items: center; gap: 14px; }
.vac-avatar { width: 44px; height: 44px; border-radius: 50%; background: linear-gradient(135deg, #667eea, #764ba2); display: flex; align-items: center; justify-content: center; font-size: 15px; font-weight: 700; color: white; flex-shrink: 0; }
.author-info { flex: 1; }
.vac-name { font-size: 15px; font-weight: 600; color: #1a1a1b; }
.vac-email { font-size: 12px; color: #64748b; }
.vac-role { margin-top: 4px; }
.badge-active { font-size: 11px; background: #f0fdf4; color: #237f4e; padding: 2px 8px; border-radius: 10px; }
.badge-restrict { font-size: 11px; background: rgba(245,158,11,0.15); color: #fbbf24; padding: 2px 8px; border-radius: 10px; }
.badge-ban { font-size: 11px; background: #fef2f2; color: #dc2626; padding: 2px 8px; border-radius: 10px; }
.btn-gerer { background: linear-gradient(135deg, #667eea, #764ba2); color: white; border: none; padding: 10px 20px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; white-space: nowrap; }
/* Bottom actions */
.flag-bottom-actions { display: flex; gap: 10px; margin-top: 8px; }
.btn-delete-content { background: rgba(239,68,68,0.1); color: #dc2626; border: 1px solid rgba(239,68,68,0.3); padding: 9px 18px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; }
.btn-ignore { background: #f0fdf4; color: #64748b; border: 1px solid #e5e7eb; padding: 9px 18px; border-radius: 8px; font-size: 13px; cursor: pointer; }
/* Slide-in panel */
.panel-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 200; }
.detail-panel { position: fixed; right: 0; top: 0; bottom: 0; width: 400px; background: white; border-left: 1px solid #e5e7eb; z-index: 201; overflow-y: auto; padding: 24px; }
.panel-header { display: flex; align-items: center; gap: 14px; margin-bottom: 24px; }
.panel-avatar { width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, #667eea, #764ba2); display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 700; color: white; flex-shrink: 0; }
.panel-name { font-size: 16px; font-weight: 700; color: #1a1a1b; }
.panel-email { font-size: 12px; color: #64748b; margin-top: 2px; }
.panel-close { margin-left: auto; background: none; border: none; color: #64748b; font-size: 22px; cursor: pointer; }
.panel-actions { display: flex; flex-direction: column; gap: 14px; }
.action-section { background: #f0fdf4; border-radius: 10px; padding: 14px; border: 1px solid #e5e7eb; }
.action-section.action-danger { border-color: rgba(239,68,68,0.3); }
.action-label { font-size: 12px; font-weight: 600; color: #64748b; margin-bottom: 10px; }
.action-row { display: flex; gap: 8px; align-items: center; }
.action-input { flex: 1; background: white; border: 1px solid #e5e7eb; color: #1a1a1b; padding: 7px 12px; border-radius: 6px; font-size: 12px; outline: none; }
.action-input-sm { width: 65px; background: white; border: 1px solid #e5e7eb; color: #1a1a1b; padding: 7px 10px; border-radius: 6px; font-size: 12px; outline: none; }
.restrict-grid { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 10px; }
.toggle-label { display: flex; align-items: center; gap: 6px; font-size: 12px; color: #64748b; cursor: pointer; }
.toggle-label input { accent-color: #237f4e; }
.btn-warn { background: rgba(245,158,11,0.15); color: #fbbf24; border: 1px solid rgba(245,158,11,0.3); padding: 7px 14px; border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer; white-space: nowrap; }
.btn-restrict { background: rgba(102,126,234,0.15); color: #818cf8; border: 1px solid rgba(102,126,234,0.3); padding: 7px 14px; border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer; white-space: nowrap; }
.btn-ban { background: #fef2f2; color: #dc2626; border: 1px solid rgba(239,68,68,0.3); padding: 7px 14px; border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer; white-space: nowrap; }
.already-banned { background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); border-radius: 8px; padding: 14px; color: #dc2626; font-size: 13px; }
</style>

<script>
function openPanel()  { document.getElementById('panelOverlay').style.display = 'block'; document.getElementById('detailPanel').style.display = 'block'; }
function closePanel() { document.getElementById('panelOverlay').style.display = 'none';  document.getElementById('detailPanel').style.display = 'none'; }

async function warnUser(id) {
    var reason = document.getElementById('warnReason').value || 'Contenu signalé par l\'IA';
    var form = new FormData(); form.append('reason', reason);
    var res  = await fetch('/forum/admin/users/' + id + '/warn', { method: 'POST', body: form });
    var data = await res.json();
    alert(data.success ? '✅ Avertissement envoyé.' : '❌ ' + (data.error || 'Erreur'));
}

async function restrictUser(id) {
    var form = new FormData();
    form.append('days',           document.getElementById('rDays').value);
    form.append('canPost',        document.getElementById('rCanPost').checked ? '1' : '0');
    form.append('canComment',     document.getElementById('rCanComment').checked ? '1' : '0');
    form.append('canCreateForum', document.getElementById('rCanForum').checked ? '1' : '0');
    form.append('reason',         document.getElementById('rReason').value || 'Contenu signalé par l\'IA');
    form.append('offense', '2');
    var res  = await fetch('/forum/admin/users/' + id + '/restrict', { method: 'POST', body: form });
    var data = await res.json();
    alert(data.success ? '✅ Restriction appliquée.' : '❌ ' + (data.error || 'Erreur'));
    if (data.success) { closePanel(); location.reload(); }
}

async function banUser(id) {
    if (!confirm('Bannir définitivement cet utilisateur ?')) return;
    var form = new FormData();
    form.append('reason', document.getElementById('banReason').value || 'Infractions répétées');
    var res  = await fetch('/forum/admin/users/' + id + '/ban', { method: 'POST', body: form });
    var data = await res.json();
    alert(data.success ? '✅ Utilisateur banni.' : '❌ ' + (data.error || 'Erreur'));
    if (data.success) { closePanel(); location.reload(); }
}

async function deleteContent() {
    if (!confirm('Supprimer ce contenu ?')) return;
    var form = new FormData();
    form.append('reason', '{{ flag.flagType == "misinformation" ? "Misinformation / Fausses informations" : "Contenu toxique ou offensant" }}');
    var res  = await fetch('/forum/admin/delete/{{ flag.contentType }}/{{ flag.contentId }}', { method: 'POST', body: form }.then ? await fetch('/forum/admin/delete/{{ flag.contentType }}/{{ flag.contentId }}', { method: 'POST', body: form } : fetch(await fetch('/forum/admin/delete/{{ flag.contentType }}/{{ flag.contentId }}', { method: 'POST', body: form }));
    var data = await res.json();
    if (data.success) window.location.href = '{{ path("admin_ai_flags") }}';
    else alert('Erreur : ' + data.message);
}
</script>
{% endblock %}
