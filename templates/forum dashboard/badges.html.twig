{% extends 'forum dashboard/_layout.html.twig' %}
{% block title %}Badges — FINOVATE Admin{% endblock %}

{% block admin_content %}
<div class="page-header">
    <h1 class="page-title">🏆 Gestion des Badges</h1>
</div>

{# Create form #}
<div class="create-card">
    <h2 class="card-title">Créer un nouveau badge</h2>
    <form method="post" action="{{ path('admin_badge_create') }}" class="badge-form">
        <div class="form-row">
            <div class="form-group">
                <label>Icône (emoji)</label>
                <input type="text" name="icon" class="form-input" placeholder="🏆" maxlength="10" required>
            </div>
            <div class="form-group" style="flex:2">
                <label>Nom du badge</label>
                <input type="text" name="name" class="form-input" placeholder="Ex: Premier Post" required>
            </div>
            <div class="form-group">
                <label>Catégorie</label>
                <input type="text" name="category" class="form-input" placeholder="Ex: posts">
            </div>
        </div>
        <div class="form-group">
            <label>Description</label>
            <input type="text" name="description" class="form-input" placeholder="Ex: Publié votre premier post" required>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>Type de condition</label>
                <select name="requirementType" class="form-input">
                    <option value="posts">Nombre de posts</option>
                    <option value="comments">Nombre de commentaires</option>
                    <option value="votes">Nombre de votes</option>
                    <option value="shares">Nombre de partages</option>
                    <option value="forums">Forums rejoints</option>
                </select>
            </div>
            <div class="form-group">
                <label>Valeur requise</label>
                <input type="number" name="requirementValue" class="form-input" value="1" min="1" required>
            </div>
            <div class="form-group" style="display:flex;align-items:flex-end">
                <button type="submit" class="btn-create">+ Créer le badge</button>
            </div>
        </div>
    </form>
</div>

{# Existing badges #}
<div class="badges-list">
    <h2 class="card-title">Badges existants ({{ badges|length }})</h2>
    {% if badges is empty %}
        <div class="empty-state">Aucun badge créé.</div>
    {% else %}
    <div class="badges-grid">
        {% for badge in badges %}
        <div class="badge-card">
            <div class="badge-icon">{{ badge.icon ?? '🏆' }}</div>
            <div class="badge-info">
                <div class="badge-name">{{ badge.name }}</div>
                <div class="badge-desc">{{ badge.description }}</div>
                <div class="badge-req">{{ badge.requirementType }} ≥ {{ badge.requirementValue }}</div>
            </div>
            <form method="post" action="{{ path('admin_badge_delete', {id: badge.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer ce badge ?')">
                <button class="btn-del">🗑️</button>
            </form>
        </div>
        {% endfor %}
    </div>
    {% endif %}
</div>

<style>
.page-header { margin-bottom: 24px; }
.page-title { font-size: 22px; font-weight: 700; color: #1a1a1b; }
.create-card { background: white; border: 1px solid #e5e7eb; border-radius: 12px; padding: 24px; margin-bottom: 28px; }
.card-title { font-size: 16px; font-weight: 700; color: #1a1a1b; margin-bottom: 18px; }
.badge-form { display: flex; flex-direction: column; gap: 14px; }
.form-row { display: flex; gap: 12px; }
.form-group { display: flex; flex-direction: column; gap: 6px; flex: 1; }
.form-group label { font-size: 12px; font-weight: 600; color: #64748b; }
.form-input { background: #f0fdf4; border: 1px solid #e5e7eb; color: #1a1a1b; padding: 9px 12px; border-radius: 8px; font-size: 13px; outline: none; width: 100%; }
.form-input:focus { border-color: #237f4e; }
.btn-create { background: #237f4e; color: white; border: none; padding: 9px 20px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; white-space: nowrap; }
.badges-list { background: white; border: 1px solid #e5e7eb; border-radius: 12px; padding: 24px; }
.empty-state { color: #64748b; font-size: 13px; padding: 20px; text-align: center; }
.badges-grid { display: flex; flex-direction: column; gap: 8px; margin-top: 16px; }
.badge-card { display: flex; align-items: center; gap: 14px; background: #f0fdf4; border: 1px solid #e5e7eb; border-radius: 10px; padding: 12px 16px; }
.badge-icon { font-size: 28px; flex-shrink: 0; }
.badge-info { flex: 1; }
.badge-name { font-size: 14px; font-weight: 700; color: #1a1a1b; }
.badge-desc { font-size: 12px; color: #64748b; margin-top: 2px; }
.badge-req { font-size: 11px; color: #237f4e; margin-top: 4px; font-weight: 600; }
.btn-del { background: rgba(239,68,68,0.1); color: #dc2626; border: 1px solid rgba(239,68,68,0.3); padding: 6px 10px; border-radius: 6px; cursor: pointer; font-size: 14px; }
</style>
{% endblock %}
