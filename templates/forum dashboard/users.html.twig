{% extends 'forum dashboard/_layout.html.twig' %}
{% block title %}Utilisateurs — FINOVATE Admin{% endblock %}

{% block admin_content %}
<div class="page-header">
    <h1 class="page-title">👥 Gestion des utilisateurs</h1>
    <form method="get" class="search-form">
        <input type="text" name="q" value="{{ search }}" placeholder="Rechercher un utilisateur..." class="search-input">
        <button type="submit" class="btn-search">🔍</button>
    </form>
</div>

<div class="table-card">
    {% if users is empty %}
        <div class="empty-state">Aucun utilisateur trouvé.</div>
    {% else %}
    <table class="data-table">
        <thead>
            <tr>
                <th>Utilisateur</th>
                <th>Email</th>
                <th>Posts</th>
                <th>Inscrit le</th>
                <th>Statut</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
            {% set restriction = restrictions[user.id] ?? null %}
            <tr>
                <td>
                    <div class="user-cell">
                        <div class="avatar">{{ user.firstname|first|upper }}{{ user.lastname|first|upper }}</div>
                        <div>
                            <div class="user-name">{{ user.firstname }} {{ user.lastname }}</div>
                            <div class="user-role">{{ user.role }}</div>
                        </div>
                    </div>
                </td>
                <td class="td-email">{{ user.email }}</td>
                <td class="td-count">{{ user.posts|length }}</td>
                <td class="td-date">{{ user.created_at|date('d/m/Y') }}</td>
                <td>
                    {% if user.role == 'BANNED' %}
                        <span class="badge badge-ban">🚫 Banni</span>
                    {% elseif restriction %}
                        <span class="badge badge-restrict">⏱ Restreint</span>
                    {% else %}
                        <span class="badge badge-active">✅ Actif</span>
                    {% endif %}
                </td>
                <td>
                    <button class="btn-action" data-user-id="{{ user.id }}" onclick="openPanel({{ user.id }}, '{{ user.firstname|e('js') }} {{ user.lastname|e('js') }}', '{{ user.email|e('js') }}', {{ user.posts|length }}, {{ user.comments|length }}, '{{ user.role }}', '{{ user.created_at|date('d/m/Y') }}')">⚙️ Gérer</button>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>

{# User detail panel #}
<div class="panel-overlay" id="panelOverlay" style="display:none" onclick="closePanel()"></div>
<div class="detail-panel" id="detailPanel" style="display:none">
    <div class="panel-header">
        <div class="panel-avatar" id="panelAvatar"></div>
        <div>
            <div class="panel-name" id="panelName"></div>
            <div class="panel-email" id="panelEmail"></div>
        </div>
        <button onclick="closePanel()" class="panel-close">×</button>
    </div>
    <div class="panel-stats">
        <div class="pstat"><span id="pPosts">0</span><small>Posts</small></div>
        <div class="pstat"><span id="pComments">0</span><small>Commentaires</small></div>
        <div class="pstat"><span id="pJoined">—</span><small>Inscrit</small></div>
    </div>

    <div class="panel-chart-wrap">
        <canvas id="userChart" height="100"></canvas>
    </div>

    <div class="panel-actions">
        <div class="action-section">
            <div class="action-label">⚠️ 1ère infraction — Avertissement</div>
            <div class="action-row">
                <input type="text" id="warnReason" placeholder="Raison..." class="action-input">
                <button class="btn-warn" onclick="warnUser()">📧 Envoyer avertissement</button>
            </div>
        </div>

        <div class="action-section">
            <div class="action-label">⏱ 2ème infraction — Restriction</div>
            <div class="restrict-grid">
                <label class="toggle-label"><input type="checkbox" id="rCanPost"> Peut poster</label>
                <label class="toggle-label"><input type="checkbox" id="rCanComment"> Peut commenter</label>
                <label class="toggle-label"><input type="checkbox" id="rCanForum"> Peut créer forum</label>
            </div>
            <div class="action-row">
                <input type="number" id="rDays" value="7" min="1" class="action-input-sm" placeholder="Jours">
                <input type="text" id="rReason" placeholder="Raison..." class="action-input">
                <button class="btn-restrict" onclick="restrictUser()">⏱ Restreindre</button>
            </div>
        </div>

        <div class="action-section action-danger">
            <div class="action-label">🚫 3ème infraction — Bannissement définitif</div>
            <div class="action-row">
                <input type="text" id="banReason" placeholder="Raison..." class="action-input">
                <button class="btn-ban" onclick="banUser()">🚫 Bannir définitivement</button>
            </div>
        </div>

        <div class="action-section action-cancel">
            <div class="action-label">✅ Annuler une sanction</div>
            <div class="cancel-btns">
                <button class="btn-unrestrict" onclick="unrestrictUser()">🔓 Annuler la restriction</button>
                <button class="btn-unban" onclick="unbanUser()">✅ Débannir l'utilisateur</button>
            </div>
        </div>
    </div>
</div>

<style>
.page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
.page-title { font-size: 22px; font-weight: 700; color: #1a1a1b; }
.search-form { display: flex; gap: 8px; }
.search-input { background: white; border: 1px solid #e5e7eb; color: #1a1a1b; padding: 8px 14px; border-radius: 8px; font-size: 13px; width: 260px; outline: none; }
.btn-search { background: #237f4e; color: white; border: none; padding: 8px 14px; border-radius: 8px; cursor: pointer; }
.table-card { background: white; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
.data-table { width: 100%; border-collapse: collapse; }
.data-table th { padding: 12px 16px; text-align: left; font-size: 11px; font-weight: 600; color: #64748b; text-transform: uppercase; border-bottom: 1px solid #e5e7eb; }
.data-table td { padding: 12px 16px; font-size: 13px; color: #1a1a1b; border-bottom: 1px solid #1e2130; }
.data-table tr:last-child td { border-bottom: none; }
.data-table tr:hover td { background: #f0fdf4; }
.user-cell { display: flex; align-items: center; gap: 10px; }
.avatar { width: 34px; height: 34px; border-radius: 50%; background: linear-gradient(135deg, #667eea, #764ba2); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; color: white; flex-shrink: 0; }
.user-name { font-weight: 600; }
.user-role { font-size: 11px; color: #64748b; }
.td-email { color: #64748b; font-size: 12px; }
.td-count { text-align: center; color: #64748b; }
.td-date { color: #64748b; }
.badge { padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
.badge-active { background: #f0fdf4; color: #237f4e; }
.badge-restrict { background: rgba(245,158,11,0.15); color: #fbbf24; }
.badge-ban { background: #fef2f2; color: #dc2626; }
.btn-action { background: #f0fdf4; color: #64748b; border: 1px solid #e5e7eb; padding: 5px 12px; border-radius: 6px; font-size: 12px; cursor: pointer; }
.empty-state { padding: 40px; text-align: center; color: #64748b; }
/* Panel */
.panel-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 200; }
.detail-panel { position: fixed; right: 0; top: 0; bottom: 0; width: 420px; background: white; border-left: 1px solid #e5e7eb; z-index: 201; overflow-y: auto; padding: 24px; }
.panel-header { display: flex; align-items: center; gap: 14px; margin-bottom: 20px; }
.panel-avatar { width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, #667eea, #764ba2); display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 700; color: white; flex-shrink: 0; }
.panel-name { font-size: 16px; font-weight: 700; color: #1a1a1b; }
.panel-email { font-size: 12px; color: #64748b; margin-top: 2px; }
.panel-close { margin-left: auto; background: none; border: none; color: #64748b; font-size: 22px; cursor: pointer; }
.panel-stats { display: flex; gap: 16px; margin-bottom: 20px; }
.pstat { background: #f0fdf4; border-radius: 8px; padding: 12px 16px; flex: 1; text-align: center; }
.pstat span { display: block; font-size: 20px; font-weight: 700; color: #1a1a1b; }
.pstat small { font-size: 11px; color: #64748b; }
.panel-chart-wrap { background: #f0fdf4; border-radius: 8px; padding: 12px; margin-bottom: 20px; }
.panel-actions { display: flex; flex-direction: column; gap: 16px; }
.action-section { background: #f0fdf4; border-radius: 10px; padding: 14px; border: 1px solid #e5e7eb; }
.action-section.action-danger { border-color: rgba(239,68,68,0.3); }
.action-label { font-size: 12px; font-weight: 600; color: #64748b; margin-bottom: 10px; }
.action-row { display: flex; gap: 8px; align-items: center; }
.action-input { flex: 1; background: white; border: 1px solid #e5e7eb; color: #1a1a1b; padding: 7px 12px; border-radius: 6px; font-size: 12px; outline: none; }
.action-input-sm { width: 70px; background: white; border: 1px solid #e5e7eb; color: #1a1a1b; padding: 7px 10px; border-radius: 6px; font-size: 12px; outline: none; }
.restrict-grid { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 10px; }
.toggle-label { display: flex; align-items: center; gap: 6px; font-size: 12px; color: #64748b; cursor: pointer; }
.toggle-label input { accent-color: #237f4e; }
.btn-warn { background: rgba(245,158,11,0.15); color: #fbbf24; border: 1px solid rgba(245,158,11,0.3); padding: 7px 14px; border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer; white-space: nowrap; }
.btn-restrict { background: rgba(102,126,234,0.15); color: #818cf8; border: 1px solid rgba(102,126,234,0.3); padding: 7px 14px; border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer; white-space: nowrap; }
.btn-ban { background: #fef2f2; color: #dc2626; border: 1px solid rgba(239,68,68,0.3); padding: 7px 14px; border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer; white-space: nowrap; }
.action-section.action-cancel { border-color: rgba(35,127,78,0.3); background: rgba(35,127,78,0.05); }
.cancel-btns { display: flex; gap: 8px; flex-wrap: wrap; }
.btn-unrestrict { background: #f0fdf4; color: #237f4e; border: 1px solid rgba(35,127,78,0.3); padding: 7px 14px; border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer; white-space: nowrap; }
.btn-unban { background: rgba(59,130,246,0.15); color: #60a5fa; border: 1px solid rgba(59,130,246,0.3); padding: 7px 14px; border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer; white-space: nowrap; }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
var currentUserId = null;
var userChart = null;

function openPanel(id, name, email, posts, comments, role, joined) {
    currentUserId = id;
    var initials = name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0,2);
    document.getElementById('panelAvatar').textContent = initials;
    document.getElementById('panelName').textContent   = name;
    document.getElementById('panelEmail').textContent  = email;
    document.getElementById('pPosts').textContent      = posts;
    document.getElementById('pComments').textContent   = comments;
    document.getElementById('pJoined').textContent     = joined;
    document.getElementById('panelOverlay').style.display = 'block';
    document.getElementById('detailPanel').style.display  = 'block';
    loadUserChart(id);
}

function closePanel() {
    document.getElementById('panelOverlay').style.display = 'none';
    document.getElementById('detailPanel').style.display  = 'none';
    currentUserId = null;
}

async function loadUserChart(id) {
    try {
        var res  = await fetch('/forum/admin/users/' + id + '/activity');
        var data = await res.json();
        if (userChart) userChart.destroy();
        userChart = new Chart(document.getElementById('userChart'), {
            type: 'bar',
            data: {
                labels: data.labels,
                datasets: [
                    { label: 'Posts', data: data.posts, backgroundColor: 'rgba(35,127,78,0.6)' },
                    { label: 'Commentaires', data: data.comments, backgroundColor: 'rgba(102,126,234,0.6)' }
                ]
            },
            options: {
                responsive: true,
                plugins: { legend: { labels: { color: '#94a3b8', font: { size: 11 } } } },
                scales: {
                    x: { grid: { color: '#e5e7eb' }, ticks: { color: '#64748b', maxTicksLimit: 8 } },
                    y: { grid: { color: '#e5e7eb' }, ticks: { color: '#64748b' }, beginAtZero: true }
                }
            }
        });
    } catch(e) {}
}

async function warnUser() {
    if (!currentUserId) return;
    var reason = document.getElementById('warnReason').value || 'Comportement contraire aux règles';
    var form = new FormData(); form.append('reason', reason);
    var res = await fetch('/forum/admin/users/' + currentUserId + '/warn', { method: 'POST', body: form });
    var data = await res.json();
    alert(data.success ? '✅ Avertissement envoyé.' : '❌ ' + (data.error || 'Erreur'));
}

async function restrictUser() {
    if (!currentUserId) return;
    var form = new FormData();
    form.append('days',           document.getElementById('rDays').value);
    form.append('canPost',        document.getElementById('rCanPost').checked ? '1' : '0');
    form.append('canComment',     document.getElementById('rCanComment').checked ? '1' : '0');
    form.append('canCreateForum', document.getElementById('rCanForum').checked ? '1' : '0');
    form.append('reason',         document.getElementById('rReason').value || 'Infraction aux règles');
    form.append('offense',        '2');
    var res = await fetch('/forum/admin/users/' + currentUserId + '/restrict', { method: 'POST', body: form });
    var data = await res.json();
    alert(data.success ? '✅ Restriction appliquée.' : '❌ ' + (data.error || 'Erreur'));
    if (data.success) location.reload();
}

async function banUser() {
    if (!currentUserId) return;
    if (!confirm('Bannir définitivement cet utilisateur ?')) return;
    var form = new FormData();
    form.append('reason', document.getElementById('banReason').value || 'Infractions répétées');
    var res = await fetch('/forum/admin/users/' + currentUserId + '/ban', { method: 'POST', body: form });
    var data = await res.json();
    alert(data.success ? '✅ Utilisateur banni.' : '❌ ' + (data.error || 'Erreur'));
    if (data.success) location.reload();
}

async function unrestrictUser() {
    if (!currentUserId) return;
    if (!confirm('Annuler la restriction de cet utilisateur ?')) return;
    var res  = await fetch('/forum/admin/users/' + currentUserId + '/unrestrict', { method: 'POST' });
    var data = await res.json();
    alert(data.success ? '✅ Restriction annulée.' : '❌ ' + (data.error || 'Erreur'));
    if (data.success) { closePanel(); location.reload(); }
}

async function unbanUser() {
    if (!currentUserId) return;
    if (!confirm('Débannir cet utilisateur ? Il retrouvera un accès normal.')) return;
    var res  = await fetch('/forum/admin/users/' + currentUserId + '/unban', { method: 'POST' });
    var data = await res.json();
    alert(data.success ? '✅ Utilisateur débanni.' : '❌ ' + (data.error || 'Erreur'));
    if (data.success) { closePanel(); location.reload(); }
}
{% if autoOpenId is defined and autoOpenId %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    var btn = document.querySelector('[data-user-id="{{ autoOpenId }}"]');
    if (btn) btn.click();
});
</script>
{% endif %}
</script>
{% endblock %}
