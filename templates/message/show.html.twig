{% extends 'base.html.twig' %}

{% block title %}Message Details{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-6 flex space-x-3">
        <a href="{{ path('app_message_index') }}" class="inline-flex items-center text-sm font-medium text-gray-500 hover:text-gray-900 transition-colors bg-white px-3 py-1.5 rounded border shadow-sm">
            <svg class="mr-1.5 h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
            </svg>
            Back to inbox
        </a>
    </div>

    <div class="bg-white shadow-lg overflow-hidden sm:rounded-xl border border-gray-100">
        <div class="px-4 py-5 sm:px-6 flex justify-between items-center bg-white border-b border-gray-200">
            <div>
                <h3 class="text-xl leading-6 font-semibold text-gray-900">Message from 
                    <span class="ml-2 font-bold {{ message.senderRole|lower == 'admin' ? 'text-purple-600' : 'text-green-600' }}">
                        {{ message.senderRole }}
                    </span>
                </h3>
                <p class="mt-1 max-w-2xl text-sm text-gray-500">Sent on {{ message.sentAt ? message.sentAt|date('F j, Y \\a\\t h:i A') : 'N/A' }}</p>
            </div>
            <div class="flex space-x-3">
                <a href="{{ path('app_message_edit', {'id': message.id}) }}" class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors">
                    <svg class="-ml-1 mr-2 h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                    </svg>
                    Edit
                </a>
            </div>
        </div>
        
        <div class="px-4 py-6 sm:px-6 bg-gray-50">
            <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-200 text-gray-800 text-base leading-relaxed whitespace-pre-wrap font-medium">
                {{ message.content }}
            </div>
        </div>
        
        <div class="border-t border-gray-200 px-4 py-4 sm:px-6 bg-gray-50 text-right text-xs text-gray-400">
            Message ID: #{{ message.id }}
        </div>
    </div>
</div>
{% endblock %}
