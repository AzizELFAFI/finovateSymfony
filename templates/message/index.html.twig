{% extends 'base.html.twig' %}

{% block title %}Message List{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 bg-white min-h-screen">

    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900">💬 Messages</h1>
            <p class="mt-1 text-sm text-gray-500">Historique de tous les messages échangés</p>
        </div>
        <a href="{{ path('app_message_new') }}"
           class="inline-flex items-center gap-2 rounded-lg bg-green-600 px-5 py-2.5 text-sm font-semibold text-white shadow hover:bg-green-700 transition-all duration-200">
            <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd" />
            </svg>
            Nouveau message
        </a>
    </div>

    <!-- Filters -->
    <form method="GET" action="{{ path('app_message_index') }}"
          class="bg-gray-50 border border-gray-200 rounded-xl p-5 mb-8 shadow-sm">
        <div class="flex flex-wrap gap-4 items-end">

            <!-- Search -->
            <div class="flex-1 min-w-[220px]">
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">🔍 Search</label>
                <input type="text" name="search" value="{{ search }}"
                    placeholder="Rechercher dans le contenu..."
                    class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-800 bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-green-400 focus:border-transparent transition">
            </div>

            <!-- Filter: Sender Role -->
            <div class="min-w-[160px]">
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">👤 Expéditeur</label>
                <select name="senderRole"
                    class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-800 bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-green-400 focus:border-transparent transition">
                    <option value="">Tous</option>
                    <option value="ADMIN" {{ senderRole == 'ADMIN' ? 'selected' }}>🛡️ Admin</option>
                    <option value="USER"  {{ senderRole == 'USER'  ? 'selected' }}>👤 User</option>
                </select>
            </div>

            <!-- Filter: Sort By -->
            <div class="min-w-[160px]">
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">📅 Trier par</label>
                <select name="sortBy"
                    class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-800 bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-green-400 focus:border-transparent transition">
                    <option value="sentAt"     {{ sortBy == 'sentAt'     ? 'selected' }}>Date</option>
                    <option value="senderRole" {{ sortBy == 'senderRole' ? 'selected' }}>Rôle</option>
                    <option value="id"         {{ sortBy == 'id'         ? 'selected' }}>ID</option>
                </select>
            </div>

            <div class="min-w-[100px]">
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Ordre</label>
                <select name="sortDir"
                    class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-800 bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-green-400 focus:border-transparent transition">
                    <option value="DESC" {{ sortDir == 'DESC' ? 'selected' }}>↓ Décroissant</option>
                    <option value="ASC"  {{ sortDir == 'ASC'  ? 'selected' }}>↑ Croissant</option>
                </select>
            </div>

            <!-- Buttons -->
            <div class="flex gap-2">
                <button type="submit"
                    class="inline-flex items-center gap-1.5 rounded-lg bg-green-600 px-5 py-2.5 text-sm font-semibold text-white shadow hover:bg-green-700 transition-all">
                    Apply
                </button>
                <a href="{{ path('app_message_index') }}"
                    class="inline-flex items-center gap-1.5 rounded-lg border border-gray-300 bg-white px-5 py-2.5 text-sm font-semibold text-gray-600 shadow hover:bg-gray-100 transition-all">
                    Reset
                </a>
            </div>
        </div>
    </form>

    <!-- Results count -->
    <p class="text-sm text-gray-500 mb-4">
        Showing <span class="font-semibold text-gray-800">{{ messages|length }}</span> message{{ messages|length != 1 ? 's' }}
    </p>

    <!-- Table -->
    <div class="overflow-hidden rounded-xl shadow ring-1 ring-gray-200">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="py-3.5 pl-6 pr-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">#</th>
                    <th class="px-4 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Contenu</th>
                    <th class="px-4 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Expéditeur</th>
                    <th class="px-4 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Ticket #</th>
                    <th class="px-4 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Date d'envoi</th>
                    <th class="px-4 py-3.5 text-right text-xs font-semibold uppercase tracking-wide text-gray-500">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 bg-white">
            {% for message in messages %}
                <tr class="hover:bg-green-50 transition-colors duration-150">
                    <td class="whitespace-nowrap py-4 pl-6 pr-3 text-sm font-bold text-gray-400">#{{ message.id }}</td>
                    <td class="px-4 py-4 text-sm text-gray-600 max-w-xs">
                        <span class="block truncate" title="{{ message.content }}">
                            {{ message.content|default('—') }}
                        </span>
                    </td>
                    <td class="whitespace-nowrap px-4 py-4 text-sm">
                        {% if message.senderRole == 'ADMIN' %}
                            <span class="inline-flex items-center gap-1 rounded-full bg-purple-100 px-3 py-1 text-xs font-semibold text-purple-700">🛡️ Admin</span>
                        {% else %}
                            <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-700">👤 User</span>
                        {% endif %}
                    </td>
                    <td class="whitespace-nowrap px-4 py-4 text-sm text-gray-500">
                        #{{ message.idTicket }}
                    </td>
                    <td class="whitespace-nowrap px-4 py-4 text-sm text-gray-500">
                        {{ message.sentAt ? message.sentAt|date('d M Y H:i') : '—' }}
                    </td>
                    <td class="whitespace-nowrap px-4 py-4 text-right text-sm font-medium">
                        <a href="{{ path('app_message_show', {'id': message.id}) }}"
                           class="inline-flex items-center rounded-lg bg-gray-100 px-3 py-1.5 text-xs font-semibold text-gray-700 hover:bg-gray-200 transition mr-1">
                            👁 View
                        </a>
                        <a href="{{ path('app_message_edit', {'id': message.id}) }}"
                           class="inline-flex items-center rounded-lg bg-green-100 px-3 py-1.5 text-xs font-semibold text-green-700 hover:bg-green-200 transition mr-1">
                            ✏️ Edit
                        </a>
                        <form method="post" action="{{ path('app_message_delete', {'id': message.id}) }}"
                              onsubmit="return confirm('Supprimer ce message ?');" style="display:inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ message.id) }}">
                            <button type="submit" class="inline-flex items-center rounded-lg bg-red-100 px-3 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-200 transition">
                                🗑 Delete
                            </button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="py-20 text-center">
                        <div class="flex flex-col items-center gap-3 text-gray-400">
                            <svg class="h-14 w-14 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" />
                            </svg>
                            <p class="text-base font-semibold text-gray-500">Aucun message trouvé</p>
                            <p class="text-sm text-gray-400">Essayez d'ajuster vos filtres ou créez un nouveau message.</p>
                            <a href="{{ path('app_message_new') }}"
                               class="mt-2 inline-flex items-center rounded-lg bg-green-600 px-4 py-2 text-sm font-semibold text-white hover:bg-green-700 transition">
                                + Nouveau message
                            </a>
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}