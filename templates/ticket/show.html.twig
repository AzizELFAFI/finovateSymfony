{% extends 'base.html.twig' %}

{% block title %}Ticket #{{ ticket.id }}{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-6 flex space-x-3">
        <a href="{{ path('app_ticket_index') }}" class="inline-flex items-center text-sm font-medium text-gray-500 hover:text-gray-900 transition-colors bg-white px-3 py-1.5 rounded border shadow-sm">
            <svg class="mr-1.5 h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
            </svg>
            Back to tickets
        </a>
    </div>

    <div class="bg-white shadow-lg overflow-hidden sm:rounded-xl border border-gray-100">
        <div class="px-4 py-5 sm:px-6 flex flex-col sm:flex-row justify-between items-start sm:items-center bg-white border-b border-gray-200">
            <div>
                <h3 class="text-xl leading-6 font-semibold text-gray-900 flex items-center">
                    Ticket Details
                    <span class="ml-3 inline-flex items-center rounded-md bg-gray-100 px-2.5 py-0.5 text-sm font-medium text-gray-800">
                        #{{ ticket.id }}
                    </span>
                </h3>
                <p class="mt-1 max-w-2xl text-sm text-gray-500">Full information and status.</p>
            </div>
            <div class="mt-4 sm:mt-0 flex space-x-3">
                <a href="{{ path('app_ticket_edit', {'id': ticket.id}) }}" class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors">
                    <svg class="-ml-1 mr-2 h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                    </svg>
                    Edit Ticket
                </a>
            </div>
        </div>
        
        <div class="border-t border-gray-200 px-4 py-5 sm:p-0">
            <dl class="sm:divide-y sm:divide-gray-200">
                <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6 transition duration-150 hover:bg-gray-50">
                    <dt class="text-sm font-medium text-gray-500">Status</dt>
                    <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
                        <span class="inline-flex items-center rounded-full bg-blue-100 px-3 py-0.5 text-sm font-medium text-blue-800">
                            {{ ticket.statut }}
                        </span>
                    </dd>
                </div>
                
                <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6 transition duration-150 hover:bg-gray-50">
                    <dt class="text-sm font-medium text-gray-500">Ticket Type</dt>
                    <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
                        {{ ticket.type }}
                    </dd>
                </div>
                
                <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6 transition duration-150 hover:bg-gray-50">
                    <dt class="text-sm font-medium text-gray-500">Priority Level</dt>
                    <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2 font-semibold">
                        {% if ticket.priorite == 'High' or ticket.priorite == 'HIGH' %}
                            <span class="text-red-600 flex items-center">
                                <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
                                </svg>
                                {{ ticket.priorite }}
                            </span>
                        {% else %}
                            {{ ticket.priorite }}
                        {% endif %}
                    </dd>
                </div>
                
                <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6 transition duration-150 hover:bg-gray-50">
                    <dt class="text-sm font-medium text-gray-500">User ID</dt>
                    <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2 flex items-center">
                        <div class="h-6 w-6 rounded-full bg-indigo-100 flex items-center justify-center mr-2">
                            <span class="text-indigo-800 text-xs font-bold">{{ ticket.userId|slice(0,1) }}</span>
                        </div>
                        {{ ticket.userId }}
                    </dd>
                </div>

                <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6 transition duration-150 hover:bg-gray-50">
                    <dt class="text-sm font-medium text-gray-500">Timestamps</dt>
                    <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="bg-gray-50 p-3 rounded-md border border-gray-100">
                                <span class="block text-xs font-medium text-gray-500 uppercase tracking-wide">Created At</span>
                                <span class="block mt-1 text-sm font-semibold text-gray-900">{{ ticket.dateCreation ? ticket.dateCreation|date('Y-m-d H:i:s') : 'N/A' }}</span>
                            </div>
                        </div>
                    </dd>
                </div>
                
                <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6 transition duration-150 hover:bg-gray-50">
                    <dt class="text-sm font-medium text-gray-500">Description</dt>
                    <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
                        <div class="bg-gray-50 rounded-md p-4 text-gray-700 whitespace-pre-wrap border border-gray-100 shadow-inner">
                            {{ ticket.description }}
                        </div>
                    </dd>
                </div>
            </dl>
        </div>
    </div>
</div>
{% endblock %}
