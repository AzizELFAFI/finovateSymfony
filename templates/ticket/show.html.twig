<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <title>Finovate - Détails du Ticket</title>

  <link href="{{ asset('front/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
  <link rel="stylesheet" href="{{ asset('front/assets/css/fontawesome.css') }}">
  <link rel="stylesheet" href="{{ asset('front/assets/css/templatemo-finance-business.css') }}">

  <style>
    .page-shell { padding: 36px 0; }

    .sidebar {
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(15, 118, 110, 0.14);
      box-shadow: 0 14px 38px rgba(0, 0, 0, 0.06);
      padding: 16px;
      position: sticky;
      top: 16px;
    }

    .sidebar .title { font-weight: 900; margin: 0 0 10px 0; }

    .sidebar a {
      display: block;
      padding: 10px 12px;
      border-radius: 12px;
      color: #111827;
      font-weight: 700;
      text-decoration: none;
      border: 1px solid transparent;
    }

    .sidebar a:hover, .sidebar a.active {
      background: rgba(16, 185, 129, 0.08);
      border-color: rgba(16, 185, 129, 0.18);
      color: #0f766e;
    }
    
    .sidebar a.active { background: rgba(16, 185, 129, 0.12); }

    .card-shell {
        background: #fff;
        border-radius: 18px;
        padding: 32px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border: 1px solid rgba(15, 118, 110, 0.1);
        margin-bottom: 24px;
    }

    .chat-container {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .message-bubble {
        padding: 14px 18px;
        border-radius: 18px;
        max-width: 80%;
        line-height: 1.5;
        font-size: 14px;
        position: relative;
    }

    .message-user {
        align-self: flex-end;
        background: #0f766e;
        color: white;
        border-bottom-right-radius: 4px;
    }

    .message-admin {
        align-self: flex-start;
        background: #f1f5f9;
        color: #334155;
        border-bottom-left-radius: 4px;
        border: 1px solid #e2e8f0;
    }

    .message-date {
        font-size: 11px;
        margin-top: 4px;
        opacity: 0.7;
    }
    
    .status-badge {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 12px;
    }
    .status-nouveau { background: #e0f2fe; color: #0284c7; }
    .status-en-cours { background: #fef3c7; color: #d97706; }
    .status-resolu { background: #dcfce7; color: #15803d; }
  </style>
</head>

<body>
  <header>
    <nav class="navbar navbar-expand-lg">
      <div class="container">
        <a class="navbar-brand" href="{{ path('front_home') }}">
          <h2>Finovate</h2>
        </a>
        <div class="collapse navbar-collapse" id="navbarResponsive">
          <ul class="navbar-nav ml-auto">
            <li class="nav-item"><a class="nav-link" href="{{ path('front_home') }}">Accueil</a></li>
            <li class="nav-item active"><a class="nav-link" href="{{ path('user_dashboard') }}">Mon espace</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('front_logout') }}">Déconnexion</a></li>
          </ul>
        </div>
      </div>
    </nav>
  </header>

  <div class="page-heading header-text">
    <div class="container">
      <div class="row">
        <div class="col-md-12">
          <h1>Ticket #{{ ticket.id }}</h1>
          <span>Discutez avec notre support</span>
        </div>
      </div>
    </div>
  </div>

  <div class="page-shell">
    <div class="container">
      <div class="row">
        <div class="col-lg-3 mb-4">
          <div class="sidebar">
            <div class="title">Mon espace</div>
            <a href="{{ path('user_dashboard') }}">Dashboard</a>
            <a href="{{ path('user_transactions') }}">Transactions</a>
            <a href="{{ path('user_bills') }}">Factures</a>
            <a href="{{ path('user_dashboard') ~ '?section=edit' }}">Modifier le profil</a>
            <a href="{{ path('app_ticket_index') }}" class="active">Mes Tickets</a>
            
          </div>
        </div>

        <div class="col-lg-9">
          <!-- Détails du ticket -->
          <div class="card-shell" style="padding: 24px;">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <div>
                <h4 style="font-weight:900;margin:0">{{ ticket.type }}</h4>
                <div style="font-size: 13px; color: #6b7280; font-weight: 600; margin-top: 4px;">
                  Créé le {{ ticket.dateCreation ? ticket.dateCreation|date('d/m/Y à H:i') : '' }}
                </div>
              </div>
              <div class="text-right">
                {% if ticket.statut|upper == 'EN_COURS' or ticket.statut|upper == 'OPEN' %}
                    <span class="status-badge status-en-cours">En cours</span>
                {% elseif ticket.statut|upper == 'RESOLU' or ticket.statut|upper == 'FERME' %}
                    <span class="status-badge status-resolu">Fermé</span>
                {% else %}
                    <span class="status-badge status-nouveau">Nouveau</span>
                {% endif %}
              </div>
            </div>
            
            <div style="background: #f8fafc; border-radius: 12px; padding: 16px; border: 1px solid #f1f5f9;">
              <strong style="color: #475569; font-size: 13px; text-transform: uppercase;">Description du problème</strong>
              <p style="margin-top: 8px; margin-bottom: 0; color: #334155; line-height: 1.6;">{{ ticket.description|nl2br }}</p>
            </div>
          </div>

          <!-- Discussion -->
          <div class="card-shell">
            <h5 style="font-weight: 800; margin-bottom: 24px; border-bottom: 2px solid #f1f5f9; padding-bottom: 12px;">Conversation</h5>
            
            <div class="chat-container mb-4">
              {% for msg in ticket.messages %}
                <div class="message-bubble {% if msg.senderRole == 'USER' %}message-user{% else %}message-admin{% endif %}">
                  {{ msg.content|nl2br }}
                  <div class="message-date">
                    {% if msg.senderRole == 'USER' %}Vous{% else %}Support Admin{% endif %} • {{ msg.sentAt ? msg.sentAt|date('d/m/Y H:i') : '' }}
                  </div>
                </div>
              {% else %}
                <div class="text-center text-muted" style="padding: 20px 0; font-style: italic;">
                  Aucun message pour le moment. Vous pouvez ajouter des précisions ci-dessous.
                </div>
              {% endfor %}
            </div>

            <!-- Formulaire d'ajout de message -->
            {% if ticket.statut|upper != 'RESOLU' and ticket.statut|upper != 'FERME' %}
              <div style="background: #f8fafc; padding: 20px; border-radius: 16px; border: 1px solid #e2e8f0;">
                {{ form_start(form) }}
                  <div class="form-group mb-3">
                    {{ form_widget(form.content, {'attr': {'style': 'border-radius: 12px; border-color: #cbd5e1;'}}) }}
                  </div>
                  <div class="text-right">
                    <button type="submit" class="btn btn-success" style="border-radius: 999px; font-weight: bold; padding: 8px 24px;">Envoyer</button>
                  </div>
                {{ form_end(form) }}
              </div>
            {% else %}
              <div class="alert alert-warning text-center" style="border-radius: 12px;">
                Ce ticket est fermé. Vous ne pouvez plus répondre.
              </div>
            {% endif %}
          </div>

        </div>
      </div>
    </div>
  </div>
</body>
</html>
