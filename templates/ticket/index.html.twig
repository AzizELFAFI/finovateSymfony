{% extends 'base.html.twig' %}

{% block title %}Ticket List{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 bg-white min-h-screen">

    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900">🎫 Tickets</h1>
            <p class="mt-1 text-sm text-gray-500">Manage and track all support tickets</p>
        </div>
        <a href="{{ path('app_ticket_new') }}"
           class="inline-flex items-center gap-2 rounded-lg bg-green-600 px-5 py-2.5 text-sm font-semibold text-white shadow hover:bg-green-700 transition-all duration-200">
            <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd" />
            </svg>
            New Ticket
        </a>
    </div>

    <!-- Filters -->
    <form method="GET" action="{{ path('app_ticket_index') }}"
          class="bg-gray-50 border border-gray-200 rounded-xl p-5 mb-8 shadow-sm">
        <div class="flex flex-wrap gap-4 items-end">

            <!-- Search -->
            <div class="flex-1 min-w-[220px]">
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">🔍 Search</label>
                <input type="text" name="search" value="{{ search }}"
                    placeholder="Search tickets..."
                    class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-800 bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-green-400 focus:border-transparent transition">
            </div>

            <!-- Filter: Status -->
            <div class="min-w-[160px]">
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">📌 Status</label>
                <select name="statut"
                    class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-800 bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-green-400 focus:border-transparent transition">
                    <option value="">All Statuses</option>
                    <option value="open"     {{ statut == 'open'     ? 'selected' }}>🟢 Open</option>
                    <option value="pending"  {{ statut == 'pending'  ? 'selected' }}>🟡 Pending</option>
                    <option value="resolved" {{ statut == 'resolved' ? 'selected' }}>🔵 Resolved</option>
                    <option value="closed"   {{ statut == 'closed'   ? 'selected' }}>⚫ Closed</option>
                </select>
            </div>

            <!-- Filter: Priority -->
            <div class="min-w-[160px]">
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">🔥 Priority</label>
                <select name="priorite"
                    class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-800 bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-green-400 focus:border-transparent transition">
                    <option value="">All Priorities</option>
                    <option value="High"   {{ priorite == 'High'   ? 'selected' }}>🔴 High</option>
                    <option value="Medium" {{ priorite == 'Medium' ? 'selected' }}>🟡 Medium</option>
                    <option value="Low"    {{ priorite == 'Low'    ? 'selected' }}>🟢 Low</option>
                </select>
            </div>

            <!-- Buttons -->
            <div class="flex gap-2">
                <button type="submit"
                    class="inline-flex items-center gap-1.5 rounded-lg bg-green-600 px-5 py-2.5 text-sm font-semibold text-white shadow hover:bg-green-700 transition-all">
                    Apply
                </button>
                <a href="{{ path('app_ticket_index') }}"
                    class="inline-flex items-center gap-1.5 rounded-lg border border-gray-300 bg-white px-5 py-2.5 text-sm font-semibold text-gray-600 shadow hover:bg-gray-100 transition-all">
                    Reset
                </a>
            </div>
        </div>
    </form>

    <!-- Results count -->
    <p class="text-sm text-gray-500 mb-4">
        Showing <span class="font-semibold text-gray-800">{{ tickets|length }}</span> ticket{{ tickets|length != 1 ? 's' }}
    </p>

    <!-- Table -->
    <div class="overflow-hidden rounded-xl shadow ring-1 ring-gray-200">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="py-3.5 pl-6 pr-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">#</th>
                    <th class="px-4 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Type</th>
                    <th class="px-4 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Description</th>
                    <th class="px-4 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Status</th>
                    <th class="px-4 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Priority</th>
                    <th class="px-4 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Created</th>
                    <th class="px-4 py-3.5 text-right text-xs font-semibold uppercase tracking-wide text-gray-500">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 bg-white">
            {% for ticket in tickets %}
                <tr class="hover:bg-green-50 transition-colors duration-150">

                    <td class="whitespace-nowrap py-4 pl-6 pr-3 text-sm font-bold text-gray-400">#{{ ticket.id }}</td>

                    <td class="whitespace-nowrap px-4 py-4 text-sm">
                        <span class="inline-flex items-center rounded-full bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700 ring-1 ring-blue-200">
                            {{ ticket.type ?? '—' }}
                        </span>
                    </td>

                    <td class="px-4 py-4 text-sm text-gray-600 max-w-xs">
                        <span class="block truncate" title="{{ ticket.description }}">
                            {{ ticket.description ?? '—' }}
                        </span>
                    </td>

                    <td class="whitespace-nowrap px-4 py-4 text-sm">
                        {% set s = ticket.statut|lower %}
                        {% if s == 'open' %}
                            <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-700">🟢 Open</span>
                        {% elseif s == 'pending' %}
                            <span class="inline-flex items-center gap-1 rounded-full bg-yellow-100 px-3 py-1 text-xs font-semibold text-yellow-700">🟡 Pending</span>
                        {% elseif s == 'resolved' %}
                            <span class="inline-flex items-center gap-1 rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">🔵 Resolved</span>
                        {% elseif s == 'closed' %}
                            <span class="inline-flex items-center gap-1 rounded-full bg-gray-200 px-3 py-1 text-xs font-semibold text-gray-600">⚫ Closed</span>
                        {% else %}
                            <span class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-500">{{ ticket.statut ?? '—' }}</span>
                        {% endif %}
                    </td>

                    <td class="whitespace-nowrap px-4 py-4 text-sm">
                        {% set p = ticket.priorite|lower %}
                        {% if p == 'high' %}
                            <span class="inline-flex items-center gap-1 rounded-full bg-red-100 px-3 py-1 text-xs font-semibold text-red-700">🔴 High</span>
                        {% elseif p == 'medium' %}
                            <span class="inline-flex items-center gap-1 rounded-full bg-yellow-100 px-3 py-1 text-xs font-semibold text-yellow-700">🟡 Medium</span>
                        {% else %}
                            <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-700">🟢 Low</span>
                        {% endif %}
                    </td>

                    <td class="whitespace-nowrap px-4 py-4 text-sm text-gray-500">
                        {{ ticket.dateCreation ? ticket.dateCreation|date('d M Y') : '—' }}
                    </td>

                    <td class="whitespace-nowrap px-4 py-4 text-right text-sm font-medium">
                        <a href="{{ path('app_ticket_show', {'id': ticket.id}) }}"
                           class="inline-flex items-center rounded-lg bg-gray-100 px-3 py-1.5 text-xs font-semibold text-gray-700 hover:bg-gray-200 transition mr-1">
                            👁 View
                        </a>
                        <a href="{{ path('app_ticket_edit', {'id': ticket.id}) }}"
                           class="inline-flex items-center rounded-lg bg-green-100 px-3 py-1.5 text-xs font-semibold text-green-700 hover:bg-green-200 transition">
                            ✏️ Edit
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="py-20 text-center">
                        <div class="flex flex-col items-center gap-3 text-gray-400">
                            <svg class="h-14 w-14 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" />
                            </svg>
                            <p class="text-base font-semibold text-gray-500">No tickets found</p>
                            <p class="text-sm text-gray-400">Try adjusting your filters or create a new ticket.</p>
                            <a href="{{ path('app_ticket_new') }}"
                               class="mt-2 inline-flex items-center rounded-lg bg-green-600 px-4 py-2 text-sm font-semibold text-white hover:bg-green-700 transition">
                                + Create Ticket
                            </a>
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}