<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <title>Finovate - Nouvelle Réclamation</title>

  <link href="{{ asset('front/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
  <link rel="stylesheet" href="{{ asset('front/assets/css/fontawesome.css') }}">
  <link rel="stylesheet" href="{{ asset('front/assets/css/templatemo-finance-business.css') }}">

  <style>
    .page-shell { padding: 36px 0; }

    .sidebar {
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(15, 118, 110, 0.14);
      box-shadow: 0 14px 38px rgba(0, 0, 0, 0.06);
      padding: 16px;
      position: sticky;
      top: 16px;
    }

    .sidebar .title { font-weight: 900; margin: 0 0 10px 0; }

    .sidebar a {
      display: block;
      padding: 10px 12px;
      border-radius: 12px;
      color: #111827;
      font-weight: 700;
      text-decoration: none;
      border: 1px solid transparent;
    }

    .sidebar a:hover, .sidebar a.active {
      background: rgba(16, 185, 129, 0.08);
      border-color: rgba(16, 185, 129, 0.18);
      color: #0f766e;
    }
    
    .sidebar a.active { background: rgba(16, 185, 129, 0.12); }

    .card-shell {
        background: #fff;
        border-radius: 18px;
        padding: 32px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border: 1px solid rgba(15, 118, 110, 0.1);
    }
    
    .form-control {
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        padding: 12px 16px;
        font-weight: 500;
    }
    
    .form-control:focus {
        border-color: #0f766e;
        box-shadow: 0 0 0 3px rgba(15, 118, 110, 0.15);
    }
  </style>
</head>

<body>
  <header>
    <nav class="navbar navbar-expand-lg">
      <div class="container">
        <a class="navbar-brand" href="{{ path('front_home') }}">
          <h2>Finovate</h2>
        </a>
        <div class="collapse navbar-collapse" id="navbarResponsive">
          <ul class="navbar-nav ml-auto">
            <li class="nav-item"><a class="nav-link" href="{{ path('front_home') }}">Accueil</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('front_about') }}">À propos</a></li>
            <li class="nav-item active"><a class="nav-link" href="{{ path('user_dashboard') }}">Mon espace</a></li>
            <li class="nav-item"><a class="nav-link" href="{{ path('front_logout') }}">Déconnexion</a></li>
          </ul>
        </div>
      </div>
    </nav>
  </header>

  <div class="page-heading header-text">
    <div class="container">
      <div class="row">
        <div class="col-md-12">
          <h1>Ouvrir une Réclamation</h1>
          <span>Créer une nouvelle demande</span>
        </div>
      </div>
    </div>
  </div>

  <div class="page-shell">
    <div class="container">
      <div class="row">
        <div class="col-lg-3 mb-4">
          <div class="sidebar">
            <div class="title">Mon espace</div>
            <a href="{{ path('user_dashboard') }}">Dashboard</a>
            <a href="{{ path('user_transactions') }}">Transactions</a>
            <a href="{{ path('user_bills') }}">Factures</a>
            <a href="{{ path('user_dashboard') ~ '?section=edit' }}">Modifier le profil</a>
            <a href="{{ path('app_ticket_index') }}">Réclamations</a>
            <a href="{{ path('app_ticket_messagerie') }}">Messagerie</a>
            <a href="{{ path('front_logout') }}">Déconnexion</a>
          </div>
        </div>

        <div class="col-lg-9">
          <div class="card-shell">
            <h4 style="font-weight:900;margin:0">Informations de la demande</h4>
            <div class="text-muted mb-4" style="font-weight:600">Veuillez décrire votre problème en détail</div>

            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
              <div class="form-row">
                <div class="form-group col-md-8">
                  {{ form_row(form.type) }}
                </div>
                <div class="form-group col-md-4">
                  {{ form_row(form.priorite) }}
                </div>
              </div>
              <div class="form-group">
                {{ form_row(form.description) }}
              </div>

              <div class="d-flex justify-content-between mt-4">
                <a href="{{ path('app_ticket_index') }}" class="btn btn-light" style="border-radius: 999px; font-weight: bold; padding: 12px 24px;">Annuler</a>
                <button type="submit" class="btn btn-success" style="border-radius: 999px; font-weight: bold; padding: 12px 24px; box-shadow: 0 4px 14px rgba(16, 185, 129, 0.4);">Soumettre la Réclamation</button>
              </div>
            {{ form_end(form) }}
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
