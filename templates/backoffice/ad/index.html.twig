<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Finovate - Gestion des Annonces</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('backoffice/assets/images/favicon_io/apple-touch-icon.png') }}">
  <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('backoffice/assets/images/favicon_io/favicon-32x32.png') }}">
  <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('backoffice/assets/images/favicon_io/favicon-16x16.png') }}">
  <base href="{{ asset('backoffice/') }}">
  <link rel="stylesheet" href="{{ asset('backoffice/assets/css/main.css') }}">
  <style>
    #sidebar {
      max-height: calc(100vh - 12px);
      overflow-y: auto;
      overscroll-behavior: contain;
    }
  </style>
</head>
<body>
  <!-- TOPBAR -->
  <nav id="topbar" class="navbar bg-white border-bottom fixed-top topbar px-3">
    <div class="d-flex align-items-center justify-content-between w-100">
      <div class="d-flex align-items-center">
        <a href="{{ path('backoffice_dashboard') }}" class="btn btn-light btn-icon btn-sm me-3">
          <i class="ti ti-arrow-left"></i>
        </a>
        <h1 class="fs-4 mb-0">Gestion des Annonces</h1>
      </div>
      <a href="{{ path('backoffice_ad_create') }}" class="btn btn-primary btn-sm">
        <i class="ti ti-plus"></i> Nouvelle Annonce
      </a>
    </div>
  </nav>

  <!-- SIDEBAR -->
  <aside id="sidebar" class="sidebar">
    <div class="logo-area">
      <a href="{{ path('backoffice_dashboard') }}" class="d-inline-flex align-items-center text-decoration-none">
        <span class="logo-text ms-2 fw-bold" style="font-size: 1.25rem; letter-spacing: 0.2px;">Finovate</span>
      </a>
    </div>
    <ul class="nav flex-column">
      <li class="px-4 py-2"><small class="nav-text">Banque Virtuelle</small></li>
      <li><a class="nav-link" href="{{ path('backoffice_dashboard') }}"><i class="ti ti-home"></i><span class="nav-text">Vue d'ensemble</span></a></li>
      <li><a class="nav-link" href="{{ path('backoffice_users') }}"><i class="ti ti-users"></i><span class="nav-text">Gestion Utilisateurs</span></a></li>
      <li><a class="nav-link" href="{{ path('backoffice_projects') }}"><i class="ti ti-briefcase"></i><span class="nav-text">Gestion Projets</span></a></li>
      <li class="nav-folder">
        <button class="nav-link nav-folder-btn w-100 text-start border-0 bg-transparent d-flex align-items-center" onclick="toggleForumFolder(this)">
          <i class="ti ti-shopping-cart"></i><span class="nav-text flex-grow-1">Produits</span><i class="ti ti-chevron-down folder-chevron ms-auto"></i>
        </button>
        <ul class="nav flex-column nav-folder-children ps-3">
          <li><a class="nav-link" href="{{ path('backoffice_products') }}"><i class="ti ti-list"></i><span class="nav-text">Liste des produits</span></a></li>
          <li><a class="nav-link" href="{{ path('admin_products_statistics') }}"><i class="ti ti-chart-bar"></i><span class="nav-text">Statistiques</span></a></li>
        </ul>
      </li>
      <li><a class="nav-link active" href="{{ path('backoffice_ads') }}"><i class="ti ti-bulb"></i><span class="nav-text">Annonces</span></a></li>
      <li><a class="nav-link" href="{{ path('admin_reclamations_index') }}"><i class="ti ti-headset"></i><span class="nav-text">Réclamations</span></a></li>
      <li class="px-4 pt-3 pb-1"><small class="nav-text">Forum</small></li>
      <li>
        <button class="nav-link folder-toggle w-100 text-start border-0 bg-transparent d-flex align-items-center gap-2" onclick="toggleForumFolder(this)" type="button">
          <i class="ti ti-messages"></i><span class="nav-text flex-grow-1">Gestion Forums</span><i class="ti ti-chevron-right ms-auto folder-arrow"></i>
        </button>
      </li>
      <div id="forumChildren" style="display:none;padding-left:16px;">
        <li><a class="nav-link" href="{{ path('backoffice_forums') }}"><i class="ti ti-list"></i><span class="nav-text">Liste des forums</span></a></li>
        <li><a class="nav-link" href="{{ path('admin_overview') }}"><i class="ti ti-layout-dashboard"></i><span class="nav-text">Vue d'ensemble</span></a></li>
        <li><a class="nav-link" href="{{ path('admin_users') }}"><i class="ti ti-users-group"></i><span class="nav-text">Utilisateurs</span></a></li>
        <li><a class="nav-link" href="{{ path('admin_ai_flags') }}"><i class="ti ti-robot"></i><span class="nav-text">IA Flags</span></a></li>
        <li><a class="nav-link" href="{{ path('admin_reports') }}"><i class="ti ti-flag"></i><span class="nav-text">Signalements</span></a></li>
        <li><a class="nav-link" href="{{ path('admin_badges') }}"><i class="ti ti-trophy"></i><span class="nav-text">Badges</span></a></li>
        <li><a class="nav-link" href="{{ path('admin_admin_policy') }}"><i class="ti ti-file-text"></i><span class="nav-text">Politique</span></a></li>
      </div>
      <li class="px-4 pt-4 pb-2"><small class="nav-text">Session</small></li>
      <li><a class="nav-link" href="{{ path('front_logout') }}"><i class="ti ti-logout"></i><span class="nav-text">Déconnexion</span></a></li>
    </ul>
  </aside>

  <!-- MAIN CONTENT -->
  <main id="content" class="content py-10">
    <div class="container-fluid">
      <div class="row">
        <div class="col-12">
          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between flex-wrap gap-3">
              <div class="d-flex align-items-center gap-2">
                <a class="btn btn-light btn-icon btn-sm" href="{{ path('backoffice_ads', {'search': search, 'sort': 'title', 'dir': 'ASC'}) }}" title="Tri A → Z">
                  <i class="ti ti-arrow-up"></i>
                </a>
                <a class="btn btn-light btn-icon btn-sm" href="{{ path('backoffice_ads', {'search': search, 'sort': 'title', 'dir': 'DESC'}) }}" title="Tri Z → A">
                  <i class="ti ti-arrow-down"></i>
                </a>
                <h4 class="mb-0">Liste des annonces</h4>
              </div>
              <form action="{{ path('backoffice_ads') }}" method="get" class="d-flex align-items-center">
      <li><a class="nav-link" href="{{ path('admin_reclamations_index') }}"><i class="ti ti-headset"></i><span class="nav-text">Réclamations</span></a></li>
                <div class="input-group">
                  <input type="text" name="search" class="form-control form-control-sm" placeholder="Rechercher une annonce..." value="{{ search }}">
                  <input type="hidden" name="sort" value="{{ sort|default('title') }}">
                  <input type="hidden" name="dir" value="{{ dir|default('ASC') }}">
                  <button class="btn btn-primary btn-sm" type="submit">
                    <i class="ti ti-search"></i> Rechercher
                  </button>
                  {% if search %}
                    <a href="{{ path('backoffice_ads') }}" class="btn btn-outline-secondary btn-sm">Réinitialiser</a>
      <li><a class="nav-link" href="{{ path('admin_reclamations_index') }}"><i class="ti ti-headset"></i><span class="nav-text">Réclamations</span></a></li>
                  {% endif %}
                </div>
              </form>
            </div>
            <div class="card-body p-0">
              {% if ads is empty %}
                <div class="alert alert-info m-3">Aucune annonce trouvée.</div>
              {% else %}
                <table class="table table-hover mb-0">
                  <thead>
                    <tr>
                      <th>#</th>
                      <th>Titre</th>
                      <th>Durée (secondes)</th>
                      <th>Points Récompense</th>
                      <th>Image</th>
                      <th>Clics</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for ad in ads %}
                    <tr>
                      <td><strong>{{ ad.id }}</strong></td>
                      <td>{{ ad.title }}</td>
                      <td>{{ ad.duration }}</td>
                      <td><badge class="badge bg-info">{{ ad.rewardPoints }}</badge></td>
                      <td>
                        {% if ad.imagePath %}
                          <img src="{{ asset(ad.imagePath) }}" alt="{{ ad.title }}" style="max-height: 40px;" class="rounded">
                        {% else %}
                          <span class="text-muted">-</span>
                        {% endif %}
                      </td>
                      <td>
                        <a href="{{ path('backoffice_ad_clicks', {'id': ad.id}) }}" class="btn btn-sm btn-outline-info">
                          <i class="ti ti-click"></i> {{ ad.userAdClicks|length }}
                        </a>
                      </td>
                      <td>
                        <a href="{{ path('backoffice_ad_edit', {'id': ad.id}) }}" class="btn btn-sm btn-outline-primary" title="Éditer">
                          <i class="ti ti-pencil"></i>
                        </a>
                        <form action="{{ path('backoffice_ad_delete', {'id': ad.id}) }}" method="POST" style="display:inline;" onsubmit="return confirm('Êtes-vous sûr ?');">
                          <input type="hidden" name="_token" value="{{ csrf_token('delete_ad_' ~ ad.id) }}">
                          <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">
                            <i class="ti ti-trash"></i>
                          </button>
                        </form>
                      </td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <script src="{{ asset('backoffice/assets/js/main.js') }}"></script>
  <script>
    function toggleForumFolder(btn) {
      var children = document.getElementById('forumChildren');
      var arrow = btn.querySelector('.folder-arrow');
      if (children.style.display === 'none') {
        children.style.display = 'block';
        if (arrow) { arrow.classList.remove('ti-chevron-right'); arrow.classList.add('ti-chevron-down'); }
      } else {
        children.style.display = 'none';
        if (arrow) { arrow.classList.remove('ti-chevron-down'); arrow.classList.add('ti-chevron-right'); }
      }
    }
  </script>
</body>
</html>