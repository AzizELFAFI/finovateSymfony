<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>Finovate - Activités Utilisateur</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('backoffice/assets/images/favicon_io/apple-touch-icon.png') }}">
  <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('backoffice/assets/images/favicon_io/favicon-32x32.png') }}">
  <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('backoffice/assets/images/favicon_io/favicon-16x16.png') }}">

  <base href="{{ asset('backoffice/') }}">
  <link rel="stylesheet" href="{{ asset('backoffice/assets/css/main.css') }}">
</head>

<body>
  <nav id="topbar" class="navbar bg-white border-bottom fixed-top topbar px-3">
    <div class="d-flex align-items-center">
      <a href="{{ path('backoffice_users') }}" class="btn btn-light btn-icon btn-sm me-3" title="Retour">
        <i class="ti ti-arrow-left"></i>
      </a>
      <h1 class="fs-4 mb-0">Activités : {{ user.firstname }} {{ user.lastname }}</h1>
    </div>
  </nav>

  <aside id="sidebar" class="sidebar">
    <div class="logo-area">
      <a href="{{ path('backoffice_dashboard') }}" class="d-inline-flex align-items-center text-decoration-none">
        <span class="logo-text ms-2 fw-bold" style="font-size: 1.25rem; letter-spacing: 0.2px;">Finovate</span>
      </a>
    </div>
    <ul class="nav flex-column">
      <li class="px-4 py-2"><small class="nav-text">Banque Virtuelle</small></li>
      <li><a class="nav-link" href="{{ path('backoffice_dashboard') }}"><i class="ti ti-home"></i><span class="nav-text">Vue d'ensemble</span></a></li>
      <li><a class="nav-link active" href="{{ path('backoffice_users') }}"><i class="ti ti-users"></i><span class="nav-text">Gestion Utilisateurs</span></a></li>
      <li class="px-4 pt-4 pb-2"><small class="nav-text">Session</small></li>
      <li><a class="nav-link" href="{{ path('front_logout') }}"><i class="ti ti-logout"></i><span class="nav-text">Déconnexion</span></a></li>
    </ul>
  </aside>

  <main id="content" class="content py-10">
    <div class="container-fluid">
      <div class="row g-3">
        <div class="col-12">
          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
              <h4 class="mb-0">Informations utilisateur</h4>
            </div>
            <div class="card-body">
              <div class="row g-2">
                <div class="col-md-4"><strong>Email:</strong> {{ user.email }}</div>
                <div class="col-md-4"><strong>Rôle:</strong> {{ user.role }}</div>
                <div class="col-md-4"><strong>Solde:</strong> {{ user.solde }} TND</div>
                <div class="col-md-4"><strong>CIN:</strong> {{ user.cin }}</div>
                <div class="col-md-4"><strong>Téléphone:</strong> {{ user.phone_number }}</div>
                <div class="col-md-4"><strong>N° Carte:</strong> <code>{{ user.numero_carte }}</code></div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12">
          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
              <h4 class="mb-0">Transactions</h4>
              <span class="badge bg-light text-dark">{{ transactions|length }}</span>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover table-centered mb-0 text-nowrap">
                  <thead class="table-light">
                    <tr>
                      <th>ID</th>
                      <th>Date</th>
                      <th>Type</th>
                      <th>Montant</th>
                      <th>Expéditeur</th>
                      <th>Bénéficiaire</th>
                      <th>Description</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for t in transactions %}
                      <tr>
                        <td>{{ t.id }}</td>
                        <td>{{ t.date|date('d/m/Y H:i') }}</td>
                        <td>{{ t.type }}</td>
                        <td class="fw-bold">{{ t.amount }}</td>
                        <td>
                          {% set senderKey = t.sender_id|striptags %}
                          {% if usersById[senderKey] is defined %}
                            {{ usersById[senderKey].firstname }} {{ usersById[senderKey].lastname }}
                          {% else %}
                            {{ t.sender_id }}
                          {% endif %}
                        </td>
                        <td>
                          {% set receiverKey = t.receiver_id|striptags %}
                          {% if usersById[receiverKey] is defined %}
                            {{ usersById[receiverKey].firstname }} {{ usersById[receiverKey].lastname }}
                          {% else %}
                            {{ t.receiver_id }}
                          {% endif %}
                        </td>
                        <td>{{ t.description }}</td>
                      </tr>
                    {% else %}
                      <tr>
                        <td colspan="7" class="text-center py-4">Aucune transaction trouvée.</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12">
          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
              <h4 class="mb-0">Goals</h4>
              <span class="badge bg-light text-dark">{{ goals|length }}</span>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover table-centered mb-0 text-nowrap">
                  <thead class="table-light">
                    <tr>
                      <th>ID</th>
                      <th>Titre</th>
                      <th>Deadline</th>
                      <th>Créé le</th>
                      <th>Statut</th>
                      <th>Objectif</th>
                      <th>Actuel</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for g in goals %}
                      <tr>
                        <td>{{ g.id }}</td>
                        <td class="fw-bold">{{ g.title }}</td>
                        <td>{{ g.deadline|date('d/m/Y') }}</td>
                        <td>{{ g.created_at|date('d/m/Y') }}</td>
                        <td>{{ g.status }}</td>
                        <td>{{ g.target_amount }}</td>
                        <td>{{ g.current_amount }}</td>
                      </tr>
                    {% else %}
                      <tr>
                        <td colspan="7" class="text-center py-4">Aucun goal trouvé.</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12">
          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
              <h4 class="mb-0">Factures payées</h4>
              <span class="badge bg-light text-dark">{{ bills|length }}</span>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover table-centered mb-0 text-nowrap">
                  <thead class="table-light">
                    <tr>
                      <th>ID</th>
                      <th>Référence</th>
                      <th>Montant</th>
                      <th>Date paiement</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for b in bills %}
                      <tr>
                        <td>{{ b.id }}</td>
                        <td class="fw-bold">{{ b.reference }}</td>
                        <td>{{ b.amount }}</td>
                        <td>{{ b.date_paiement|date('d/m/Y') }}</td>
                      </tr>
                    {% else %}
                      <tr>
                        <td colspan="4" class="text-center py-4">Aucune facture trouvée.</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>

  <footer class="text-center py-2 mt-6 text-secondary ">
    <p class="mb-0">Copyright © 2026 Finovate. Tous droits réservés.</p>
  </footer>

  <script src="{{ asset('backoffice/assets/js/main.js') }}" type="module"></script>
</body>

</html>
