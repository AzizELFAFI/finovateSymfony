<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>Finovate - Gestion Utilisateurs</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('backoffice/assets/images/favicon_io/apple-touch-icon.png') }}">
  <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('backoffice/assets/images/favicon_io/favicon-32x32.png') }}">
  <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('backoffice/assets/images/favicon_io/favicon-16x16.png') }}">
  
  <base href="{{ asset('backoffice/') }}">
  <link rel="stylesheet" href="{{ asset('backoffice/assets/css/main.css') }}">
</head>

<body>
  <!-- TOPBAR -->
  <nav id="topbar" class="navbar bg-white border-bottom fixed-top topbar px-3">
    <div class="d-flex align-items-center">
      <a href="{{ path('backoffice_dashboard') }}" class="btn btn-light btn-icon btn-sm me-3">
        <i class="ti ti-arrow-left"></i>
      </a>
      <h1 class="fs-4 mb-0">Gestion des Utilisateurs</h1>
    </div>
  </nav>

  <!-- SIDEBAR (Simplified for users page) -->
  <aside id="sidebar" class="sidebar">
    <div class="logo-area">
     <a href="{{ path('backoffice_dashboard') }}" class="d-inline-flex align-items-center text-decoration-none">
        <span class="logo-text ms-2 fw-bold" style="font-size: 1.25rem; letter-spacing: 0.2px;">Finovate</span>
      </a>
    </div>
    <ul class="nav flex-column">
      <li class="px-4 py-2"><small class="nav-text">Banque Virtuelle</small></li>
      <li><a class="nav-link" href="{{ path('backoffice_dashboard') }}"><i class="ti ti-home"></i><span class="nav-text">Vue d'ensemble</span></a></li>
      <li><a class="nav-link active" href="{{ path('backoffice_users') }}"><i class="ti ti-users"></i><span class="nav-text">Gestion Utilisateurs</span></a></li>
      <li class="px-4 pt-4 pb-2"><small class="nav-text">Session</small></li>
      <li><a class="nav-link" href="{{ path('front_logout') }}"><i class="ti ti-logout"></i><span class="nav-text">Déconnexion</span></a></li>
    </ul>
  </aside>

  <!-- MAIN CONTENT -->
  <main id="content" class="content py-10">
    <div class="container-fluid">
      <div class="row">
        <div class="col-12">
          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between flex-wrap gap-3">
              <div class="d-flex align-items-center gap-2">
                <a class="btn btn-light btn-icon btn-sm" href="{{ path('backoffice_users', {'search': search, 'sort': 'lastname', 'dir': 'ASC'}) }}" title="Tri A → Z">
                  <i class="ti ti-arrow-up"></i>
                </a>
                <a class="btn btn-light btn-icon btn-sm" href="{{ path('backoffice_users', {'search': search, 'sort': 'lastname', 'dir': 'DESC'}) }}" title="Tri Z → A">
                  <i class="ti ti-arrow-down"></i>
                </a>
                <h4 class="mb-0">Liste complète des utilisateurs</h4>
              </div>
              <div class="d-flex align-items-center gap-2 flex-wrap">
                <div class="btn-group" role="group" aria-label="Filtre rôle">
                  <a class="btn btn-sm {{ role is empty ? 'btn-primary' : 'btn-outline-primary' }}" href="{{ path('backoffice_users', {'search': search, 'sort': sort|default('lastname'), 'dir': dir|default('ASC')}) }}">Tous</a>
                  <a class="btn btn-sm {{ role == 'ADMIN' ? 'btn-primary' : 'btn-outline-primary' }}" href="{{ path('backoffice_users', {'role': 'ADMIN', 'search': search, 'sort': sort|default('lastname'), 'dir': dir|default('ASC')}) }}">Admins</a>
                  <a class="btn btn-sm {{ role == 'USER' ? 'btn-primary' : 'btn-outline-primary' }}" href="{{ path('backoffice_users', {'role': 'USER', 'search': search, 'sort': sort|default('lastname'), 'dir': dir|default('ASC')}) }}">Users</a>
                </div>

                <form action="{{ path('backoffice_users') }}" method="get" class="d-flex align-items-center">
                  <div class="input-group">
                    <input type="text" name="search" class="form-control form-control-sm" placeholder="Rechercher un utilisateur..." value="{{ search }}">
                    <input type="hidden" name="role" value="{{ role }}">
                    <input type="hidden" name="sort" value="{{ sort|default('lastname') }}">
                    <input type="hidden" name="dir" value="{{ dir|default('ASC') }}">
                    <button class="btn btn-primary btn-sm" type="submit">
                      <i class="ti ti-search"></i> Rechercher
                    </button>
                    {% if search %}
                      <a href="{{ path('backoffice_users', {'role': role, 'sort': sort|default('lastname'), 'dir': dir|default('ASC')}) }}" class="btn btn-outline-secondary btn-sm">Réinitialiser</a>
                    {% endif %}
                  </div>
                </form>
              </div>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover table-centered mb-0 text-nowrap">
                  <thead class="table-light">
                    <tr>
                      <th>Email</th>
                      <th>Nom</th>
                      <th>Prénom</th>
                      <th>Rôle</th>
                      <th>Solde (TND)</th>
                      <th>Points</th>
                      <th>Date Naissance</th>
                      <th>CIN</th>
                      <th>Téléphone</th>
                      <th>N° Carte</th>
                      <th>Créé le</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for user in users %}
                    <tr>
                      <td class="fw-bold">{{ user.email }}</td>
                      <td>{{ user.lastname }}</td>
                      <td>{{ user.firstname }}</td>
                      <td>
                        {% if user.role == 'ADMIN' %}
                          <span class="badge bg-danger">Admin</span>
                        {% else %}
                          <span class="badge bg-primary">Client</span>
                        {% endif %}
                      </td>
                      <td class="text-success fw-bold">{{ user.solde }}</td>
                      <td>{{ user.points }}</td>
                      <td>{{ user.birthdate|date('d/m/Y') }}</td>
                      <td>{{ user.cin }}</td>
                      <td>{{ user.phone_number }}</td>
                      <td><code>{{ user.numero_carte }}</code></td>
                      <td>{{ user.getCreated_at()|date('d/m/Y H:i') }}</td>
                    </tr>
                    {% else %}
                    <tr>
                      <td colspan="11" class="text-center py-4">Aucun utilisateur trouvé dans la base de données.</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <footer class="text-center py-2 mt-6 text-secondary ">
    <p class="mb-0">Copyright © 2026 Finovate. Tous droits réservés.</p>
  </footer>

  <script src="{{ asset('backoffice/assets/js/main.js') }}" type="module"></script>
</body>
</html>
