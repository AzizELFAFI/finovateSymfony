<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Finovate - Gestion des Produits</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('backoffice/assets/images/favicon_io/apple-touch-icon.png') }}">
  <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('backoffice/assets/images/favicon_io/favicon-32x32.png') }}">
  <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('backoffice/assets/images/favicon_io/favicon-16x16.png') }}">
  <base href="{{ asset('backoffice/') }}">
  <link rel="stylesheet" href="{{ asset('backoffice/assets/css/main.css') }}">
</head>
<body>
  <!-- TOPBAR -->
  <nav id="topbar" class="navbar bg-white border-bottom fixed-top topbar px-3">
    <div class="d-flex align-items-center justify-content-between w-100">
      <div class="d-flex align-items-center">
        <a href="{{ path('backoffice_dashboard') }}" class="btn btn-light btn-icon btn-sm me-3">
          <i class="ti ti-arrow-left"></i>
        </a>
        <h1 class="fs-4 mb-0">Gestion des Produits</h1>
      </div>
      <a href="{{ path('backoffice_product_create') }}" class="btn btn-primary btn-sm">
        <i class="ti ti-plus"></i> Nouveau Produit
      </a>
    </div>
  </nav>

  <!-- SIDEBAR -->
  <aside id="sidebar" class="sidebar">
    <div class="logo-area">
      <a href="{{ path('backoffice_dashboard') }}" class="d-inline-flex align-items-center text-decoration-none">
        <span class="logo-text ms-2 fw-bold" style="font-size: 1.25rem; letter-spacing: 0.2px;">Finovate</span>
      </a>
    </div>
    <ul class="nav flex-column">
      <li class="px-4 py-2"><small class="nav-text">Banque Virtuelle</small></li>
      <li><a class="nav-link" href="{{ path('backoffice_dashboard') }}"><i class="ti ti-home"></i><span class="nav-text">Vue d'ensemble</span></a></li>
      <li><a class="nav-link" href="{{ path('backoffice_users') }}"><i class="ti ti-users"></i><span class="nav-text">Gestion Utilisateurs</span></a></li>
      <li><a class="nav-link" href="{{ path('backoffice_projects') }}"><i class="ti ti-briefcase"></i><span class="nav-text">Gestion Projets</span></a></li>
      <li><a class="nav-link active" href="{{ path('backoffice_products') }}"><i class="ti ti-shopping-cart"></i><span class="nav-text">Produits</span></a></li>
      <li><a class="nav-link" href="{{ path('backoffice_ads') }}"><i class="ti ti-bulb"></i><span class="nav-text">Annonces</span></a></li>
      <li class="px-4 pt-4 pb-2"><small class="nav-text">Session</small></li>
      <li><a class="nav-link" href="{{ path('front_logout') }}"><i class="ti ti-logout"></i><span class="nav-text">Déconnexion</span></a></li>
    </ul>
  </aside>

  <!-- MAIN CONTENT -->
  <main id="content" class="content py-10">
    <div class="container-fluid">
      <div class="row">
        <div class="col-12">
          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between flex-wrap gap-3">
              <div class="d-flex align-items-center gap-2">
                <a class="btn btn-light btn-icon btn-sm" href="{{ path('backoffice_products', {'search': search, 'sort': 'name', 'dir': 'ASC'}) }}" title="Tri A → Z">
                  <i class="ti ti-arrow-up"></i>
                </a>
                <a class="btn btn-light btn-icon btn-sm" href="{{ path('backoffice_products', {'search': search, 'sort': 'name', 'dir': 'DESC'}) }}" title="Tri Z → A">
                  <i class="ti ti-arrow-down"></i>
                </a>
                <h4 class="mb-0">Liste des produits</h4>
              </div>
              <form action="{{ path('backoffice_products') }}" method="get" class="d-flex align-items-center">
                <div class="input-group">
                  <input type="text" name="search" class="form-control form-control-sm" placeholder="Rechercher un produit..." value="{{ search }}">
                  <input type="hidden" name="sort" value="{{ sort|default('name') }}">
                  <input type="hidden" name="dir" value="{{ dir|default('ASC') }}">
                  <button class="btn btn-primary btn-sm" type="submit">
                    <i class="ti ti-search"></i> Rechercher
                  </button>
                  {% if search %}
                    <a href="{{ path('backoffice_products') }}" class="btn btn-outline-secondary btn-sm">Réinitialiser</a>
                  {% endif %}
                </div>
              </form>
            </div>
            <div class="card-body p-0">
              {% if products is empty %}
                <div class="alert alert-info m-3">Aucun produit trouvé.</div>
              {% else %}
                <table class="table table-hover mb-0">
                  <thead>
                    <tr>
                      <th>#</th>
                      <th>Nom</th>
                      <th>Description</th>
                      <th>Prix (Points)</th>
                      <th>Stock</th>
                      <th>Image</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for product in products %}
                    <tr>
                      <td><strong>{{ product.id }}</strong></td>
                      <td>{{ product.name }}</td>
                      <td>{{ product.description ? product.description: '-' }}</td>
                      <td><badge class="badge bg-primary">{{ product.pricePoints }}</badge></td>
                      <td>
                        <badge class="badge {{ product.stock > 10 ? 'bg-success' : (product.stock > 0 ? 'bg-warning' : 'bg-danger') }}">
                          {{ product.stock }}
                        </badge>
                      </td>
                      <td>
                        {% if product.image %}
                          <img src="{{ asset(product.image) }}" alt="{{ product.name }}" style="max-height: 40px;" class="rounded">
                        {% else %}
                          <span class="text-muted">-</span>
                        {% endif %}
                      </td>
                      <td>
                        <a href="{{ path('backoffice_product_edit', {'id': product.id}) }}" class="btn btn-sm btn-outline-primary" title="Éditer">
                          <i class="ti ti-pencil"></i>
                        </a>
                        <form action="{{ path('backoffice_product_delete', {'id': product.id}) }}" method="POST" style="display:inline;" onsubmit="return confirm('Êtes-vous sûr ?');">
                          <input type="hidden" name="_token" value="{{ csrf_token('delete_product_' ~ product.id) }}">
                          <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">
                            <i class="ti ti-trash"></i>
                          </button>
                        </form>
                      </td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <script src="{{ asset('backoffice/assets/js/main.js') }}"></script>
</body>
</html>