<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>Finovate - Statistiques Produits</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('backoffice/assets/images/favicon_io/apple-touch-icon.png') }}">
  <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('backoffice/assets/images/favicon_io/favicon-32x32.png') }}">
  <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('backoffice/assets/images/favicon_io/favicon-16x16.png') }}">
  
  <base href="{{ asset('backoffice/') }}">
  <link rel="stylesheet" href="{{ asset('backoffice/assets/css/main.css') }}">
  <style>
    #sidebar {
      max-height: calc(100vh - 12px);
      overflow-y: auto;
      overscroll-behavior: contain;
    }
  </style>
</head>

<body>
  <!-- TOPBAR -->
  <nav id="topbar" class="navbar bg-white border-bottom fixed-top topbar px-3">
    <div class="d-flex align-items-center">
      <a href="{{ path('backoffice_dashboard') }}" class="btn btn-light btn-icon btn-sm me-3">
        <i class="ti ti-arrow-left"></i>
      </a>
      <h1 class="fs-4 mb-0">Statistiques Produits</h1>
    </div>
  </nav>

  <!-- SIDEBAR -->
  <aside id="sidebar" class="sidebar">
    <div class="logo-area">
     <a href="{{ path('backoffice_dashboard') }}" class="d-inline-flex align-items-center text-decoration-none">
        <span class="logo-text ms-2 fw-bold" style="font-size: 1.25rem; letter-spacing: 0.2px;">Finovate</span>
      </a>
    </div>
    <ul class="nav flex-column">
      <li class="px-4 py-2"><small class="nav-text">Banque Virtuelle</small></li>
      <li><a class="nav-link" href="{{ path('backoffice_dashboard') }}"><i class="ti ti-home"></i><span class="nav-text">Vue d'ensemble</span></a></li>
      <li><a class="nav-link" href="{{ path('backoffice_users') }}"><i class="ti ti-users"></i><span class="nav-text">Gestion Utilisateurs</span></a></li>
      <li><a class="nav-link" href="{{ path('backoffice_projects') }}"><i class="ti ti-briefcase"></i><span class="nav-text">Gestion Projets</span></a></li>
      <li class="nav-folder">
        <button class="nav-link nav-folder-btn w-100 text-start border-0 bg-transparent d-flex align-items-center" onclick="toggleForumFolder(this)">
          <i class="ti ti-shopping-cart"></i><span class="nav-text flex-grow-1">Produits</span><i class="ti ti-chevron-down folder-chevron ms-auto"></i>
        </button>
        <ul class="nav flex-column nav-folder-children ps-3">
          <li><a class="nav-link" href="{{ path('backoffice_products') }}"><i class="ti ti-list"></i><span class="nav-text">Liste des produits</span></a></li>
          <li><a class="nav-link active" href="{{ path('admin_products_statistics') }}"><i class="ti ti-chart-bar"></i><span class="nav-text">Statistiques</span></a></li>
        </ul>
      </li>
      <li><a class="nav-link" href="{{ path('backoffice_ads') }}"><i class="ti ti-bulb"></i><span class="nav-text">Annonces</span></a></li>
      <li><a class="nav-link" href="{{ path('admin_reclamations_index') }}"><i class="ti ti-headset"></i><span class="nav-text">Réclamations</span></a></li>
      <li class="nav-folder">
        <button class="nav-link nav-folder-btn w-100 text-start border-0 bg-transparent d-flex align-items-center" onclick="toggleForumFolder(this)">
          <i class="ti ti-messages"></i><span class="nav-text flex-grow-1">Gestion Forums</span><i class="ti ti-chevron-down folder-chevron ms-auto"></i>
        </button>
        <ul class="nav flex-column nav-folder-children ps-3">
          <li><a class="nav-link" href="{{ path('backoffice_forums') }}"><i class="ti ti-list"></i><span class="nav-text">Liste des forums</span></a></li>
          <li><a class="nav-link" href="{{ path('admin_liste_posts') }}"><i class="ti ti-file-text"></i><span class="nav-text">Liste des posts</span></a></li>
          <li><a class="nav-link" href="{{ path('admin_liste_comments') }}"><i class="ti ti-message"></i><span class="nav-text">Liste des commentaires</span></a></li>
          <li><a class="nav-link" href="{{ path('admin_users') }}"><i class="ti ti-users"></i><span class="nav-text">Utilisateurs</span></a></li>
          <li><a class="nav-link" href="{{ path('admin_ai_flags') }}"><i class="ti ti-robot"></i><span class="nav-text">IA Flags</span></a></li>
          <li><a class="nav-link" href="{{ path('admin_reports') }}"><i class="ti ti-flag"></i><span class="nav-text">Signalements</span></a></li>
          <li><a class="nav-link" href="{{ path('admin_badges') }}"><i class="ti ti-award"></i><span class="nav-text">Badges</span></a></li>
          <li><a class="nav-link" href="{{ path('admin_admin_policy') }}"><i class="ti ti-file-text"></i><span class="nav-text">Politique</span></a></li>
        </ul>
      </li>
      <li class="px-4 pt-4 pb-2"><small class="nav-text">Session</small></li>
      <li><a class="nav-link" href="{{ path('front_logout') }}"><i class="ti ti-logout"></i><span class="nav-text">Déconnexion</span></a></li>
    </ul>
  </aside>

  <!-- MAIN CONTENT -->
  <main id="content" class="content py-10">
    <div class="container-fluid">

    {# Overview Cards #}
    <div class="row g-3 mb-4">
        <div class="col-lg-3 col-12">
            <div class="card p-4 bg-primary bg-opacity-10 border border-primary border-opacity-25 rounded-2">
                <div class="d-flex gap-3">
                    <div class="icon-shape icon-md bg-primary text-white rounded-2">
                        <i class="ti ti-package fs-4"></i>
                    </div>
                    <div>
                        <h2 class="mb-3 fs-6">Total Produits</h2>
                        <h3 class="fw-bold mb-0">{{ totalProducts }}</h3>
                        <p class="text-primary mb-0 small">Produits en catalogue</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-12">
            <div class="card p-4 bg-success bg-opacity-10 border border-success border-opacity-25 rounded-2">
                <div class="d-flex gap-3">
                    <div class="icon-shape icon-md bg-success text-white rounded-2">
                        <i class="ti ti-check fs-4"></i>
                    </div>
                    <div>
                        <h2 class="mb-3 fs-6">En Stock</h2>
                        <h3 class="fw-bold mb-0">{{ inStockProducts }}</h3>
                        <p class="text-success mb-0 small">Disponibles</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-12">
            <div class="card p-4 bg-danger bg-opacity-10 border border-danger border-opacity-25 rounded-2">
                <div class="d-flex gap-3">
                    <div class="icon-shape icon-md bg-danger text-white rounded-2">
                        <i class="ti ti-x fs-4"></i>
                    </div>
                    <div>
                        <h2 class="mb-3 fs-6">Rupture</h2>
                        <h3 class="fw-bold mb-0">{{ outOfStockProducts }}</h3>
                        <p class="text-danger mb-0 small">Indisponibles</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-12">
            <div class="card p-4 bg-warning bg-opacity-10 border border-warning border-opacity-25 rounded-2">
                <div class="d-flex gap-3">
                    <div class="icon-shape icon-md bg-warning text-white rounded-2">
                        <i class="ti ti-coins fs-4"></i>
                    </div>
                    <div>
                        <h2 class="mb-3 fs-6">Valeur Stock</h2>
                        <h3 class="fw-bold mb-0">{{ totalStockValue|number_format(0, ',', ' ') }}</h3>
                        <p class="text-warning mb-0 small">Points totaux</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Additional Stats #}
    <div class="row g-3 mb-4">
        <div class="col-lg-4 col-12">
            <div class="card p-4 bg-info bg-opacity-10 border border-info border-opacity-25 rounded-2">
                <div class="d-flex gap-3">
                    <div class="icon-shape icon-md bg-info text-white rounded-2">
                        <i class="ti ti-chart-line fs-4"></i>
                    </div>
                    <div>
                        <h2 class="mb-3 fs-6">Prix Moyen</h2>
                        <h3 class="fw-bold mb-0">{{ avgPrice }} pts</h3>
                        <p class="text-info mb-0 small">Par produit</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-12">
            <div class="card p-4 bg-secondary bg-opacity-10 border border-secondary border-opacity-25 rounded-2">
                <div class="d-flex gap-3">
                    <div class="icon-shape icon-md bg-secondary text-white rounded-2">
                        <i class="ti ti-heart fs-4"></i>
                    </div>
                    <div>
                        <h2 class="mb-3 fs-6">Total Favoris</h2>
                        <h3 class="fw-bold mb-0">{{ totalFavorites }}</h3>
                        <p class="text-secondary mb-0 small">Ajouts aux favoris</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-12">
            <div class="card p-4 bg-danger bg-opacity-10 border border-danger border-opacity-25 rounded-2">
                <div class="d-flex gap-3">
                    <div class="icon-shape icon-md bg-danger text-white rounded-2">
                        <i class="ti ti-alert-triangle fs-4"></i>
                    </div>
                    <div>
                        <h2 class="mb-3 fs-6">Alerte Stock</h2>
                        <h3 class="fw-bold mb-0">{{ lowStockProducts|length }}</h3>
                        <p class="text-danger mb-0 small">Stock &lt; 10</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Charts #}
    <div class="row g-3 mb-4">
        <div class="col-lg-6 col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="ti ti-chart-pie me-2"></i>Distribution du Stock</h5>
                </div>
                <div class="card-body">
                    <div style="height: 300px;">
                        <canvas id="stockDistributionChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6 col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="ti ti-chart-bar me-2"></i>Distribution des Prix</h5>
                </div>
                <div class="card-body">
                    <div style="height: 300px;">
                        <canvas id="priceDistributionChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Tables #}
    <div class="row g-3 mb-4">
        <div class="col-lg-6 col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="ti ti-trophy text-warning me-2"></i>Top Produits par Valeur</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Produit</th>
                                    <th>Stock</th>
                                    <th>Prix</th>
                                    <th>Valeur</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for product in topProductsByValue %}
                                <tr>
                                    <td>{{ product.name }}</td>
                                    <td><span class="badge bg-info">{{ product.stock }}</span></td>
                                    <td><span class="badge bg-warning text-dark">{{ product.pricePoints }} pts</span></td>
                                    <td><span class="badge bg-success">{{ product.totalValue|number_format(0, ',', ' ') }} pts</span></td>
                                </tr>
                                {% else %}
                                <tr><td colspan="4" class="text-center text-muted py-3">Aucun produit</td></tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6 col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="ti ti-heart text-danger me-2"></i>Produits les Plus Favoris</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Produit</th>
                                    <th>Favoris</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for product in mostFavorited %}
                                <tr>
                                    <td>{{ product.name }}</td>
                                    <td><span class="badge bg-danger"><i class="ti ti-heart me-1"></i>{{ product.favoriteCount }}</span></td>
                                </tr>
                                {% else %}
                                <tr><td colspan="2" class="text-center text-muted py-3">Aucun favori</td></tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Low Stock Alert #}
    <div class="row g-3">
        <div class="col-12">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="ti ti-alert-triangle me-2"></i>Alerte Stock Faible</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Produit</th>
                                    <th>Stock Restant</th>
                                    <th>Prix</th>
                                    <th>Statut</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for product in lowStockProducts %}
                                <tr>
                                    <td>{{ product.name }}</td>
                                    <td><span class="badge bg-warning text-dark">{{ product.stock }}</span></td>
                                    <td>{{ product.pricePoints }} pts</td>
                                    <td><span class="badge bg-danger">Stock Critique</span></td>
                                </tr>
                                {% else %}
                                <tr><td colspan="4" class="text-center text-success py-3">Aucun produit en stock critique</td></tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
// Stock Distribution Doughnut Chart
const stockDistCtx = document.getElementById('stockDistributionChart').getContext('2d');
new Chart(stockDistCtx, {
    type: 'doughnut',
    data: {
        labels: [{% for label, count in stockDistribution %}'{{ label }}'{% if not loop.last %}, {% endif %}{% endfor %}],
        datasets: [{
            data: [{% for label, count in stockDistribution %}{{ count }}{% if not loop.last %}, {% endif %}{% endfor %}],
            backgroundColor: ['#dc3545', '#ffc107', '#17a2b8', '#28a745'],
            borderWidth: 2,
            borderColor: '#fff'
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: { position: 'bottom' }
        }
    }
});

// Price Distribution Bar Chart
const priceDistCtx = document.getElementById('priceDistributionChart').getContext('2d');
new Chart(priceDistCtx, {
    type: 'bar',
    data: {
        labels: [{% for label, count in priceRanges %}'{{ label }} pts'{% if not loop.last %}, {% endif %}{% endfor %}],
        datasets: [{
            label: 'Nombre de produits',
            data: [{% for label, count in priceRanges %}{{ count }}{% if not loop.last %}, {% endif %}{% endfor %}],
            backgroundColor: ['rgba(40,167,69,0.7)', 'rgba(23,162,184,0.7)', 'rgba(255,193,7,0.7)', 'rgba(220,53,69,0.7)'],
            borderColor: ['#28a745', '#17a2b8', '#ffc107', '#dc3545'],
            borderWidth: 2
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } },
        plugins: { legend: { display: false } }
    }
});
</script>

<script src="{{ asset('backoffice/assets/js/main.js') }}"></script>
</body>
</html>
